---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About — hollow.logs"
  bodyClass="bg-[#0f0806] text-[#d4c4a8] font-sans min-h-screen relative"
>
  <!-- Mars atmosphere -->
  <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
    <div class="absolute inset-0"
         style="background:
           radial-gradient(ellipse 120% 50% at 50% 100%, rgba(232,112,64,0.08) 0%, transparent 60%),
           radial-gradient(ellipse 80% 40% at 30% 90%, rgba(196,90,60,0.06) 0%, transparent 50%);">
    </div>
  </div>

  <div class="relative z-10">
    <Nav variant="mars" logo="hollow.logs" />

    <main class="max-w-[680px] mx-auto px-5 sm:px-8 py-16 sm:py-24 pb-24">
      <!-- Signal bar -->
      <div class="font-mono text-[10px] sm:text-[11px] text-[#5a5044] tracking-[0.25em] uppercase mb-8 sm:mb-10 flex items-center gap-2">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-[#e87040] mars-pulse"></span>
        About
      </div>

      <h1 class="text-[2.5rem] sm:text-5xl font-bold leading-[1.1] tracking-tight mb-4 font-space">Xin chào.</h1>
      <p class="italic text-[#8a7d6b] text-[1.1rem] sm:text-[1.3rem] mb-12 border-l-2 border-[#e87040]/30 pl-4 sm:pl-5 leading-relaxed">
        Tôi là Phuong Nguyen, hay còn gọi là <span class="text-[#e87040]">Mars</span>. Đây là nơi tôi ghi lại những gì mình đang học.
      </p>

      <div class="space-y-6 text-[#d4c4a8]/85 text-lg leading-relaxed">
        <p>
          Blog này được tạo ra như một cuốn sổ tay công khai — nơi tôi sắp xếp lại những suy nghĩ, ghi chú từ sách, và các ý tưởng đang dần hình thành.
        </p>

        <p>
          Phần lớn nội dung ở đây là <em class="text-[#e87040]/70">work-in-progress</em> — những bài viết có thể được chỉnh sửa, mở rộng, hoặc rút gọn theo thời gian.
        </p>

        <h2 class="text-2xl font-bold text-[#d4c4a8] mt-12 mb-4 font-space">Disclaimer</h2>
        <p>
          Nội dung trên blog này phản ánh quan điểm cá nhân và quá trình học tập của tôi, không phải lời khuyên chuyên môn. Các bài viết có thể chứa sai sót hoặc hiểu biết chưa đầy đủ — tôi viết để học, không phải để dạy.
        </p>
        <p>
          Một số bài viết trên blog này được hỗ trợ bởi AI trong quá trình nghiên cứu, biên soạn, hoặc chỉnh sửa.
        </p>
        <p>
          Người đọc tự chịu trách nhiệm khi áp dụng bất kỳ thông tin nào từ blog này vào quyết định cá nhân, tài chính, hay chuyên môn của mình.
        </p>
      </div>
    </main>

    <Footer variant="mars" />
  </div>
</BaseLayout>

<style>
  .mars-pulse {
    animation: mars-glow 3s ease-in-out infinite;
  }
  @keyframes mars-glow {
    0%, 100% { opacity: 1; box-shadow: 0 0 4px rgba(232,112,64,0.6); }
    50% { opacity: 0.4; box-shadow: 0 0 2px rgba(232,112,64,0.2); }
  }
</style>
