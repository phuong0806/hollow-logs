---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Hiệu Ứng Dunning-Kruger: Bạn Tự Tin — Nhưng Có Khi Đó Là Triệu Chứng',
  description: 'Nghiên cứu gốc 1999 chưa bao giờ nói "người ngu không biết mình ngu." Nó nói điều tinh vi hơn nhiều — và toán học gần đây cho thấy biểu đồ viral bạn thấy trên mạng có thể chỉ là ảo ảnh thống kê.',
  pubDate: new Date('2026-04-25'),
  tags: ['psychology', 'science'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="LỖI NHẬN THỨC"
  kickerColor="emerald"
>
  <style>
    /* ─── Popovers (cyan theme) ───────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(34, 211, 238);
      border-bottom: 1px dashed rgba(34, 211, 238, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(34, 211, 238); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 300px;
      padding: 12px 14px; background: #0a1a2e;
      border: 1px solid rgba(34, 211, 238, 0.3);
      box-shadow: 0 8px 24px rgba(0,0,0,0.5);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(34, 211, 238, 0.3);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 240px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Timeline (cyan) ─────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(34, 211, 238, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(34, 211, 238, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(34, 211, 238); border-color: rgb(34, 211, 238);
      box-shadow: 0 0 8px rgba(34, 211, 238, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.success::before {
      background: rgb(52, 211, 153); border-color: rgb(52, 211, 153);
      box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(34, 211, 238); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.success .timeline-year { color: rgb(52, 211, 153); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.success .timeline-desc { color: rgb(209 250 229); font-weight: 600; }

    /* ─── Stat cards (cyan) ──────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(34, 211, 238);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(34, 211, 238, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(34, 211, 238, 0.12);
      color: rgb(34, 211, 238);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(34, 211, 238, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }
    .hl-amber {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }

    /* ─── Evidence bars ────────────────────────── */
    .evidence-row { margin-bottom: 12px; }
    .evidence-label {
      font-size: 0.78rem; font-weight: 600; color: rgb(203 213 225);
      margin-bottom: 4px;
    }
    .evidence-track {
      height: 28px; background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.2);
      position: relative; overflow: hidden;
    }
    .evidence-fill {
      height: 100%; display: flex; align-items: center;
      padding-left: 8px; font-size: 0.7rem; font-weight: 700;
    }

    /* ─── Redflag items ────────────────────────── */
    .redflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.03); margin-bottom: 10px;
    }
    .redflag-icon { color: rgb(239 68 68); flex-shrink: 0; margin-top: 2px; }
    .redflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .redflag-text strong { color: white; }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(34, 211, 238, 0.06);
      border: 1px solid rgba(34, 211, 238, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(34, 211, 238); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(34, 211, 238);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(34, 211, 238); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Study card ───────────────────────────── */
    .study-card {
      background: rgba(21, 31, 50, 0.4);
      border: 1px solid rgba(34, 211, 238, 0.15);
      padding: 16px; margin-bottom: 10px;
    }
    .study-num { font-size: 0.68rem; font-family: monospace; color: rgb(34, 211, 238); font-weight: 700; letter-spacing: 0.05em; margin-bottom: 4px; }
    .study-title { font-size: 0.9rem; font-weight: 700; color: white; margin-bottom: 6px; }
    .study-body { font-size: 0.85rem; line-height: 1.6; color: rgb(148 163 184); }
    .study-result {
      margin-top: 8px; padding: 8px 12px;
      background: rgba(34, 211, 238, 0.06);
      border-left: 2px solid rgba(34, 211, 238, 0.4);
      font-size: 0.82rem; color: rgb(203 213 225);
    }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-cyan-400 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-cyan-300 leading-snug">
        "Về bất kỳ chủ đề nào, những người không phải chuyên gia thiếu chính xác thứ chuyên môn mà họ cần để nhận ra mình thiếu bao nhiêu chuyên môn."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — David Dunning, phỏng vấn trên <em>Social Science Space</em> (2023)
      </footer>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- CONTEXT INTRO                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh</p>
        <p class="text-slate-300 text-sm leading-relaxed">Năm 1999, hai nhà tâm lý Cornell công bố paper cho thấy <span class="popover-wrap"><button class="popover-trigger">người kém nhất</button><span class="popover-bubble">Trong nghiên cứu gốc, "bottom quartile" — nhóm 25% có điểm thấp nhất — tự đánh giá mình ở phân vị 62, tức cao hơn thực tế ~50 bậc. Họ không chỉ kém — họ không biết mình kém.</span></span> tự đánh giá mình cao hơn thực tế ~50 bậc. Paper đó trở thành <strong class="text-white">một trong những hiệu ứng tâm lý được trích dẫn nhiều nhất mọi thời đại</strong>.</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed">Mạng xã hội biến Dunning-Kruger thành vũ khí: <span class="hl-red">"Bạn quá ngu để biết mình ngu."</span> Nhưng paper gốc chưa bao giờ nói điều đó. Và các nhà thống kê cho thấy biểu đồ viral có thể được tạo ra từ <strong class="text-white">dữ liệu ngẫu nhiên hoàn toàn</strong>.</p>
      </div>
      <div class="border border-cyan-500/20 bg-cyan-950/10 p-4">
        <p class="text-xs font-mono text-cyan-400 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed"><span class="hl">4 thí nghiệm gốc</span> mà không ai đọc. <span class="hl-red">Phản bác thống kê</span> — dữ liệu ngẫu nhiên tái tạo hiệu ứng. <span class="hl-amber">Mô hình Bayesian 2021</span> lật ngược cơ chế. <span class="hl-green">Văn hoá Đông Á</span> làm hiệu ứng biến mất. Và cách phân biệt <span class="hl">tự tin thật</span> với <span class="hl-red">tự tin giả</span>.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- STATS OVERVIEW                                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="stat-card">
        <div class="stat-num">~50</div>
        <div class="stat-label">Bậc phân vị nhóm kém tự đánh giá quá cao</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">36%</div>
        <div class="stat-label">Người Mỹ nghĩ mình biết hơn bác sĩ về tự kỷ</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">929</div>
        <div class="stat-label">Mẫu nghiên cứu phản bác DK là "ảo ảnh thống kê"</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">d = 0.84</div>
        <div class="stat-label">Chênh lệch tự đánh giá Đông-Tây (meta-analysis)</div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- MỞ BÀI                                                 -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border border-slate-700/40 bg-slate-900/20 p-6">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Bạn đã thấy biểu đồ đó. Trục X là "năng lực thực tế," trục Y là "sự tự tin." Một đường cong lên cao vút ở phía trái — người kém thì tự tin nhất — rồi rơi xuống "Thung lũng tuyệt vọng" trước khi leo lại từ từ. Nó xuất hiện trên LinkedIn, Reddit, Twitter, podcast, và trong mọi cuộc tranh cãi trên mạng khi ai đó muốn nói: <em>"Bạn quá ngu để biết mình ngu."</em></p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Có một vấn đề: <strong class="text-white">biểu đồ đó không đến từ nghiên cứu của Dunning và Kruger</strong>. Paper gốc 1999 không vẽ đường cong nào cả. Không có "Thung lũng tuyệt vọng." Không có "Đỉnh Ngu Dốt." Những khái niệm này được internet phát minh, ghép vào tên hai nhà khoa học, rồi lan truyền như sự thật.</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Tệ hơn — các nhà thống kê gần đây chứng minh rằng ngay cả phát hiện gốc có thể <span class="hl-red">chỉ là ảo ảnh toán học</span>. Hiệu ứng Dunning-Kruger nổi tiếng nhất thế giới tâm lý học đại chúng — và nó có thể không hoạt động đúng như bạn nghĩ. Câu chuyện thật phức tạp hơn, và thú vị hơn.</p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 01: PAPER GỐC                                     -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-cyan-400 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Bốn Thí Nghiệm Mà Không Ai Đọc</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Paper gốc 1999 chứa 4 nghiên cứu, mỗi cái kiểm tra một lĩnh vực khác nhau. Hầu hết mọi người chỉ biết kết luận — nhưng chi tiết mới là phần quan trọng.</p>

    <div class="border border-cyan-500/20 bg-cyan-950/10 p-5 mb-6">
      <p class="text-xs font-mono text-cyan-400 font-bold uppercase tracking-wider mb-3">Paper Gốc</p>
      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Kruger, J., & Dunning, D. (1999). <em>"Unskilled and Unaware of It: How Difficulties in Recognizing One's Own Incompetence Lead to Inflated Self-Assessments."</em> <span class="popover-wrap"><button class="popover-trigger">Journal of Personality and Social Psychology</button><span class="popover-bubble">JPSP — tạp chí hàng đầu về tâm lý xã hội và tâm lý nhân cách, do Hiệp hội Tâm lý học Hoa Kỳ (APA) xuất bản. Impact factor ~7.6. Đây là tạp chí "tier 1" trong ngành — paper được đăng ở đây đã qua peer review nghiêm ngặt.</span></span>, 77(6), 1121-1134.</p>
    </div>

    <!-- 4 Studies -->
    <p class="text-xs font-mono text-cyan-400 font-bold uppercase tracking-wider mb-4">4 Nghiên Cứu — Số Liệu Thực Tế</p>

    <div class="study-card">
      <div class="study-num">NGHIÊN CỨU 1 — SỰ HÀI HƯỚC</div>
      <div class="study-title">65 sinh viên Cornell đánh giá 30 truyện cười</div>
      <div class="study-body">Tham gia viên xếp hạng 30 truyện cười, rồi tự đánh giá khả năng nhận diện hài hước của mình so với người khác. Đáp án "đúng" do các diễn viên hài chuyên nghiệp cung cấp.</div>
      <div class="study-result">
        <strong class="text-white">Nhóm 25% kém nhất:</strong> thực tế ở <span class="hl-red">phân vị 12</span> — tự đánh giá ở <span class="hl">phân vị 58</span>. Sai lệch: <strong class="text-white">+46 bậc</strong>.
      </div>
    </div>

    <div class="study-card">
      <div class="study-num">NGHIÊN CỨU 2 — LOGIC</div>
      <div class="study-title">45 sinh viên làm 20 câu hỏi từ đề thi LSAT</div>
      <div class="study-body">Câu hỏi lấy từ tài liệu ôn thi <span class="popover-wrap"><button class="popover-trigger">LSAT</button><span class="popover-bubble">Law School Admission Test — kỳ thi chuẩn hoá để xét tuyển vào trường luật tại Hoa Kỳ và Canada. Phần lý luận logic là một trong những phần khó nhất, đo khả năng phân tích luận điểm, nhận diện ngụy biện, và rút ra kết luận hợp lệ.</span></span> — phần lý luận logic.</div>
      <div class="study-result">
        <strong class="text-white">Nhóm 25% kém nhất:</strong> thực tế ở <span class="hl-red">phân vị 12</span> — tự đánh giá ở <span class="hl">phân vị 68</span>. Sai lệch: <strong class="text-white">+56 bậc</strong>.
      </div>
    </div>

    <div class="study-card">
      <div class="study-num">NGHIÊN CỨU 3 — NGỮ PHÁP</div>
      <div class="study-title">84 sinh viên làm 20 câu hỏi ngữ pháp từ National Teacher Examination</div>
      <div class="study-body">Bài kiểm tra ngữ pháp tiếng Anh tiêu chuẩn, lấy từ kỳ thi sát hạch giáo viên quốc gia Hoa Kỳ.</div>
      <div class="study-result">
        Kết quả lặp lại cùng pattern: nhóm kém <span class="hl-red">đánh giá quá cao</span>, nhóm giỏi <span class="hl-green">đánh giá hơi thấp</span>.
      </div>
    </div>

    <div class="study-card" style="border-color: rgba(52, 211, 153, 0.3);">
      <div class="study-num" style="color: rgb(52, 211, 153);">NGHIÊN CỨU 4 — CAN THIỆP (THÍ NGHIỆM THEN CHỐT)</div>
      <div class="study-title">140 sinh viên: một nửa được dạy logic trước khi tự đánh giá lại</div>
      <div class="study-body">Tất cả làm bài <span class="popover-wrap"><button class="popover-trigger">Wason selection task</button><span class="popover-bubble">Wason selection task — bài test kinh điển về lý luận logic do Peter Wason thiết kế năm 1966. Cho 4 lá bài, mỗi mặt có số hoặc chữ. Hỏi: cần lật lá nào để kiểm tra một quy tắc? Khoảng 90% người trưởng thành trả lời sai — cho thấy con người yếu về lý luận điều kiện.</span></span>. Nửa nhóm được dạy logic trước khi tự đánh giá lần hai. Đây là thí nghiệm then chốt nhất — kiểm tra cơ chế.</div>
      <div class="study-result" style="border-color: rgba(52, 211, 153, 0.4); background: rgba(52, 211, 153, 0.06);">
        <span class="hl-green">Nhóm được huấn luyện</span> không chỉ làm tốt hơn — họ còn <strong class="text-white">tự đánh giá chính xác hơn</strong>. Cải thiện kỹ năng = cải thiện khả năng tự nhận biết. Đúng như dự đoán của giả thuyết <span class="popover-wrap"><button class="popover-trigger">metacognition</button><span class="popover-bubble">Metacognition — "nhận thức về nhận thức" — khả năng suy nghĩ về chính quá trình tư duy của mình. Bao gồm: tự giám sát (monitoring), tự đánh giá (evaluation), và tự điều chỉnh (regulation) hiệu suất nhận thức. Dunning & Kruger cho rằng kỹ năng thực hiện và kỹ năng metacognition là một.</span></span>.
      </div>
    </div>

    <div class="border-l-4 border-cyan-400 pl-6 py-2 mt-8 mb-6">
      <blockquote class="text-xl md:text-2xl font-bold italic text-cyan-300 leading-snug">
        "Hiệu ứng Dunning-Kruger ghé thăm tất cả chúng ta, sớm hay muộn, ở những vùng bất tài vô hình. Chúng vô hình vì để biết rằng bạn không biết gì, bạn cần phải biết gì đó."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — David Dunning, phỏng vấn 2024
      </footer>
    </div>

    <!-- What the study ACTUALLY claimed -->
    <p class="text-xs font-mono text-cyan-400 font-bold uppercase tracking-wider mb-4">Paper Nói Gì — Và Không Nói Gì</p>

    <table class="compare-table">
      <thead>
        <tr>
          <th>Paper gốc nói</th>
          <th>Internet nói</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="good">Người kém <strong>trong một lĩnh vực cụ thể</strong> thiếu metacognition để nhận ra mình kém <strong>ở lĩnh vực đó</strong></td>
          <td class="bad">"Người ngu không biết mình ngu" — áp dụng cho trí thông minh tổng quát</td>
        </tr>
        <tr>
          <td class="good">Kỹ năng thực hiện và kỹ năng tự đánh giá <strong>là một</strong> — cải thiện kỹ năng sẽ cải thiện tự nhận thức</td>
          <td class="bad">Người ngu bị "mắc kẹt" vĩnh viễn, không có cách sửa</td>
        </tr>
        <tr>
          <td class="good">Hiệu ứng xảy ra với <strong>mọi người</strong> — ở những lĩnh vực mà họ yếu</td>
          <td class="bad">Chỉ "người ngu" mới bị ảnh hưởng, còn "tôi" thì không</td>
        </tr>
        <tr>
          <td class="good">Nhóm giỏi nhất <strong>cũng sai</strong> — họ đánh giá thấp bản thân 12-17 bậc</td>
          <td class="bad">Chỉ tập trung vào nhóm kém; bỏ qua hoàn toàn sai lệch của nhóm giỏi</td>
        </tr>
      </tbody>
    </table>

    <details class="expand-block mt-6">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Cơ chế "Gánh nặng kép" (Dual Burden) — giải thích chi tiết
      </summary>
      <div class="expand-content">
        <p class="mb-3">Giả thuyết trung tâm của Dunning & Kruger là <strong class="text-white">"dual burden" (gánh nặng kép)</strong>: trong nhiều lĩnh vực trí tuệ, kỹ năng cần để làm đúng chính là kỹ năng cần để nhận ra mình sai.</p>
        <p class="mb-3">Ví dụ: để biết một luận điểm logic có hợp lệ hay không, bạn cần hiểu logic. Nhưng nếu bạn không hiểu logic, bạn cũng không thể nhận ra luận điểm của mình sai. Bạn gánh hai lần: (1) làm sai, và (2) không biết mình sai.</p>
        <p class="mb-3">Thí nghiệm 4 kiểm tra trực tiếp giả thuyết này: nếu dạy logic cho nhóm kém, metacognition của họ có cải thiện không? Câu trả lời: <strong class="text-white">có</strong>. Điều này phân biệt Dunning-Kruger khỏi ảo ảnh thống kê thuần túy — vì ảo ảnh thống kê không thể bị "chữa" bằng huấn luyện.</p>
        <p>Nhưng — như phần tiếp theo sẽ cho thấy — câu chuyện không dừng ở đó.</p>
      </div>
    </details>
  </section>

