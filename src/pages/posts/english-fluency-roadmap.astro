  <!-- PHẦN 06: LỘ TRÌNH 12 THÁNG                             -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-emerald-500 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 06</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Lộ Trình 12 Tháng — Từ "Câm" Đến Lưu Loát</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Dựa trên dữ liệu Cambridge, FSI, và phương pháp của các polyglot thành công nhất.</p>

    <!-- Phase 1 -->
    <div class="phase-card mb-4">
      <div class="phase-num text-cyan-400">Giai đoạn 1 — Nền Tảng</div>
      <div class="phase-title">Xây Kho Nguyên Liệu</div>
      <div class="phase-time">Tháng 1 - 3 &nbsp;|&nbsp; Tỷ lệ: 70% Input · 20% Output · 10% Review</div>
      <div class="phase-body">
        <p class="mb-2">Giai đoạn này ưu tiên <span class="popover-wrap"><button class="popover-trigger">comprehensible input</button><span class="popover-bubble">Comprehensible input (đầu vào dễ hiểu) — thuật ngữ của Krashen. Input phải ở mức "i+1" — bạn hiểu ~90% và đoán được 10% còn lại từ ngữ cảnh. Quá dễ = không học. Quá khó = não bỏ qua. Tìm "sweet spot" là chìa khóa.</span></span> khổng lồ — xây kho từ vựng và mẫu câu. Đừng ép nói nhiều, nhưng bắt đầu tập nói solo.</p>
      </div>
      <div class="phase-tasks">
        <div class="phase-task">Anki: 20 từ mới/ngày + ôn cũ (30 phút)</div>
        <div class="phase-task">Shadowing podcast dễ: 6 Minute English, TED-Ed (30 phút)</div>
        <div class="phase-task">Đọc graded readers (A2-B1 level) (30 phút)</div>
        <div class="phase-task">Self-talk: tự thuật lại ngày của mình bằng tiếng Anh (15 phút)</div>
        <div class="phase-task">Ghi âm bản thân, so sánh với bản gốc (15 phút)</div>
      </div>
    </div>

    <!-- Phase 2 -->
    <div class="phase-card mb-4">
      <div class="phase-num text-emerald-400">Giai đoạn 2 — Kích Hoạt</div>
      <div class="phase-title">Buộc Não Chuyển Sang "Chế Độ Sản Xuất"</div>
      <div class="phase-time">Tháng 4 - 6 &nbsp;|&nbsp; Tỷ lệ: 40% Input · 40% Output · 20% Review</div>
      <div class="phase-body">
        <p class="mb-2">Đây là giai đoạn quan trọng nhất — biến kiến thức <span class="hl-gold">declarative thành procedural</span>. Bắt đầu tương tác thật với con người hoặc AI.</p>
      </div>
      <div class="phase-tasks">
        <div class="phase-task">Anki: duy trì ôn cũ + 10 từ mới/ngày (20 phút)</div>
        <div class="phase-task">Hội thoại thật: AI tutor (ChatGPT Voice) hoặc HelloTalk (30 phút)</div>
        <div class="phase-task">Shadowing nâng cao: TED Talks, podcast chuyên ngành (20 phút)</div>
        <div class="phase-task">Viết nhật ký tiếng Anh → đọc to (20 phút)</div>
        <div class="phase-task">Gia sư iTalki: 2 buổi/tuần × 30 phút</div>
      </div>
    </div>

    <!-- Phase 3 -->
    <div class="phase-card mb-4">
      <div class="phase-num text-amber-400">Giai đoạn 3 — Tăng Tốc</div>
      <div class="phase-title">Vượt Qua Cao Nguyên Trung Cấp</div>
      <div class="phase-time">Tháng 7 - 9 &nbsp;|&nbsp; Tỷ lệ: 30% Input · 50% Output · 20% Review</div>
      <div class="phase-body">
        <p class="mb-2">Đây là giai đoạn <span class="popover-wrap"><button class="popover-trigger">plateau</button><span class="popover-bubble">Plateau (cao nguyên) — giai đoạn mà bạn cảm thấy không tiến bộ dù luyện đều. Richards (2008): từ B1→B2 mất gấp đôi B2→C1. Giải pháp: tăng độ khó, đa dạng hóa phương pháp, tập trung vào lỗ hổng cụ thể thay vì "luyện chung chung."</span></span> nguy hiểm nhất. Chống lại bằng cách đa dạng hóa chủ đề và tăng độ phức tạp.</p>
      </div>
      <div class="phase-tasks">
        <div class="phase-task">Tranh luận có cấu trúc: chọn chủ đề → trình bày quan điểm 3 phút (hàng ngày)</div>
        <div class="phase-task">Nghe podcast bản ngữ: NPR, The Daily, Freakonomics (30 phút)</div>
        <div class="phase-task">Gia sư iTalki: tăng lên 3 buổi/tuần</div>
        <div class="phase-task">Đọc sách/tin tức gốc (không phải graded readers) (30 phút)</div>
        <div class="phase-task">Ghi hình bản thân nói → tự đánh giá (1 lần/tuần)</div>
      </div>
    </div>

    <!-- Phase 4 -->
    <div class="phase-card mb-4">
      <div class="phase-num text-rose-400">Giai đoạn 4 — Lưu Loát</div>
      <div class="phase-title">Tự Động Hóa — Nói Mà Không Cần Nghĩ</div>
      <div class="phase-time">Tháng 10 - 12 &nbsp;|&nbsp; Tỷ lệ: 20% Input · 60% Output · 20% Review</div>
      <div class="phase-body">
        <p class="mb-2">Mục tiêu: biến procedural thành <span class="hl">automatized</span>. Bạn phản xạ bằng tiếng Anh mà không cần dịch trong đầu.</p>
      </div>
      <div class="phase-tasks">
        <div class="phase-task">Immersion: chuyển điện thoại/laptop sang tiếng Anh, xem phim KHÔNG phụ đề</div>
        <div class="phase-task">Tham gia cộng đồng tiếng Anh: Discord, Reddit, Meetup</div>
        <div class="phase-task">Thuyết trình 5-10 phút/tuần về chủ đề tự chọn</div>
        <div class="phase-task">Mock interview: chuẩn bị phỏng vấn tiếng Anh với gia sư</div>
        <div class="phase-task">Ghi nhật ký lỗi: mỗi tuần review lỗi lặp lại → sửa có chủ đích</div>
      </div>
    </div>

    <!-- Daily Routine -->
    <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-4 mt-8">Mẫu lịch luyện hàng ngày (2 giờ)</p>

