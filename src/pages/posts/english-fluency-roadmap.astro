  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-cyan-400 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 05</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Bao Lâu Để "Lưu Loát"? — Dữ Liệu Thực</h2>
