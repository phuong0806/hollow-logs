---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Đọc Hiểu, Nghe Hiểu — Nhưng Mở Miệng Thì Câm? Lộ Trình 1 Năm Nói Tiếng Anh Trôi Chảy',
  description: 'Não bộ bạn xử lý tiếp nhận và sản xuất ngôn ngữ bằng hai hệ thống khác nhau — và hệ thống "nói" cần được luyện riêng. Đây là bản đồ khoa học thần kinh + ngôn ngữ học để phá vỡ bức tường câm lặng.',
  pubDate: new Date('2026-04-26'),
  tags: ['linguistics', 'psychology'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="Ngôn Ngữ Học Ứng Dụng"
  kickerColor="cyan"
>
  <style>
    /* ─── Popovers ─────────────────────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(52, 211, 153);
      border-bottom: 1px dashed rgba(52, 211, 153, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(52, 211, 153); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 300px;
      padding: 12px 14px; background: #1a2744;
      border: 1px solid rgba(16, 185, 129, 0.3);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(16, 185, 129, 0.3);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 240px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Stat cards ───────────────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(16, 185, 129, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(52, 211, 153);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(16, 185, 129, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }
    .compare-table .emerald { color: rgb(52, 211, 153); }

    /* ─── Timeline ─────────────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(16, 185, 129, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(16, 185, 129, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(16, 185, 129); border-color: rgb(16, 185, 129);
      box-shadow: 0 0 8px rgba(16, 185, 129, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.gold::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
    }
    .timeline-item.blue::before {
      background: rgb(96, 165, 250); border-color: rgb(96, 165, 250);
      box-shadow: 0 0 8px rgba(96, 165, 250, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(52, 211, 153); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.gold .timeline-year { color: rgb(251, 191, 36); }
    .timeline-item.blue .timeline-year { color: rgb(147, 197, 253); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.gold .timeline-desc { color: rgb(254 243 199); font-weight: 600; }
    .timeline-item.blue .timeline-desc { color: rgb(219 234 254); font-weight: 600; }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(16, 185, 129);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(52, 211, 153); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Case cards ───────────────────────────── */
    .case-card {
      background: rgba(21, 31, 50, 0.4);
      border: 1px solid rgba(100, 116, 139, 0.2);
      padding: 18px;
    }
    .case-card:hover {
      border-color: rgba(16, 185, 129, 0.4);
      background: rgba(21, 31, 50, 0.6);
    }
    .case-label { font-size: 0.7rem; font-family: monospace; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px; }
    .case-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 6px; }
    .case-body { font-size: 0.85rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Versus cards ─────────────────────────── */
    .vs-card {
      padding: 16px; text-align: center;
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.2);
    }
    .vs-label {
      font-size: 0.7rem; font-family: monospace;
      font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; margin-bottom: 6px;
    }
    .vs-text {
      font-size: 1rem; font-weight: 700; color: white;
    }
    .vs-sub {
      font-size: 0.8rem; line-height: 1.5; color: rgb(148 163 184); margin-top: 4px;
    }
    .vs-arrow {
      color: rgb(100 116 139); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(16, 185, 129, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(16, 185, 129, 0.08);
      border: 1px solid rgba(16, 185, 129, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(52, 211, 153); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.35);
    }
    .hl-gold {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-blue {
      background: rgba(59, 130, 246, 0.12);
      color: rgb(147, 197, 253);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(59, 130, 246, 0.3);
    }
    .hl-rose {
      background: rgba(244, 63, 94, 0.12);
      color: rgb(251, 113, 133);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(244, 63, 94, 0.3);
    }

    /* ─── Bar chart ────────────────────────────── */
    .bar-track {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.15);
      height: 32px; position: relative; margin-bottom: 6px;
    }
    .bar-fill {
      height: 100%; display: flex; align-items: center;
      padding-left: 10px; font-size: 0.75rem; font-weight: 700;
      font-family: monospace; color: #0B1221;
    }
    .bar-label-row {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 4px;
    }
    .bar-label-text {
      font-size: 0.8rem; color: rgb(203 213 225); font-weight: 600;
    }
    .bar-label-value {
      font-size: 0.75rem; font-family: monospace; color: rgb(100 116 139);
    }

    /* ─── Brain diagram ────────────────────────── */
    .brain-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.2);
      padding: 20px; text-align: center;
    }
    .brain-card:hover {
      border-color: rgba(16, 185, 129, 0.4);
      background: rgba(21, 31, 50, 0.6);
    }
    .brain-icon {
      font-size: 2.5rem; margin-bottom: 8px;
    }
    .brain-name {
      font-size: 0.9rem; font-weight: 700; color: white; margin-bottom: 4px;
    }
    .brain-role {
      font-size: 0.7rem; font-family: monospace; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;
    }
    .brain-desc {
      font-size: 0.82rem; line-height: 1.5; color: rgb(148 163 184);
    }

    /* ─── Roadmap phase card ──────────────────── */
    .phase-card {
      background: rgba(21, 31, 50, 0.4);
      border: 1px solid rgba(100, 116, 139, 0.2);
      padding: 20px;
    }
    .phase-card:hover {
      border-color: rgba(16, 185, 129, 0.4);
    }
    .phase-num {
      font-size: 0.7rem; font-family: monospace; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px;
    }
    .phase-title {
      font-size: 1.1rem; font-weight: 700; color: white; margin-bottom: 6px;
    }
    .phase-time {
      font-size: 0.75rem; font-family: monospace; color: rgb(100 116 139);
      margin-bottom: 10px;
    }
    .phase-body {
      font-size: 0.85rem; line-height: 1.6; color: rgb(148 163 184);
    }
    .phase-tasks {
      margin-top: 10px; padding-top: 10px;
      border-top: 1px solid rgba(100, 116, 139, 0.15);
    }
    .phase-task {
      font-size: 0.8rem; color: rgb(203 213 225); padding: 3px 0;
      display: flex; align-items: baseline; gap: 6px;
    }
    .phase-task::before {
      content: '▸'; color: rgb(52, 211, 153); flex-shrink: 0;
    }

    /* ─── Forgetting curve chart ─────────────── */
    .curve-row {
      display: flex; align-items: center; gap: 12px; margin-bottom: 8px;
    }
    .curve-time {
      font-size: 0.75rem; font-family: monospace; color: rgb(148 163 184);
      width: 90px; text-align: right; flex-shrink: 0;
    }
    .curve-bar-track {
      flex: 1; height: 20px; background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.1);
    }
    .curve-bar-fill {
      height: 100%;
    }
    .curve-pct {
      font-size: 0.72rem; font-family: monospace; font-weight: 700;
      width: 42px; flex-shrink: 0;
    }

    /* ─── Daily routine ring ─────────────────── */
    .routine-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgba(16, 185, 129, 0.5);
      padding: 14px 16px; margin-bottom: 8px;
      display: flex; align-items: center; gap: 14px;
    }
    .routine-time {
      font-size: 1.2rem; font-weight: 900; color: rgb(52, 211, 153);
      min-width: 55px; text-align: center; line-height: 1;
    }
    .routine-time-unit {
      font-size: 0.6rem; font-family: monospace; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .routine-info { flex: 1; }
    .routine-name {
      font-size: 0.9rem; font-weight: 700; color: white; margin-bottom: 2px;
    }
    .routine-desc {
      font-size: 0.8rem; color: rgb(148 163 184); line-height: 1.4;
    }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-cyan-400 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-cyan-300 leading-snug">
        "Giới hạn ngôn ngữ của tôi là giới hạn thế giới của tôi."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Ludwig Wittgenstein, <em>Tractatus Logico-Philosophicus</em> (1922)
      </footer>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- CONTEXT INTRO                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh</p>
        <p class="text-slate-300 text-sm leading-relaxed">Bạn đọc tiếng Anh — hiểu. Nghe podcast — hiểu. Nhưng khi đứng trước một người nước ngoài, đầu bạn trống rỗng, lưỡi cứng đơ, và câu nói đầu tiên là <strong class="text-white">"Uh... sorry, my English is not good."</strong></p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed">Đây không phải lỗi của bạn. Não bộ xử lý <span class="popover-wrap"><button class="popover-trigger">comprehension</button><span class="popover-bubble">Comprehension (tiếp nhận ngôn ngữ) — quá trình giải mã ý nghĩa từ tín hiệu ngôn ngữ đầu vào (đọc, nghe). Chỉ cần một quá trình: nhận diện và khớp với kiến thức đã lưu.</span></span> và <span class="popover-wrap"><button class="popover-trigger">production</button><span class="popover-bubble">Production (sản xuất ngôn ngữ) — quá trình tạo ra lời nói hoặc văn bản. Cần ba giai đoạn liên tiếp: nghĩ nội dung → mã hóa ngữ pháp + phát âm → phát ra âm thanh. Phức tạp hơn tiếp nhận rất nhiều.</span></span> bằng <span class="hl-red">hai hệ thống thần kinh khác nhau</span>. Luyện đọc/nghe không tự động giúp bạn nói được.</p>
      </div>
      <div class="border border-cyan-500/20 bg-cyan-950/10 p-4">
        <p class="text-xs font-mono text-cyan-400 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed">Khoa học thần kinh giải thích <span class="hl">tại sao hiểu ≠ nói</span>, 5 rào cản chính, các phương pháp <span class="hl-gold">có bằng chứng khoa học</span>, và <span class="hl-blue">lộ trình 12 tháng</span> chi tiết.</p>
      </div>
    </div>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Năm 1982, nhà ngôn ngữ học <strong class="text-white">Stephen Krashen</strong> (Đại học Nam California) công bố lý thuyết nổi tiếng nhất trong lịch sử dạy ngoại ngữ: <span class="popover-wrap"><button class="popover-trigger">Input Hypothesis</button><span class="popover-bubble">Input Hypothesis (Giả thuyết Đầu vào) — lý thuyết của Stephen Krashen cho rằng con người chỉ thụ đắc ngôn ngữ khi tiếp nhận thông điệp dễ hiểu ở mức "i+1" — cao hơn trình độ hiện tại một bậc. Krashen tin rằng nói sẽ tự đến khi đủ input.</span></span>. Ý tưởng cốt lõi: <em>"Chúng ta thụ đắc ngôn ngữ chỉ bằng một cách duy nhất — khi hiểu thông điệp."</em></p>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Nhưng ba năm sau, nhà ngôn ngữ học <strong class="text-white">Merrill Swain</strong> (Đại học Toronto) phát hiện một lỗ hổng lớn. Bà nghiên cứu học sinh chương trình <span class="popover-wrap"><button class="popover-trigger">French immersion</button><span class="popover-bubble">French immersion (chương trình ngâm mình tiếng Pháp) — mô hình giáo dục ở Canada, nơi học sinh nói tiếng Anh được dạy mọi môn bằng tiếng Pháp. Chương trình kéo dài nhiều năm với lượng input khổng lồ.</span></span> ở Canada — những đứa trẻ được "tắm" trong tiếng Pháp suốt nhiều năm. Kết quả: <span class="hl">khả năng hiểu gần như bản ngữ</span>, nhưng khi nói thì <span class="hl-red">đầy lỗi ngữ pháp</span>.</p>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed">Input không đủ. Bạn cần <strong class="text-white">output</strong> — và đây là bài viết giải thích tại sao, rào cản nào cần phá, và làm thế nào để phá chúng trong 12 tháng.</p>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- STATS OVERVIEW                                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="stat-card">
        <div class="stat-num">1.5 tỷ</div>
        <div class="stat-label">Người đang học tiếng Anh toàn cầu</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">8%</div>
        <div class="stat-label">Người dùng app hoàn thành khóa học</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">#64</div>
        <div class="stat-label">Xếp hạng Việt Nam (EF EPI 2025)</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">2.4x</div>
        <div class="stat-label">Nhanh hơn khi có gia sư thực</div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 01: KHOA HỌC THẦN KINH                            -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-cyan-400 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Hai Bộ Não — Một Hiểu, Một Nói</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Tại sao não xử lý việc nghe hiểu và nói thành thạo bằng hai hệ thống hoàn toàn khác nhau.</p>

    <!-- Brain Areas Visual -->
    <div class="grid md:grid-cols-2 gap-4 mb-8">
      <div class="brain-card">
        <div class="brain-icon">🧠</div>
        <div class="brain-name">Vùng Wernicke</div>
        <div class="brain-role text-cyan-400">Tiếp nhận → Hiểu</div>
        <div class="brain-desc">Nằm ở thùy thái dương trái. Chịu trách nhiệm giải mã ngôn ngữ — đọc và nghe hiểu. Tổn thương vùng này gây <span class="popover-wrap"><button class="popover-trigger">Wernicke's aphasia</button><span class="popover-bubble">Wernicke's aphasia (mất ngôn ngữ Wernicke) — bệnh nhân nói trôi chảy nhưng vô nghĩa, không hiểu lời người khác nói. Âm thanh ra nhưng nội dung rỗng, vì vùng giải mã ý nghĩa bị hỏng.</span></span>: nói trôi chảy nhưng vô nghĩa.</div>
      </div>
      <div class="brain-card">
        <div class="brain-icon">🗣️</div>
        <div class="brain-name">Vùng Broca</div>
        <div class="brain-role text-rose-400">Sản xuất → Nói</div>
        <div class="brain-desc">Nằm ở thùy trán trái. Chịu trách nhiệm sản xuất lời nói — lập kế hoạch ngữ pháp và phát âm. Tổn thương gây <span class="popover-wrap"><button class="popover-trigger">Broca's aphasia</button><span class="popover-bubble">Broca's aphasia (mất ngôn ngữ Broca) — bệnh nhân hiểu mọi thứ nhưng không thể nói trôi chảy. Câu nói ngắn, gãy, đầy nỗ lực. Chính xác là tình trạng "hiểu nhưng không nói được" mà nhiều người học ngoại ngữ trải qua ở mức nhẹ hơn.</span></span>: hiểu mọi thứ nhưng không nói được.</div>
      </div>
    </div>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Theo mô hình cổ điển Wernicke-Lichtheim-Geschwind, hai vùng này nối với nhau qua bó sợi thần kinh <span class="popover-wrap"><button class="popover-trigger">arcuate fasciculus</button><span class="popover-bubble">Arcuate fasciculus (bó cung) — bó sợi thần kinh nối vùng Wernicke (hiểu) với vùng Broca (nói). Khi bạn nghe một từ và muốn lặp lại, tín hiệu chạy qua bó này. Ở người học ngoại ngữ, kết nối này cần được rèn luyện.</span></span>. Nghiên cứu fMRI hiện đại (Tremblay & Dick, 2016) cho thấy thực tế phức tạp hơn — ngôn ngữ liên quan đến mạng lưới phân tán — nhưng nguyên lý cốt lõi vẫn đúng:</p>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4"><strong class="text-white">Hiểu và nói dùng mạch thần kinh khác nhau.</strong> Luyện đọc/nghe chỉ tăng cường mạch tiếp nhận. Mạch sản xuất phải được luyện riêng.</p>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Mô hình sản xuất lời nói của Levelt (1989)
      </summary>
      <div class="expand-content">
        <p class="mb-3">Willem Levelt — nhà tâm lý ngôn ngữ học người Hà Lan — xây dựng mô hình sản xuất lời nói được trích dẫn hơn 60.000 lần. Khi bạn nói một câu, não phải chạy qua ba giai đoạn trong thời gian thực:</p>
        <div class="grid md:grid-cols-3 gap-3">
          <div class="flow-box">
            <p class="text-xs font-mono text-cyan-400 font-bold mb-2">GIAI ĐOẠN 1</p>
            <p class="text-sm font-bold text-white mb-1">Conceptualization</p>
            <p class="text-xs text-slate-400">Quyết định NÓI GÌ — ý định giao tiếp</p>
          </div>
          <div class="flow-box">
            <p class="text-xs font-mono text-emerald-400 font-bold mb-2">GIAI ĐOẠN 2</p>
            <p class="text-sm font-bold text-white mb-1">Formulation</p>
            <p class="text-xs text-slate-400">Mã hóa ngữ pháp + âm vị — biến ý thành câu</p>
          </div>
          <div class="flow-box">
            <p class="text-xs font-mono text-rose-400 font-bold mb-2">GIAI ĐOẠN 3</p>
            <p class="text-sm font-bold text-white mb-1">Articulation</p>
            <p class="text-xs text-slate-400">Điều khiển cơ miệng, lưỡi, hơi thở để phát âm</p>
          </div>
        </div>
        <p class="mt-3">Nghe hiểu chỉ cần <strong class="text-white">giải mã</strong>. Nói cần <strong class="text-white">cả ba giai đoạn</strong> chạy đồng thời trong vài trăm mili-giây. Đó là lý do nó khó hơn nhiều.</p>
      </div>
    </details>

    <!-- Recognition vs Recall -->
    <div class="grid md:grid-cols-2 gap-4 mt-6">
      <div class="vs-card">
        <div class="vs-label text-cyan-400">Hiểu = Recognition</div>
        <div class="vs-text">1 quá trình</div>
        <div class="vs-sub">Nhìn/nghe từ → khớp với bộ nhớ → hiểu.</div>
      </div>
      <div class="vs-card">
        <div class="vs-label text-rose-400">Nói = Recall</div>
        <div class="vs-text">2 quá trình</div>
        <div class="vs-sub">Tìm từ trong bộ nhớ → kiểm tra → phát âm. Luôn khó hơn recognition.</div>
      </div>
    </div>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mt-6">Trong tâm lý nhận thức, đây gọi là <span class="popover-wrap"><button class="popover-trigger">recognition-recall asymmetry</button><span class="popover-bubble">Recognition-recall asymmetry (bất đối xứng nhận diện-hồi tưởng) — hiện tượng đã được chứng minh rộng rãi: con người luôn nhận diện (recognize) tốt hơn hồi tưởng (recall). Bạn nhận ra khuôn mặt người quen dễ dàng, nhưng mô tả khuôn mặt đó từ trí nhớ thì rất khó.</span></span>. Bạn nhận ra từ "procrastinate" khi đọc thấy — nhưng khi cần nói "tôi hay trì hoãn" bằng tiếng Anh, bạn tìm không ra từ đó. Cùng một từ, hai đường dẫn thần kinh hoàn toàn khác nhau.</p>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 02: 5 RÀO CẢN CHÍNH                               -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-rose-500 text-white font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 02</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">5 Bức Tường Ngăn Bạn Mở Miệng</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Từ bộ lọc cảm xúc đến hóa thạch ngôn ngữ — khoa học giải thích từng rào cản.</p>

    <!-- Barrier 1: Affective Filter -->
    <div class="lesson-card">
      <div class="lesson-num">RÀO CẢN 01</div>
      <div class="lesson-title">Bộ Lọc Cảm Xúc — Sợ Nói Sai</div>
      <div class="lesson-body">
        <p class="mb-3">Krashen gọi đây là <span class="popover-wrap"><button class="popover-trigger">Affective Filter</button><span class="popover-bubble">Affective Filter Hypothesis (Giả thuyết Bộ lọc cảm xúc) — Krashen cho rằng stress, lo âu, thiếu tự tin tạo ra một "bức tường" tâm lý ngăn não tiếp nhận ngôn ngữ. Khi bộ lọc cao, dù input tốt bao nhiêu cũng không vào được. Krashen: "Để thụ đắc ngôn ngữ thành công, lo âu phải bằng không."</span></span>. Khi bạn sợ nói sai, não kích hoạt phản ứng đe dọa — cortisol tăng, vùng <span class="popover-wrap"><button class="popover-trigger">prefrontal cortex</button><span class="popover-bubble">Prefrontal cortex (vỏ não trước trán) — vùng não chịu trách nhiệm tư duy logic, lập kế hoạch, và ngôn ngữ phức tạp. Khi stress tăng, hoạt động vùng này giảm, nhường cho amygdala (phản ứng chiến-hoặc-chạy). Đó là lý do stress làm bạn "quên sạch" tiếng Anh.</span></span> giảm hoạt động. Kết quả: bạn biết từ đó, biết ngữ pháp đó, nhưng dưới áp lực — nó biến mất.</p>
        <p>Đặc biệt với người Việt Nam: văn hóa sợ "mất mặt" cộng hưởng với bộ lọc cảm xúc, tạo ra vòng lặp — <span class="hl-red">sợ nói sai → không nói → không tiến bộ → sợ hơn</span>.</p>
      </div>
    </div>

    <!-- Barrier 2: Declarative vs Procedural -->
    <div class="lesson-card">
      <div class="lesson-num">RÀO CẢN 02</div>
      <div class="lesson-title">Biết Luật Nhưng Không Chạy Được — Declarative vs Procedural</div>
      <div class="lesson-body">
        <p class="mb-3"><span class="popover-wrap"><button class="popover-trigger">Skill Acquisition Theory</button><span class="popover-bubble">Skill Acquisition Theory (Lý thuyết thụ đắc kỹ năng) — Robert DeKeyser áp dụng nghiên cứu của Anderson (ACT-R) vào học ngôn ngữ. Ba giai đoạn: Declarative (biết luật) → Procedural (áp dụng được luật) → Automatized (không cần nghĩ). Mỗi giai đoạn cần luyện tập riêng.</span></span> của Robert DeKeyser giải thích: bạn có kiến thức <strong class="text-white">declarative</strong> (khai báo) — "tiếng Anh dùng S-V-O" — nhưng chưa biến nó thành kiến thức <strong class="text-white">procedural</strong> (thủ tục).</p>
        <p>Phát hiện quan trọng nhất: <span class="hl-gold">"Luyện hiểu không tự động chuyển sang nói, và ngược lại."</span> Đọc 1.000 cuốn sách tiếng Anh giúp bạn đọc giỏi — nhưng không giúp bạn nói giỏi. Hai kỹ năng cần hai dạng luyện tập riêng biệt.</p>
      </div>
    </div>

    <!-- Barrier 3: L1 Interference -->
    <div class="lesson-card">
      <div class="lesson-num">RÀO CẢN 03</div>
      <div class="lesson-title">Tiếng Mẹ Đẻ Phá Sóng — L1 Interference</div>
      <div class="lesson-body">
        <p class="mb-3">Khi bạn muốn nói tiếng Anh, não phải <strong class="text-white">ức chế</strong> tiếng Việt — ngôn ngữ mạnh hơn, luôn "bật" sẵn. Nghiên cứu cho thấy người song ngữ nói chậm hơn sau khi chuyển ngôn ngữ, vì phải tốn năng lượng thần kinh để kìm nén L1.</p>
        <p>Đặc thù tiếng Việt → tiếng Anh: âm cuối (<em>/z/, /s/, /t/</em>) bị nuốt, thanh điệu 6 tones bị áp lên tiếng Anh tạo ngữ điệu phẳng, và ~80% từ tiếng Việt là hai âm tiết khiến từ đa âm tiết tiếng Anh trở nên lúng túng.</p>
      </div>
    </div>

    <!-- Barrier 4: Tip-of-the-Tongue -->
    <div class="lesson-card">
      <div class="lesson-num">RÀO CẢN 04</div>
      <div class="lesson-title">Hiện Tượng "Ở Đầu Lưỡi" — Tip-of-the-Tongue</div>
      <div class="lesson-body">
        <p class="mb-3"><span class="popover-wrap"><button class="popover-trigger">TOT</button><span class="popover-bubble">Tip-of-the-Tongue (hiện tượng "ở đầu lưỡi") — khi bạn biết chắc mình biết một từ, cảm nhận được ý nghĩa và thậm chí âm đầu, nhưng không thể truy xuất đầy đủ. Nghiên cứu của Gollan & Silverberg (2001) chứng minh người song ngữ gặp tình trạng này thường xuyên hơn người đơn ngữ.</span></span> — bạn biết từ đó, bạn "cảm" được nó, nhưng không lôi ra được. Nghiên cứu của Gollan & Silverberg (2001) cho thấy: <span class="hl-red">người song ngữ trải qua TOT nhiều hơn đáng kể</span> so với người đơn ngữ, đặc biệt khi sử dụng ngôn ngữ yếu hơn.</p>
        <p>Lý do: khi bạn biết hai ngôn ngữ, từ vựng bị "chia" cho hai hệ thống, làm giảm tần suất truy cập mỗi từ, dẫn đến tốc độ truy xuất chậm hơn.</p>
      </div>
    </div>

    <!-- Barrier 5: Fossilization -->
    <div class="lesson-card">
      <div class="lesson-num">RÀO CẢN 05</div>
      <div class="lesson-title">Hóa Thạch Ngôn Ngữ — Fossilization & Plateau</div>
      <div class="lesson-body">
        <p class="mb-3"><span class="popover-wrap"><button class="popover-trigger">Fossilization</button><span class="popover-bubble">Fossilization (hóa thạch ngôn ngữ) — hiện tượng lỗi ngôn ngữ bị "đông cứng" vĩnh viễn dù luyện tập thêm. Ví dụ: người Việt luôn nói "I go to school yesterday" thay vì "went" — lỗi này lặp lại đến mức não coi nó là đúng. Cần can thiệp có chủ đích mới sửa được.</span></span> là khi lỗi sai lặp lại nhiều đến mức não coi nó là đúng — giống thạch hóa trong đá. <span class="popover-wrap"><button class="popover-trigger">Plateau effect</button><span class="popover-bubble">Plateau effect (hiệu ứng cao nguyên) — giai đoạn trì trệ mà hầu hết người học gặp ở trình độ trung cấp (B1-B2). Jack Richards (2008) gọi đây là "hóa thạch tạm thời." Từ A2→B1 mất gấp đôi thời gian A1→A2. Từ B1→B2 lại gấp đôi nữa.</span></span> là anh em sinh đôi — bạn mắc kẹt ở mức "đủ dùng" và không tiến thêm.</p>
        <p>Richards (2008) mô tả: người học trung cấp lạm dụng từ vựng cơ bản, nói trôi chảy nhưng không phức tạp, và lỗi ngữ pháp đã <span class="hl-red">hóa thạch</span>.</p>
      </div>
    </div>

    <!-- Comparison: barriers vs solutions -->
    <table class="compare-table mt-6">
      <thead>
        <tr>
          <th>Rào cản</th>
          <th class="bad">Biểu hiện</th>
          <th class="good">Giải pháp (preview)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="col-metric">Bộ lọc cảm xúc</td>
          <td class="bad">"Biết nhưng không dám nói"</td>
          <td class="good">Luyện với AI / solo trước → giảm áp lực</td>
        </tr>
        <tr>
          <td class="col-metric">Declarative ≠ Procedural</td>
          <td class="bad">"Biết ngữ pháp nhưng nói sai"</td>
          <td class="good">Deliberate practice — luyện có mục đích</td>
        </tr>
        <tr>
          <td class="col-metric">L1 Interference</td>
          <td class="bad">"Dịch trong đầu rồi mới nói"</td>
          <td class="good">Shadowing + tư duy bằng tiếng Anh</td>
        </tr>
        <tr>
          <td class="col-metric">Tip-of-the-Tongue</td>
          <td class="bad">"Biết từ đó nhưng không nhớ ra"</td>
          <td class="good">Spaced repetition + active recall</td>
        </tr>
        <tr>
          <td class="col-metric">Fossilization</td>
          <td class="bad">"Lỗi cũ lặp lại mãi"</td>
          <td class="good">Noticing + phản hồi có chủ đích</td>
        </tr>
      </tbody>
    </table>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 03: PHƯƠNG PHÁP KHOA HỌC                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-emerald-500 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 03</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">5 Phương Pháp Có Bằng Chứng Khoa Học</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Không phải mẹo vặt — đây là những lý thuyết được kiểm chứng bằng nghiên cứu peer-reviewed.</p>

    <!-- Method 1: Output Hypothesis -->
    <div class="case-card mb-4">
      <div class="case-label text-emerald-400">Phương pháp 01</div>
      <div class="case-title">Comprehensible Output — Buộc Não Phải "Sản Xuất"</div>
      <div class="case-body">
        <p class="mb-3">Merrill Swain (1985) phát hiện: khi bạn <strong class="text-white">cố gắng nói</strong>, ba điều xảy ra mà đọc/nghe không thể tạo được:</p>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-emerald-400 font-bold mb-2">NOTICING</p>
        <p class="text-sm text-white font-bold mb-1">Phát hiện lỗ hổng</p>
        <p class="text-xs text-slate-400">Bạn muốn nói "tôi đã từng" nhưng không biết cấu trúc → nhận ra mình thiếu gì.</p>
      </div>
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-emerald-400 font-bold mb-2">HYPOTHESIS TESTING</p>
        <p class="text-sm text-white font-bold mb-1">Thử nghiệm</p>
        <p class="text-xs text-slate-400">Bạn nói "I have been go..." → người nghe sửa → bạn điều chỉnh giả thuyết.</p>
      </div>
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-emerald-400 font-bold mb-2">METALINGUISTIC</p>
        <p class="text-sm text-white font-bold mb-1">Phản tư ngôn ngữ</p>
        <p class="text-xs text-slate-400">Bạn tự hỏi "present perfect hay past simple?" → suy nghĩ SÂU về ngôn ngữ.</p>
      </div>
    </div>

    <!-- Method 2: Interaction Hypothesis -->
    <div class="case-card mb-4">
      <div class="case-label text-cyan-400">Phương pháp 02</div>
      <div class="case-title">Interaction Hypothesis — Hội Thoại Là Trường Học Tốt Nhất</div>
      <div class="case-body">
        <p class="mb-3">Michael Long (1996) chứng minh: cơ chế học ngôn ngữ hiệu quả nhất là <span class="popover-wrap"><button class="popover-trigger">negotiation of meaning</button><span class="popover-bubble">Negotiation of meaning (thương lượng ý nghĩa) — quá trình người nói và người nghe làm rõ hiểu lầm trong hội thoại. Ví dụ: "You mean the big one?" "No, the red one." Quá trình này buộc cả hai bên xử lý ngôn ngữ sâu hơn. Long cho rằng đây là "cơ chế tâm lý ngôn ngữ chính" cho việc thụ đắc.</span></span> — khi hai người cùng cố hiểu nhau.</p>
        <p>Pica, Young & Doughty (1987) kiểm chứng: nhóm học bằng <span class="hl">tương tác hội thoại</span> vượt trội hơn nhóm chỉ nghe input, vì tương tác kết hợp cả input lẫn output trong bối cảnh có ý nghĩa.</p>
      </div>
    </div>

    <!-- Method 3: Shadowing -->
    <div class="case-card mb-4">
      <div class="case-label text-blue-400">Phương pháp 03</div>
      <div class="case-title">Shadowing — Lặp Lại Đồng Thời Như Cái Bóng</div>
      <div class="case-body">
        <p class="mb-3"><span class="popover-wrap"><button class="popover-trigger">Shadowing</button><span class="popover-bubble">Shadowing (kỹ thuật bóng) — nghe bản ngữ nói qua tai nghe và lặp lại gần như đồng thời, trễ 0.5-2 giây. Phát triển bởi các phiên dịch viên hội nghị. Alexander Arguelles (nói 30+ ngôn ngữ) phổ biến hóa phương pháp này.</span></span> — bạn nghe và lặp lại gần như đồng thời, trễ khoảng 1 giây. Kỹ thuật này ép ba hệ thống làm việc cùng lúc: nghe (input), phát âm (output), và tự kiểm tra (monitoring).</p>
        <p>Hamada (2012, 2016) nghiên cứu trên sinh viên Nhật Bản: nhóm shadowing cải thiện <span class="hl">khả năng nghe + phát âm + trôi chảy</span> đáng kể so với nhóm đối chứng. Đánh giá hệ thống 2025 xác nhận shadowing hiệu quả cho dạy phát âm.</p>
      </div>
    </div>

    <!-- Method 4: Spaced Repetition -->
    <div class="case-card mb-4">
      <div class="case-label text-amber-400">Phương pháp 04</div>
      <div class="case-title">Spaced Repetition — Đánh Bại Đường Cong Quên</div>
      <div class="case-body">
        <p class="mb-3">Năm 1885, Hermann Ebbinghaus phát hiện <span class="popover-wrap"><button class="popover-trigger">forgetting curve</button><span class="popover-bubble">Forgetting curve (đường cong quên) — phát hiện bởi Ebbinghaus: ký ức suy giảm theo hàm mũ nếu không ôn tập. Sau 20 phút chỉ nhớ 58%, sau 1 giờ còn 44%, sau 1 ngày còn 33%. Spaced repetition chống lại hiệu ứng này bằng cách ôn đúng lúc sắp quên.</span></span> — não quên theo hàm mũ. Spaced repetition lên lịch ôn tập đúng thời điểm sắp quên, tối ưu hóa trí nhớ dài hạn.</p>
      </div>
    </div>

    <!-- Forgetting Curve Visual -->
    <div class="mb-8">
      <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-4">Đường Cong Quên của Ebbinghaus (1885)</p>

      <div class="curve-row">
        <div class="curve-time">20 phút</div>
        <div class="curve-bar-track"><div class="curve-bar-fill" style="width: 58%; background: rgb(52, 211, 153);"></div></div>
        <div class="curve-pct" style="color: rgb(52, 211, 153);">58%</div>
      </div>
      <div class="curve-row">
        <div class="curve-time">1 giờ</div>
        <div class="curve-bar-track"><div class="curve-bar-fill" style="width: 44%; background: rgb(251, 191, 36);"></div></div>
        <div class="curve-pct" style="color: rgb(251, 191, 36);">44%</div>
      </div>
      <div class="curve-row">
        <div class="curve-time">9 giờ</div>
        <div class="curve-bar-track"><div class="curve-bar-fill" style="width: 36%; background: rgb(251, 146, 60);"></div></div>
        <div class="curve-pct" style="color: rgb(251, 146, 60);">36%</div>
      </div>
      <div class="curve-row">
        <div class="curve-time">1 ngày</div>
        <div class="curve-bar-track"><div class="curve-bar-fill" style="width: 33%; background: rgb(239, 68, 68);"></div></div>
        <div class="curve-pct" style="color: rgb(239, 68, 68);">33%</div>
      </div>
      <div class="curve-row">
        <div class="curve-time">1 tuần</div>
        <div class="curve-bar-track"><div class="curve-bar-fill" style="width: 25%; background: rgb(239, 68, 68);"></div></div>
        <div class="curve-pct" style="color: rgb(239, 68, 68);">25%</div>
      </div>
      <div class="curve-row">
        <div class="curve-time">1 tháng</div>
        <div class="curve-bar-track"><div class="curve-bar-fill" style="width: 21%; background: rgb(190, 50, 50);"></div></div>
        <div class="curve-pct" style="color: rgb(252, 165, 165);">21%</div>
      </div>
      <p class="text-center text-xs font-mono text-slate-500 mt-3">Không ôn tập → mất 79% sau 1 tháng. Spaced repetition giữ tỷ lệ ghi nhớ trên 90%.</p>
    </div>

    <!-- Method 5: Noticing Hypothesis -->
    <div class="case-card mb-4">
      <div class="case-label text-rose-400">Phương pháp 05</div>
      <div class="case-title">Noticing Hypothesis — "Không Nhận Ra Thì Không Học Được"</div>
      <div class="case-body">
        <p class="mb-3">Richard Schmidt (1990) phát hiện từ chính trải nghiệm học tiếng Bồ Đào Nha tại Brazil: <span class="hl-gold">những cấu trúc ngữ pháp ông được tiếp xúc hàng ngày không hề "vào đầu"</span> cho đến khi được chỉ ra trực tiếp.</p>
        <p>Ý tưởng cốt lõi: bạn phải <strong class="text-white">chủ động nhận ra</strong> (notice) khoảng cách giữa cái bạn nói và cái người bản xứ nói. Chỉ nghe thụ động không đủ — cần ý thức so sánh.</p>
      </div>
    </div>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Tại sao chỉ dùng app không đủ? Dữ liệu nói gì
      </summary>
      <div class="expand-content">
        <p class="mb-3">Dữ liệu từ nhiều nghiên cứu cho thấy:</p>
        <ul class="space-y-2">
          <li class="flex items-baseline gap-2"><span class="text-rose-400 flex-shrink-0">▸</span> <span>Chỉ <strong class="text-white">8%</strong> người dùng app ngôn ngữ hoàn thành khóa học (EdSurge Research, 2024)</span></li>
          <li class="flex items-baseline gap-2"><span class="text-rose-400 flex-shrink-0">▸</span> <span>Rosetta Stone: chỉ 21% người dùng hoàn thành 10 giờ trong khóa 200 giờ</span></li>
          <li class="flex items-baseline gap-2"><span class="text-rose-400 flex-shrink-0">▸</span> <span>Lý do bỏ cuộc: thiếu động lực (42%), quá khó (31%), thiếu tài nguyên (15%)</span></li>
          <li class="flex items-baseline gap-2"><span class="text-emerald-400 flex-shrink-0">▸</span> <span>Chương trình <span class="hl">immersion hiệu quả gấp 5x</span> so với lớp truyền thống (ACTFL, 2024)</span></li>
          <li class="flex items-baseline gap-2"><span class="text-emerald-400 flex-shrink-0">▸</span> <span>Gia sư thực giúp <span class="hl">tiến bộ nhanh gấp 2.4x</span> so với chỉ dùng app</span></li>
        </ul>
        <p class="mt-3">App tốt cho từ vựng (input). Nhưng để nói — bạn cần con người hoặc AI có khả năng hội thoại.</p>
      </div>
    </details>
  </section>

