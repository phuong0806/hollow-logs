---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Finance 101: Cổ Phiếu — Từ Con Số Zero Đến Nhà Đầu Tư Tỉnh Táo',
  description: 'Cổ phiếu không phải trò chơi may rủi. Nó là quyền sở hữu một phần doanh nghiệp. Hiểu cơ chế hoạt động, cách định giá, và những sai lầm kinh điển — trước khi bỏ tiền thật vào thị trường.',
  pubDate: new Date('2026-04-23'),
  tags: ['finance', 'economics'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="Tài Chính Cơ Bản"
  kickerColor="emerald"
>
  <style>
    /* ─── Popovers ─────────────────────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(34 211 238);
      border-bottom: 1px dashed rgba(34, 211, 238, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(34 211 238); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 290px;
      padding: 12px 14px; background: #1a2744;
      border: 1px solid rgba(34, 211, 238, 0.25);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(34, 211, 238, 0.25);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 230px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Bar chart ────────────────────────────── */
    .bar-track {
      height: 28px; background: rgba(30, 41, 59, 0.8);
      position: relative; overflow: hidden;
    }
    .bar-fill { height: 100%; }
    .bar-label {
      position: absolute; right: 10px; top: 50%;
      transform: translateY(-50%);
      font-size: 0.75rem; font-weight: 700;
      color: white; text-shadow: 0 1px 2px rgba(0,0,0,0.6);
    }

    /* ─── Timeline ─────────────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(34, 211, 238, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(34, 211, 238, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(34, 211, 238); border-color: rgb(34, 211, 238);
      box-shadow: 0 0 8px rgba(34, 211, 238, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.gold::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(34, 211, 238); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.gold .timeline-year { color: rgb(251, 191, 36); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.gold .timeline-desc { color: rgb(254 243 199); font-weight: 600; }

    /* ─── Stats grid ───────────────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(34, 211, 238);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(34, 211, 238, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }

    /* ─── Red flags ────────────────────────────── */
    .redflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.03); margin-bottom: 10px;
    }
    .redflag-icon { color: rgb(239 68 68); flex-shrink: 0; margin-top: 2px; }
    .redflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .redflag-text strong { color: white; }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(34, 211, 238, 0.12);
      color: rgb(34, 211, 238);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(34, 211, 238, 0.35);
    }
    .hl-gold {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(34, 211, 238, 0.08);
      border: 1px solid rgba(34, 211, 238, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(34, 211, 238); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(34, 211, 238);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(34, 211, 238); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Pie chart (CSS) ──────────────────────── */
    .pie-legend-dot {
      width: 12px; height: 12px; border-radius: 2px; flex-shrink: 0;
    }

    /* ─── Green flag ───────────────────────────── */
    .greenflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(16, 185, 129, 0.2);
      background: rgba(16, 185, 129, 0.03); margin-bottom: 10px;
    }
    .greenflag-icon { color: rgb(52 211 153); flex-shrink: 0; margin-top: 2px; }
    .greenflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .greenflag-text strong { color: white; }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-emerald-500 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-emerald-400 leading-snug">
        "Giá là thứ bạn trả. Giá trị là thứ bạn nhận được."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Warren Buffett, thư gửi cổ đông Berkshire Hathaway, 2008
      </footer>
    </div>
  </section>

  <!-- CONTEXT INTRO -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh</p>
        <p class="text-slate-300 text-sm leading-relaxed">Hơn <strong class="text-white">58% người Mỹ trưởng thành</strong> sở hữu cổ phiếu (Gallup, 2024). Tại Việt Nam, số tài khoản chứng khoán vượt <strong class="text-white">8 triệu</strong> — nhưng phần lớn giao dịch theo tin đồn, không hiểu mình đang mua gì.</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed">Nhiều người nghĩ <span class="popover-wrap"><button class="popover-trigger">cổ phiếu</button><span class="popover-bubble">Stock / Share — chứng chỉ đại diện quyền sở hữu một phần công ty. Khi bạn mua 1 cổ phiếu Apple, bạn sở hữu một phần cực nhỏ của Apple — bao gồm cả lợi nhuận và rủi ro của nó.</span></span> là "đánh bạc hợp pháp". Sai. Cổ phiếu là quyền sở hữu doanh nghiệp — nhưng phần lớn người mua không hiểu mình sở hữu cái gì.</p>
      </div>
      <div class="border border-emerald-500/20 bg-emerald-950/10 p-4">
        <p class="text-xs font-mono text-emerald-500 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed">Cổ phiếu là gì, <span class="hl">cơ chế thị trường</span> hoạt động ra sao, cách <span class="hl-gold">định giá</span> cơ bản, và những <span class="hl-red">sai lầm kinh điển</span> cần tránh.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- STATS OVERVIEW                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="stat-card">
        <div class="stat-num">$109T</div>
        <div class="stat-label">Vốn hóa TTCK toàn cầu</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">58,000+</div>
        <div class="stat-label">Công ty niêm yết</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">~10%</div>
        <div class="stat-label">Lợi suất TB S&P 500/năm</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">8M+</div>
        <div class="stat-label">Tài khoản CK Việt Nam</div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 01: CỔ PHIẾU LÀ GÌ?                              -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-emerald-500 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Cổ Phiếu Là Gì? — Không Phải Con Số Trên Màn Hình</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Mỗi cổ phiếu là một mảnh giấy pháp lý nói rằng: "Bạn sở hữu một phần công ty này." Hiểu được điều đó thay đổi hoàn toàn cách bạn nhìn thị trường.</p>

    <!-- Core concept -->
    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-8">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Khi một công ty cần tiền để mở rộng, họ có hai lựa chọn: <span class="hl">vay nợ</span> (phát hành <span class="popover-wrap"><button class="popover-trigger">trái phiếu</button><span class="popover-bubble">Bond — giấy nợ do công ty hoặc chính phủ phát hành. Người mua trái phiếu cho công ty vay tiền, đổi lại nhận lãi suất cố định theo kỳ hạn. Khác cổ phiếu: trái phiếu không cho quyền sở hữu, chỉ cho quyền đòi nợ.</span></span>) hoặc <span class="hl-gold">bán quyền sở hữu</span> (phát hành cổ phiếu).</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Khi bạn mua cổ phiếu, bạn trở thành <span class="popover-wrap"><button class="popover-trigger">cổ đông</button><span class="popover-bubble">Shareholder — người sở hữu cổ phần của công ty. Cổ đông có quyền biểu quyết tại đại hội, nhận cổ tức (nếu có), và hưởng lợi khi giá trị công ty tăng. Nhưng cũng chịu rủi ro khi công ty thua lỗ.</span></span> — đồng sở hữu doanh nghiệp. Bạn không cho vay, bạn <strong class="text-white">góp vốn</strong>.</p>
    </div>

    <!-- Flow diagram: company → shares → investors -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-3 items-center mb-8">
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-cyan-400 uppercase tracking-wider mb-1">Công ty</p>
        <p class="text-lg font-bold text-white">Cần vốn mở rộng</p>
      </div>
      <div class="flow-arrow hidden md:flex">&rarr;</div>
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-cyan-400 uppercase tracking-wider mb-1">Phát hành</p>
        <p class="text-lg font-bold text-white">Chia thành cổ phần</p>
      </div>
      <div class="flow-arrow hidden md:flex">&rarr;</div>
      <div class="flow-box" style="border-color: rgba(251, 191, 36, 0.4); background: rgba(251, 191, 36, 0.06);">
        <p class="text-xs font-mono text-amber-400 uppercase tracking-wider mb-1">Nhà đầu tư</p>
        <p class="text-lg font-bold text-white">Mua = Đồng sở hữu</p>
      </div>
    </div>

    <!-- What you get as shareholder -->
    <div class="lesson-card">
      <div class="lesson-num">QUYỀN CỦA CỔ ĐÔNG</div>
      <div class="lesson-title">3 quyền cơ bản khi sở hữu cổ phiếu</div>
      <div class="lesson-body">
        <strong class="text-white">1.</strong> Quyền biểu quyết — bầu ban giám đốc, quyết định chiến lược lớn.<br/>
        <strong class="text-white">2.</strong> Quyền nhận <span class="popover-wrap"><button class="popover-trigger">cổ tức</button><span class="popover-bubble">Dividend — phần lợi nhuận công ty chia cho cổ đông. Không phải công ty nào cũng trả cổ tức — nhiều công ty tăng trưởng giữ lại toàn bộ lợi nhuận để tái đầu tư (như Amazon, Tesla thời đầu).</span></span> — nếu công ty chia lợi nhuận.<br/>
        <strong class="text-white">3.</strong> Quyền hưởng lợi từ tăng giá — giá trị công ty tăng, giá cổ phiếu tăng theo.
      </div>
    </div>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Cổ phiếu phổ thông vs. Cổ phiếu ưu đãi — khác gì?
      </summary>
      <div class="expand-content">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Tiêu chí</th>
              <th>Cổ phiếu phổ thông (Common Stock)</th>
              <th>Cổ phiếu ưu đãi (Preferred Stock)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="col-metric">Quyền biểu quyết</td>
              <td class="good">Có</td>
              <td class="bad">Thường không</td>
            </tr>
            <tr>
              <td class="col-metric">Cổ tức</td>
              <td class="neutral">Không cố định, tùy lợi nhuận</td>
              <td class="good">Cố định, ưu tiên nhận trước</td>
            </tr>
            <tr>
              <td class="col-metric">Khi phá sản</td>
              <td class="bad">Nhận sau cùng (sau trái chủ + cổ đông ưu đãi)</td>
              <td class="neutral">Nhận trước cổ đông phổ thông</td>
            </tr>
            <tr>
              <td class="col-metric">Tiềm năng tăng giá</td>
              <td class="good">Không giới hạn</td>
              <td class="neutral">Hạn chế hơn</td>
            </tr>
          </tbody>
        </table>
        <p class="mt-3 text-sm text-slate-400">Phần lớn nhà đầu tư cá nhân mua cổ phiếu phổ thông. Cổ phiếu ưu đãi phổ biến hơn với quỹ đầu tư muốn dòng tiền ổn định.</p>
      </div>
    </details>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 02: THỊ TRƯỜNG HOẠT ĐỘNG THẾ NÀO                  -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-emerald-500 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 02</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Cơ Chế Thị Trường — Từ IPO Đến Sàn Giao Dịch</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Cổ phiếu không tự nhiên xuất hiện. Nó đi qua hai giai đoạn: phát hành lần đầu (thị trường sơ cấp) và mua bán giữa nhà đầu tư (thị trường thứ cấp).</p>

    <!-- Two markets -->
    <div class="grid md:grid-cols-2 gap-4 mb-8">
      <div class="border border-cyan-500/30 bg-cyan-950/10 p-5">
        <p class="text-xs font-mono text-cyan-400 font-bold uppercase mb-3">Thị Trường Sơ Cấp</p>
        <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-3">Công ty bán cổ phiếu <strong class="text-white">lần đầu tiên</strong> cho nhà đầu tư thông qua <span class="popover-wrap"><button class="popover-trigger">IPO</button><span class="popover-bubble">Initial Public Offering — lần đầu tiên công ty bán cổ phiếu ra công chúng trên sàn giao dịch. Trước IPO, công ty là "tư nhân" — chỉ sáng lập viên và nhà đầu tư mạo hiểm nắm cổ phần. Sau IPO, bất kỳ ai cũng có thể mua.</span></span>.</p>
        <p class="text-base md:text-lg text-slate-300 leading-relaxed">Tiền từ IPO chảy <strong class="text-white">vào công ty</strong> — dùng để mở rộng, trả nợ, hoặc đầu tư R&D.</p>
      </div>
      <div class="border border-amber-500/30 bg-amber-950/10 p-5">
        <p class="text-xs font-mono text-amber-400 font-bold uppercase mb-3">Thị Trường Thứ Cấp</p>
        <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-3">Sau IPO, cổ phiếu được giao dịch giữa <strong class="text-white">nhà đầu tư với nhau</strong> trên <span class="popover-wrap"><button class="popover-trigger">sàn giao dịch</button><span class="popover-bubble">Stock Exchange — nền tảng tập trung nơi người mua và người bán khớp lệnh. Ví dụ: NYSE (New York), NASDAQ (Mỹ), HOSE (TP.HCM), HNX (Hà Nội). Sàn đảm bảo giao dịch minh bạch, có giám sát pháp lý.</span></span>.</p>
        <p class="text-base md:text-lg text-slate-300 leading-relaxed">Tiền <strong class="text-white">không chảy về công ty</strong> — chỉ chuyển từ ví người mua sang ví người bán. Đây là nơi 99% giao dịch hàng ngày diễn ra.</p>
      </div>
    </div>

    <!-- Price mechanism -->
    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-8">
      <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-3">Cơ Chế Giá</p>
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Giá cổ phiếu được quyết định bởi <span class="hl">cung</span> và <span class="hl-gold">cầu</span> — hoàn toàn giống mọi thị trường khác.</p>
      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Nhiều người muốn mua hơn bán → giá tăng. Nhiều người muốn bán hơn mua → giá giảm. Đơn giản vậy thôi. Nhưng <em>tại sao</em> người ta muốn mua hoặc bán — đó mới là phần phức tạp.</p>
    </div>

    <!-- Factors driving supply/demand -->
    <div class="grid md:grid-cols-2 gap-3 mb-6">
      <div class="greenflag-item">
        <svg class="greenflag-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
        <div class="greenflag-text">
          <strong>Đẩy giá lên:</strong> Lợi nhuận tăng, sản phẩm mới, ngành đang "hot", <span class="popover-wrap"><button class="popover-trigger">lãi suất</button><span class="popover-bubble">Interest Rate — chi phí vay tiền. Khi lãi suất thấp, gửi tiết kiệm lãi ít → nhà đầu tư chuyển tiền sang cổ phiếu để tìm lợi suất cao hơn → cầu cổ phiếu tăng → giá tăng.</span></span> giảm, tâm lý lạc quan.
        </div>
      </div>
      <div class="redflag-item">
        <svg class="redflag-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
        <div class="redflag-text">
          <strong>Kéo giá xuống:</strong> Lợi nhuận giảm, scandal, suy thoái kinh tế, lãi suất tăng, nhà đầu tư hoảng loạn bán tháo.
        </div>
      </div>
    </div>

    <div class="lesson-card">
      <div class="lesson-num">NGUYÊN TẮC NỀN TẢNG</div>
      <div class="lesson-title">Ngắn hạn, giá cổ phiếu bị chi phối bởi tâm lý. Dài hạn, nó quay về giá trị thực của doanh nghiệp.</div>
      <div class="lesson-body">Benjamin Graham gọi thị trường ngắn hạn là "máy bỏ phiếu" (voting machine) — đo lường sự phổ biến. Dài hạn, nó là "cái cân" (weighing machine) — đo lường giá trị thực.</div>
    </div>
  </section>

