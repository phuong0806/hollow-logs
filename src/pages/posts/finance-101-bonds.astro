          <span class="font-mono text-cyan-400">-4.5%</span>
        </div>
        <div class="bar-track">
          <div class="bar-fill bg-cyan-500" style="width: 22.5%"></div>
        </div>
      </div>
      <div>
        <div class="flex justify-between text-xs text-slate-400 mb-1">
