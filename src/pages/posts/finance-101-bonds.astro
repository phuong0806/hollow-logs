---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Finance 101: Trái Phiếu — Tại Sao "Kênh Đầu Tư Nhàm Chán Nhất" Là Thứ Bạn Cần Hiểu Trước Tiên',
  description: 'Trái phiếu không sexy, nhưng nếu bạn không hiểu bond thì bạn không thực sự hiểu lãi suất — và lãi suất chi phối mọi quyết định tài chính của bạn.',
  pubDate: new Date('2026-04-23'),
  tags: ['finance', 'economics'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="Tài Chính Cơ Bản"
  kickerColor="cyan"
>
  <style>
    /* ─── Popovers ─────────────────────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(34 211 238);
      border-bottom: 1px dashed rgba(34, 211, 238, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(34 211 238); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 290px;
      padding: 12px 14px; background: #1a2744;
      border: 1px solid rgba(34, 211, 238, 0.25);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(34, 211, 238, 0.25);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 230px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Bar chart ────────────────────────────── */
    .bar-track {
      height: 28px; background: rgba(30, 41, 59, 0.8);
      position: relative; overflow: hidden;
    }
    .bar-fill { height: 100%; }

    /* ─── Timeline ─────────────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(34, 211, 238, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(34, 211, 238, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(34, 211, 238); border-color: rgb(34, 211, 238);
      box-shadow: 0 0 8px rgba(34, 211, 238, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.gold::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(34, 211, 238); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.gold .timeline-year { color: rgb(251, 191, 36); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.gold .timeline-desc { color: rgb(254 243 199); font-weight: 600; }

    /* ─── Stats grid ───────────────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(34, 211, 238);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(34, 211, 238, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }

    /* ─── Red flags ────────────────────────────── */
    .redflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.03); margin-bottom: 10px;
    }
    .redflag-icon { color: rgb(239 68 68); flex-shrink: 0; margin-top: 2px; }
    .redflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .redflag-text strong { color: white; }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(34, 211, 238, 0.12);
      color: rgb(34, 211, 238);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(34, 211, 238, 0.35);
    }
    .hl-gold {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(34, 211, 238, 0.08);
      border: 1px solid rgba(34, 211, 238, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(34, 211, 238); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(34, 211, 238);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(34, 211, 238); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Green flag ───────────────────────────── */
    .greenflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(16, 185, 129, 0.2);
      background: rgba(16, 185, 129, 0.03); margin-bottom: 10px;
    }
    .greenflag-icon { color: rgb(52 211 153); flex-shrink: 0; margin-top: 2px; }
    .greenflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .greenflag-text strong { color: white; }

    /* ─── Yield curve visual ───────────────────── */
    .curve-chart {
      position: relative; height: 200px;
      border-left: 2px solid rgba(100, 116, 139, 0.4);
      border-bottom: 2px solid rgba(100, 116, 139, 0.4);
      margin: 0 0 8px 0;
    }
    .curve-dot {
      position: absolute; width: 10px; height: 10px; border-radius: 50%;
      transform: translate(-50%, 50%);
    }
    .curve-label {
      position: absolute; font-size: 0.65rem; font-family: monospace;
      color: rgb(148 163 184); transform: translateX(-50%);
    }

    /* ─── Price seesaw ─────────────────────────── */
    .seesaw-box {
      display: flex; align-items: center; justify-content: center;
      gap: 12px; padding: 20px;
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3);
    }
    .seesaw-item {
      text-align: center; flex: 1;
    }
    .seesaw-arrow {
      font-size: 2rem; color: rgb(148 163 184); flex-shrink: 0;
    }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-cyan-500 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-cyan-400 leading-snug">
        "Trái phiếu không phải là thứ nhàm chán. Nó là nền móng của toàn bộ hệ thống tài chính."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Ray Dalio, <em>Principles for Navigating Big Debt Crises</em>, 2018
      </footer>
    </div>
  </section>

  <!-- CONTEXT INTRO -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh</p>
        <p class="text-slate-300 text-sm leading-relaxed">Thị trường trái phiếu toàn cầu trị giá hơn <strong class="text-white">$133 nghìn tỷ</strong> — lớn hơn thị trường cổ phiếu. Nhưng phần lớn nhà đầu tư cá nhân bỏ qua nó, vì nghĩ bond là "thứ dành cho người già".</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed">Năm 2022–2023, nhiều người mua trái phiếu "an toàn" và <strong class="text-white">lỗ 10–20%</strong> khi Fed tăng lãi suất. Họ không hiểu: bond có giá, và giá bond biến động theo <span class="popover-wrap"><button class="popover-trigger">lãi suất</button><span class="popover-bubble">Interest Rate — chi phí vay tiền do ngân hàng trung ương (Fed, NHNN) điều chỉnh. Khi lãi suất tăng, trái phiếu cũ có coupon thấp hơn trở nên kém hấp dẫn → giá giảm. Đây là rủi ro số 1 của bond.</span></span>.</p>
      </div>
      <div class="border border-cyan-500/20 bg-cyan-950/10 p-4">
        <p class="text-xs font-mono text-cyan-500 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed">Trái phiếu hoạt động ra sao, tại sao <span class="hl">giá nghịch chiều lãi suất</span>, cách đọc <span class="hl-gold">yield curve</span>, và khi nào bond là <span class="hl-green">lựa chọn tối ưu</span> trong portfolio.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- STATS OVERVIEW                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="stat-card">
        <div class="stat-num">$133T</div>
        <div class="stat-label">Thị trường bond toàn cầu</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">4.25%</div>
        <div class="stat-label">Yield US 10Y (T4/2026)</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">~5%</div>
        <div class="stat-label">Lợi suất TB bond dài hạn</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">800+</div>
        <div class="stat-label">Năm lịch sử trái phiếu</div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 01: TRÁI PHIẾU LÀ GÌ?                             -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-cyan-500 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Giải Phẫu Một Trái Phiếu — Coupon, Yield, Và Cái Bẫy "Lãi Suất Cố Định"</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Khi bạn mua cổ phiếu, bạn trở thành đồng sở hữu. Khi bạn mua trái phiếu, bạn trở thành chủ nợ. Sự khác biệt đó thay đổi mọi thứ.</p>

    <!-- Core concept -->
    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-8">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4"><span class="popover-wrap"><button class="popover-trigger">Trái phiếu</button><span class="popover-bubble">Bond — giấy nợ do chính phủ, doanh nghiệp, hoặc tổ chức phát hành. Người mua trái phiếu cho bên phát hành vay tiền, đổi lại nhận lãi suất định kỳ (coupon) và được hoàn gốc khi đáo hạn. Khác cổ phiếu: không cho quyền sở hữu, chỉ cho quyền đòi nợ.</span></span> là một hợp đồng vay. Bên phát hành (chính phủ hoặc doanh nghiệp) nói: "Cho tôi vay X đồng, tôi sẽ trả lãi Y% mỗi năm, và hoàn gốc sau Z năm."</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Nghe đơn giản. Nhưng cái phức tạp nằm ở chỗ: trái phiếu có thể <strong class="text-white">mua bán trên thị trường thứ cấp</strong> — và giá của nó thay đổi mỗi ngày, phụ thuộc vào lãi suất, lạm phát, và mức độ tín nhiệm của bên vay.</p>
    </div>

    <!-- 3 components of a bond -->
    <div class="grid md:grid-cols-3 gap-4 mb-8">
      <div class="border border-cyan-500/30 bg-cyan-950/10 p-5">
        <p class="text-xs font-mono text-cyan-400 font-bold uppercase mb-2">Thành Phần #1</p>
        <h3 class="text-xl font-bold text-white mb-3"><span class="popover-wrap"><button class="popover-trigger">Face Value</button><span class="popover-bubble">Mệnh giá — số tiền bên phát hành cam kết trả lại khi trái phiếu đáo hạn. Thường là $1.000 (Mỹ) hoặc 100.000đ (Việt Nam). Giá giao dịch trên thị trường có thể cao hơn hoặc thấp hơn mệnh giá.</span></span> (Mệnh giá)</h3>
        <p class="text-base text-slate-300 leading-relaxed">Số tiền bạn nhận lại khi bond đáo hạn. Ví dụ: mệnh giá $1.000 nghĩa là bạn được hoàn đúng $1.000 vào ngày kết thúc.</p>
      </div>
      <div class="border border-amber-500/30 bg-amber-950/10 p-5">
        <p class="text-xs font-mono text-amber-400 font-bold uppercase mb-2">Thành Phần #2</p>
        <h3 class="text-xl font-bold text-white mb-3"><span class="popover-wrap"><button class="popover-trigger">Coupon Rate</button><span class="popover-bubble">Lãi suất coupon — tỷ lệ % lãi cố định mà bên phát hành trả hàng năm dựa trên mệnh giá. Bond mệnh giá $1.000 với coupon 5% → trả $50/năm. Coupon không đổi suốt đời bond — đó là lý do gọi nó là "cố định".</span></span> (Lãi suất coupon)</h3>
        <p class="text-base text-slate-300 leading-relaxed">Lãi suất cố định trả hàng năm (hoặc nửa năm). Bond $1.000 coupon 5% → nhận $50/năm, bất kể giá thị trường.</p>
      </div>
      <div class="border border-emerald-500/30 bg-emerald-950/10 p-5">
        <p class="text-xs font-mono text-emerald-400 font-bold uppercase mb-2">Thành Phần #3</p>
        <h3 class="text-xl font-bold text-white mb-3"><span class="popover-wrap"><button class="popover-trigger">Maturity Date</button><span class="popover-bubble">Ngày đáo hạn — thời điểm bên phát hành hoàn trả toàn bộ mệnh giá. Bond 10 năm phát hành 2026 → đáo hạn 2036. Kỳ hạn càng dài, rủi ro lãi suất càng cao — vì nhiều thứ có thể thay đổi trong 30 năm.</span></span> (Ngày đáo hạn)</h3>
        <p class="text-base text-slate-300 leading-relaxed">Thời điểm bond "hết hạn" và bạn nhận lại gốc. Kỳ hạn 2 năm đến 30 năm — mỗi mức mang rủi ro khác nhau.</p>
      </div>
    </div>

    <!-- Flow diagram: how a bond works -->
    <div class="grid grid-cols-1 md:grid-cols-7 gap-3 items-center mb-8">
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-cyan-400 uppercase tracking-wider mb-1">Nhà đầu tư</p>
        <p class="text-lg font-bold text-white">Cho vay $1.000</p>
      </div>
      <div class="flow-arrow hidden md:flex">&rarr;</div>
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-cyan-400 uppercase tracking-wider mb-1">Bên phát hành</p>
        <p class="text-lg font-bold text-white">Nhận tiền, dùng vốn</p>
      </div>
      <div class="flow-arrow hidden md:flex">&rarr;</div>
      <div class="flow-box" style="border-color: rgba(251, 191, 36, 0.4); background: rgba(251, 191, 36, 0.06);">
        <p class="text-xs font-mono text-amber-400 uppercase tracking-wider mb-1">Mỗi năm</p>
        <p class="text-lg font-bold text-white">Trả coupon $50</p>
      </div>
      <div class="flow-arrow hidden md:flex">&rarr;</div>
      <div class="flow-box" style="border-color: rgba(52, 211, 153, 0.4); background: rgba(52, 211, 153, 0.06);">
        <p class="text-xs font-mono text-emerald-400 uppercase tracking-wider mb-1">Đáo hạn</p>
        <p class="text-lg font-bold text-white">Hoàn gốc $1.000</p>
      </div>
    </div>

    <!-- Yield vs Coupon — the key distinction -->
    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-8">
      <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-3">Sự Khác Biệt Quan Trọng Nhất</p>
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4"><span class="popover-wrap"><button class="popover-trigger">Coupon</button><span class="popover-bubble">Coupon — lãi suất cố định ghi trên bond, không bao giờ thay đổi. Bond coupon 5% sẽ trả 5% mệnh giá mỗi năm cho đến khi đáo hạn — dù thị trường lãi suất lên 10% hay xuống 1%.</span></span> là lãi suất <strong class="text-white">cố định</strong> ghi trên bond. <span class="popover-wrap"><button class="popover-trigger">Yield</button><span class="popover-bubble">Yield (lợi suất) — lợi nhuận thực tế bạn nhận được dựa trên giá bạn trả. Nếu bond coupon 5% mệnh giá $1.000 nhưng bạn mua giá $900, yield thực tế cao hơn 5% — vì bạn nhận $50/năm trên khoản đầu tư $900, không phải $1.000.</span></span> là lợi suất <strong class="text-white">thực tế</strong> dựa trên giá bạn trả.</p>

      <div class="grid md:grid-cols-2 gap-3">
        <div class="border border-cyan-500/20 bg-cyan-950/10 p-4">
          <p class="text-sm text-cyan-400 font-bold mb-1">Mua đúng mệnh giá ($1.000)</p>
          <p class="text-slate-300 text-sm">Coupon 5% → Yield = 5%</p>
        </div>
        <div class="border border-amber-500/20 bg-amber-950/10 p-4">
          <p class="text-sm text-amber-400 font-bold mb-1">Mua dưới mệnh giá ($900)</p>
          <p class="text-slate-300 text-sm">Coupon 5% → Yield = 5.56% ($50/$900)</p>
        </div>
      </div>
      <p class="text-sm text-slate-400 mt-3">Mua giá thấp hơn → yield cao hơn. Mua giá cao hơn → yield thấp hơn. Đây là nguyên lý nền tảng của toàn bộ thị trường bond.</p>
    </div>

    <!-- THE SEESAW: Price vs Yield -->
    <div class="border-2 border-cyan-500/40 bg-cyan-950/10 p-6 md:p-8 mb-8">
      <p class="text-xs text-cyan-500 font-bold uppercase tracking-widest mb-4">Quy Luật Vàng</p>
      <p class="text-2xl md:text-3xl font-black text-white leading-tight mb-4">
        Giá bond và yield luôn đi ngược chiều nhau.
      </p>
      <div class="seesaw-box">
        <div class="seesaw-item">
          <p class="text-3xl font-bold text-emerald-400 mb-1">&uarr;</p>
          <p class="text-sm font-bold text-white">Lãi suất tăng</p>
        </div>
        <div class="seesaw-arrow">=</div>
        <div class="seesaw-item">
          <p class="text-3xl font-bold text-rose-400 mb-1">&darr;</p>
          <p class="text-sm font-bold text-white">Giá bond giảm</p>
        </div>
      </div>
      <p class="text-sm text-slate-400 mt-4">Tại sao? Vì khi lãi suất mới cao hơn, không ai muốn mua bond cũ có coupon thấp — trừ khi được giảm giá. Bond coupon 3% trở nên "rẻ" so với bond mới coupon 5%. Vậy giá nó phải giảm để yield tăng lên cho cạnh tranh.</p>
    </div>

    <!-- Duration concept -->
    <div class="lesson-card">
      <div class="lesson-num">KHÁI NIỆM THEN CHỐT</div>
      <div class="lesson-title"><span class="popover-wrap"><button class="popover-trigger">Duration</button><span class="popover-bubble">Duration (thời lượng) — thước đo độ nhạy của giá bond với thay đổi lãi suất. Duration 7 năm nghĩa là: lãi suất tăng 1% → giá bond giảm ~7%. Kỳ hạn càng dài, duration càng cao, và bond càng "rung lắc" mạnh khi lãi suất thay đổi.</span></span> — Thước đo rủi ro lãi suất</div>
      <div class="lesson-body">Duration cho biết giá bond nhạy cảm thế nào với lãi suất. Duration 10 năm = lãi suất tăng 1%, giá bond giảm ~10%. Bond 30 năm có duration cao nhất — và cũng biến động mạnh nhất.</div>
    </div>

    <!-- Duration impact table -->
    <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-3 mt-6">Ảnh Hưởng Của Lãi Suất Tăng 1% Theo Duration</p>
    <div class="space-y-2 mb-6">
      <div>
        <div class="flex justify-between text-xs text-slate-400 mb-1">
          <span>Bond 2 năm (Duration ~2)</span>
          <span class="font-mono text-emerald-400">-2%</span>
        </div>
