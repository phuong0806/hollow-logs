    <!-- Architecture -->
    <p class="text-xs font-mono text-amber-400 font-bold uppercase tracking-wider mb-4">"Ngày Xưa Xây Đẹp Hơn" — Ảo Giác Kiến Trúc</p>

    <div class="grid md:grid-cols-2 gap-4 mb-6">
