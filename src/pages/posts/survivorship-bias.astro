---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Vì Sao Bạn Nên Đi Viếng Các Nghĩa Trang — Lỗi Tư Duy Sống Sót',
  description: 'Bạn đang học từ những kẻ thắng cuộc mà quên mất nghĩa trang chứa hàng triệu người đã làm y hệt — và thất bại. Từ Diagoras thế kỷ 5 TCN đến Abraham Wald trong Thế chiến II, từ Steve Jobs đến 65% doanh nghiệp phá sản — survivorship bias đang bóp méo mọi quyết định của bạn.',
  pubDate: new Date('2026-04-24'),
  tags: ['psychology', 'philosophy'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="LỖI TƯ DUY"
  kickerColor="emerald"
>
  <style>
    /* ─── Popovers (amber theme) ───────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(251, 191, 36);
      border-bottom: 1px dashed rgba(251, 191, 36, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(251, 191, 36); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 300px;
      padding: 12px 14px; background: #1a1a0a;
      border: 1px solid rgba(251, 191, 36, 0.3);
      box-shadow: 0 8px 24px rgba(0,0,0,0.5);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(251, 191, 36, 0.3);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 240px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Timeline (amber) ─────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(251, 191, 36, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(251, 191, 36, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.success::before {
      background: rgb(52, 211, 153); border-color: rgb(52, 211, 153);
      box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(251, 191, 36); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.success .timeline-year { color: rgb(52, 211, 153); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.success .timeline-desc { color: rgb(209 250 229); font-weight: 600; }

    /* ─── Stat cards (amber) ──────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(251, 191, 36, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(251, 191, 36);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(251, 191, 36, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(251, 191, 36);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(251, 191, 36); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }
    .hl-cyan {
      background: rgba(34, 211, 238, 0.12);
      color: rgb(34, 211, 238);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(34, 211, 238, 0.35);
    }

    /* ─── Evidence bars ────────────────────────── */
    .evidence-row { margin-bottom: 12px; }
    .evidence-label {
      font-size: 0.78rem; font-weight: 600; color: rgb(203 213 225);
      margin-bottom: 4px;
    }
    .evidence-track {
      height: 28px; background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.2);
      position: relative; overflow: hidden;
    }
    .evidence-fill {
      height: 100%; display: flex; align-items: center;
      padding-left: 8px; font-size: 0.7rem; font-weight: 700;
    }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(251, 191, 36, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(251, 191, 36, 0.06);
      border: 1px solid rgba(251, 191, 36, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(251, 191, 36); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Redflag items ────────────────────────── */
    .redflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.03); margin-bottom: 10px;
    }
    .redflag-icon { color: rgb(239 68 68); flex-shrink: 0; margin-top: 2px; }
    .redflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .redflag-text strong { color: white; }

    /* ─── Bomber diagram ───────────────────────── */
    .bomber-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 640px) { .bomber-grid { grid-template-columns: 1fr; } }
    .bomber-part {
      padding: 14px; border: 1px solid rgba(100, 116, 139, 0.2);
      background: rgba(21, 31, 50, 0.4);
    }
    .bomber-part-name {
      font-size: 0.72rem; font-family: monospace; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;
    }
    .bomber-bar {
      height: 20px; background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.15);
      position: relative; overflow: hidden; margin-bottom: 4px;
    }
    .bomber-bar-fill {
      height: 100%; display: flex; align-items: center;
      padding-left: 6px; font-size: 0.65rem; font-weight: 700;
    }
    .bomber-conclusion {
      font-size: 0.75rem; color: rgb(148 163 184);
    }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-amber-400 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-amber-300 leading-snug">
        "Nghĩa trang của những kẻ thất bại sẽ chứa đầy người có chung các đặc điểm sau: can đảm, dám chấp nhận rủi ro, lạc quan — y hệt dàn triệu phú. Thứ thực sự chia tách hai nhóm, phần lớn, là một yếu tố duy nhất: may mắn."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Nassim Nicholas Taleb, <em>The Black Swan</em>, Chương 8 (2007)
      </footer>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- CONTEXT INTRO                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh</p>
        <p class="text-slate-300 text-sm leading-relaxed"><span class="popover-wrap"><button class="popover-trigger">Survivorship bias</button><span class="popover-bubble">Survivorship bias (Thiên kiến sống sót) — lỗi logic xảy ra khi ta chỉ tập trung vào những thứ "sống sót" qua một bộ lọc chọn lọc (thành công, còn tồn tại, được ghi nhận) mà bỏ qua những thứ đã bị loại bỏ. Kết quả: bức tranh bị bóp méo nghiêm trọng vì phần lớn dữ liệu — phần thất bại — đã biến mất.</span></span> — thiên kiến sống sót — là một trong những lỗi tư duy phổ biến nhất và khó nhận ra nhất. Nó xảy ra khi ta chỉ nhìn vào "người sống" mà quên rằng <strong class="text-white">nghĩa trang tồn tại</strong>.</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed">Chúng ta đọc tiểu sử tỷ phú, nghiên cứu các quỹ đầu tư thắng lớn, ngưỡng mộ các tòa nhà cổ — nhưng <span class="hl-red">không bao giờ thấy</span> hàng triệu doanh nhân phá sản, hàng ngàn quỹ đã bị đóng, hàng vạn tòa nhà tồi đã bị phá dỡ.</p>
      </div>
      <div class="border border-amber-500/20 bg-amber-950/10 p-4">
        <p class="text-xs font-mono text-amber-400 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed"><span class="hl">Câu hỏi 2,500 tuổi</span> của Diagoras. <span class="hl-cyan">Vết đạn vô hình</span> của Abraham Wald. <span class="hl-red">Nghĩa trang doanh nhân</span> — 65% phá sản trong 10 năm. <span class="hl-green">Nghĩa trang tài chính</span> — 93% quỹ thua chỉ số. Và cách <span class="hl">Kahneman giải thích</span> tại sao não bạn bẫy bạn.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- STATS OVERVIEW                                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="stat-card">
        <div class="stat-num">~2,500</div>
        <div class="stat-label">Năm kể từ Diagoras nhận ra</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">65.3%</div>
        <div class="stat-label">Doanh nghiệp Mỹ chết trong 10 năm</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">93%</div>
        <div class="stat-label">Quỹ thua S&P 500 sau 20 năm</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">87%</div>
        <div class="stat-label">Nhạc trên Spotify &lt; 1,000 lượt nghe</div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- MỞ BÀI                                                 -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border border-slate-700/40 bg-slate-900/20 p-6">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Khi ai đó hỏi bạn: <em>"Muốn thành công, hãy học từ người thành công"</em> — điều đó nghe hợp lý. Đọc tiểu sử Steve Jobs. Bắt chước thói quen của Elon Musk. Làm theo lời khuyên "bỏ học đại học, khởi nghiệp."</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Nhưng có một câu hỏi mà <strong class="text-white">không ai đặt ra</strong>: trong hàng triệu người đã làm y hệt Steve Jobs — bỏ học, khởi nghiệp trong garage, làm việc 18 giờ/ngày, tin vào tầm nhìn điên rồ — bao nhiêu người đã thất bại?</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Câu trả lời: <span class="hl-red">hầu hết</span>. Nhưng bạn sẽ không bao giờ đọc tiểu sử của họ. Nhà xuất bản không in sách về kẻ thua cuộc. TED Talks không mời diễn giả kể về cách họ mất sạch. <strong class="text-white">Nghĩa trang im lặng</strong> — và đó chính xác là vấn đề.</p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 01: DIAGORAS                                       -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-amber-400 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Bức Tranh Trong Đền — Câu Hỏi 2,500 Năm Tuổi</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Một người vô thần nhìn thấy điều mà cả ngôi đền không nhìn ra.</p>

    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-6">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Thế kỷ 5 trước Công nguyên. Một ngôi đền trên đảo <span class="popover-wrap"><button class="popover-trigger">Samothrace</button><span class="popover-bubble">Samothrace — hòn đảo Hy Lạp ở phía bắc biển Aegean, nổi tiếng với ngôi đền thờ các vị thần biển cả. Thủy thủ thường đến đây cầu nguyện trước khi ra khơi và cúng dường sau khi sống sót qua bão.</span></span>. Trên tường treo đầy bức tranh vẽ những thủy thủ đã cầu nguyện thần <span class="popover-wrap"><button class="popover-trigger">Neptune</button><span class="popover-bubble">Neptune (Poseidon trong thần thoại Hy Lạp) — thần biển cả, một trong 12 vị thần Olympus. Thủy thủ La Mã và Hy Lạp thường cầu nguyện Neptune trước mỗi chuyến đi, dâng lễ vật để xin biển lặng và gió thuận.</span></span> — rồi sống sót qua bão.</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Ai đó dẫn <span class="popover-wrap"><button class="popover-trigger">Diagoras xứ Melos</button><span class="popover-bubble">Diagoras xứ Melos (thế kỷ 5 TCN) — triết gia Hy Lạp, được mệnh danh là "Kẻ Vô Thần" (ho atheos). Bị Athens kết án tử hình vì phỉ báng các vị thần. Là một trong những người vô thần nổi tiếng đầu tiên trong lịch sử phương Tây.</span></span> — một triết gia nổi tiếng là kẻ vô thần — đến ngôi đền này. Họ chỉ vào những bức tranh: <em>"Nhìn xem, bằng chứng đây! Những người cầu nguyện đều được cứu!"</em></p>

      <p class="text-base md:text-lg text-amber-300 leading-relaxed font-bold">Diagoras trả lời: "Vậy những bức tranh của những người đã cầu nguyện — rồi chết đuối — đâu?"</p>
    </div>

    <div class="border border-amber-500/20 bg-amber-950/10 p-5 mb-6">
      <p class="text-xs font-mono text-amber-400 font-bold uppercase tracking-wider mb-3">Nguồn Gốc</p>
      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Câu chuyện được <span class="popover-wrap"><button class="popover-trigger">Cicero</button><span class="popover-bubble">Marcus Tullius Cicero (106–43 TCN) — chính trị gia, triết gia, và nhà hùng biện La Mã. Tác phẩm De Natura Deorum (Về Bản Chất Các Vị Thần) viết năm 45 TCN, là một trong những cuộc tranh luận triết học quan trọng nhất về sự tồn tại và bản chất của thần thánh.</span></span> ghi lại trong <em>De Natura Deorum</em> (Về Bản Chất Các Vị Thần), Quyển III, năm 45 TCN. Năm 2005, tạp chí y khoa <em>The Lancet</em> đăng bài "Diagoras of Melos (500 BC): an early analyst of publication bias" — chính thức công nhận Diagoras là người đầu tiên trong lịch sử nhận ra cơ chế mà ngày nay gọi là <span class="hl">survivorship bias</span>.</p>
    </div>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Câu hỏi của Diagoras đơn giản đến mức thiên tài: <strong class="text-white">người chết không để lại bằng chứng</strong>. Ngôi đền chỉ trưng bày tranh của người sống sót. Không ai vẽ tranh cho kẻ đã chìm xuống đáy biển.</p>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed">Hai ngàn năm trăm năm sau, chúng ta vẫn mắc <em>chính xác</em> lỗi này — chỉ khác ở quy mô.</p>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 02: ABRAHAM WALD                                   -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-amber-400 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 02</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Những Vết Đạn Không Ai Nhìn Thấy — Abraham Wald và Chiến Tranh Thế Giới Thứ Hai</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Một nhà toán học Do Thái chạy trốn phát xít đã cứu hàng ngàn phi công bằng cách nhìn vào nơi không có vết đạn.</p>

    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-6">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Năm 1943, tại số 401 West 118th Street, khu Morningside Heights, New York — <span class="popover-wrap"><button class="popover-trigger">Nhóm Nghiên cứu Thống kê</button><span class="popover-bubble">Statistical Research Group (SRG) — nhóm nghiên cứu bí mật tại Đại học Columbia trong Thế chiến II, quy tụ 18 nhà toán học và thống kê xuất sắc nhất nước Mỹ. Thành viên gồm cả những người sau này đoạt Nobel: Milton Friedman (Kinh tế 1976) và George Stigler (Kinh tế 1982).</span></span> (SRG) tại Đại học Columbia đối mặt với bài toán sống còn: <strong class="text-white">bọc thép chỗ nào trên máy bay ném bom?</strong></p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Thêm thép = thêm nặng = ít bom hơn + bay chậm hơn + tốn nhiều nhiên liệu hơn. Không thể bọc thép toàn bộ. Phải chọn.</p>
    </div>

    <!-- Wald Timeline -->
    <p class="text-xs font-mono text-amber-400 font-bold uppercase tracking-wider mb-4">Abraham Wald — Hành Trình Từ Nạn Nhân Đến Cứu Tinh</p>

    <div class="timeline mb-8">
      <div class="timeline-item">
        <div class="timeline-year">1902</div>
        <div class="timeline-desc">Sinh tại Kolozsvár (Cluj), Transylvania. Gia đình Do Thái chính thống — cậu bé Wald được học tại nhà vì không thể đến trường vào thứ Bảy (<span class="popover-wrap"><button class="popover-trigger">Shabbat</button><span class="popover-bubble">Shabbat — ngày nghỉ thiêng liêng trong Do Thái giáo, từ chiều thứ Sáu đến tối thứ Bảy. Người Do Thái chính thống không được làm việc, đi xe, hay viết lách trong Shabbat. Điều này khiến Wald không thể đến trường công.</span></span>).</div>
      </div>
      <div class="timeline-item">
        <div class="timeline-year">1931</div>
        <div class="timeline-desc">Nhận bằng tiến sĩ toán học tại Đại học Vienna dưới sự hướng dẫn của Karl Menger. Chuyên về hình học và thống kê.</div>
      </div>
      <div class="timeline-item danger">
        <div class="timeline-year">1938</div>
        <div class="timeline-desc">Phát xít Đức sáp nhập Áo (Anschluss). Wald chạy trốn sang Mỹ. Trong 9 thành viên gia đình ở lại, 8 người chết tại Auschwitz.</div>
      </div>
      <div class="timeline-item highlight">
        <div class="timeline-year">1943</div>
        <div class="timeline-desc">Gia nhập SRG. Viết báo cáo "A Method of Estimating Plane Vulnerability Based on Damage of Survivors" — bài báo thay đổi cách Quân đội Mỹ thiết kế máy bay.</div>
      </div>
    </div>

    <!-- The Problem -->
    <p class="text-xs font-mono text-amber-400 font-bold uppercase tracking-wider mb-4">Dữ Liệu Quân Đội Thu Thập: Vết Đạn Trên Máy Bay Trở Về</p>

    <div class="bomber-grid mb-6">
      <div class="bomber-part">
        <p class="bomber-part-name text-slate-400">Thân máy bay (Fuselage)</p>
        <div class="bomber-bar">
          <div class="bomber-bar-fill" style="width: 96%; background: rgba(239, 68, 68, 0.4); color: rgb(252, 165, 165);">1.73 lỗ đạn/ft²</div>
        </div>
        <p class="bomber-conclusion"><span class="hl-red">Nhiều nhất</span> — quân đội muốn bọc thép ở đây</p>
      </div>
      <div class="bomber-part">
        <p class="bomber-part-name text-slate-400">Phần còn lại</p>
        <div class="bomber-bar">
          <div class="bomber-bar-fill" style="width: 100%; background: rgba(239, 68, 68, 0.3); color: rgb(252, 165, 165);">1.80 lỗ đạn/ft²</div>
        </div>
        <p class="bomber-conclusion"><span class="hl-red">Cũng nhiều</span> — cũng muốn bọc thép</p>
      </div>
      <div class="bomber-part">
        <p class="bomber-part-name text-slate-400">Hệ thống nhiên liệu</p>
        <div class="bomber-bar">
          <div class="bomber-bar-fill" style="width: 86%; background: rgba(251, 191, 36, 0.3); color: rgb(251, 191, 36);">1.55 lỗ đạn/ft²</div>
        </div>
        <p class="bomber-conclusion"><span class="hl">Ít hơn</span></p>
      </div>
      <div class="bomber-part">
        <p class="bomber-part-name text-amber-400">Động cơ (Engine)</p>
        <div class="bomber-bar">
          <div class="bomber-bar-fill" style="width: 62%; background: rgba(52, 211, 153, 0.3); color: rgb(52, 211, 153);">1.11 lỗ đạn/ft²</div>
        </div>
        <p class="bomber-conclusion"><span class="hl-green">Ít nhất</span> — quân đội bỏ qua</p>
      </div>
    </div>

    <!-- The Insight -->
    <div class="border border-amber-500/30 bg-amber-950/15 p-6 mb-6">
      <p class="text-xs font-mono text-amber-400 font-bold uppercase tracking-wider mb-3">Insight Của Wald</p>
      <p class="text-base md:text-lg text-amber-200 leading-relaxed font-bold mb-4">Quân đội đang đếm vết đạn trên máy bay đã trở về. Nhưng máy bay trúng đạn vào động cơ — không bao giờ trở về.</p>
      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Thân máy bay có nhiều vết đạn vì <em>máy bay trúng đạn ở thân vẫn bay được về</em>. Động cơ có ít vết đạn không phải vì đạn né động cơ — mà vì <span class="hl-red">máy bay trúng đạn vào động cơ đã rơi</span>. Dữ liệu chỉ đến từ "người sống sót." Câu trả lời nằm ở nghĩa trang.</p>
    </div>

    <!-- Flow diagram -->
    <div class="grid md:grid-cols-5 gap-3 items-center mb-6">
      <div class="flow-box">
        <p class="text-sm font-bold text-white mb-1">Máy bay xuất kích</p>
        <p class="text-xs text-slate-400">100 chiếc</p>
      </div>
      <div class="flow-arrow">&#8594;</div>
      <div class="flow-box">
        <p class="text-sm font-bold text-white mb-1">Trúng đạn</p>
        <p class="text-xs text-slate-400">Ngẫu nhiên khắp nơi</p>
      </div>
      <div class="flow-arrow">&#8594;</div>
      <div class="grid grid-rows-2 gap-3">
        <div class="flow-box-accent">
          <p class="text-sm font-bold text-amber-300">Về được</p>
          <p class="text-xs text-slate-400">Trúng thân &#8594; ta thấy dữ liệu</p>
        </div>
        <div class="flow-box" style="border-color: rgba(239, 68, 68, 0.3);">
          <p class="text-sm font-bold text-red-300">Rơi</p>
          <p class="text-xs text-slate-400">Trúng động cơ &#8594; dữ liệu biến mất</p>
        </div>
      </div>
    </div>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4"><strong class="text-white">Kết quả:</strong> Quân đội bọc thép động cơ theo khuyến nghị của Wald. Tỷ lệ máy bay trở về tăng đáng kể.</p>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Chi tiết thú vị: Wald không được phép đọc chính báo cáo của mình
      </summary>
      <div class="expand-content">
        <p class="mb-3">Vì là người gốc Áo — về mặt kỹ thuật là "kiều dân nước thù" — Wald không được phép tiếp cận tài liệu mật. Câu chuyện đùa tại SRG: các thư ký phải giật mỗi trang khỏi tay ông ngay khi ông viết xong.</p>
        <p class="mb-3">Báo cáo của Wald bị phân loại mật suốt gần 4 thập kỷ. Mãi đến năm 1980, Trung tâm Thông tin Kỹ thuật Quốc phòng mới giải mật và công bố nó.</p>
        <p>Năm 1950, Wald và vợ thiệt mạng trong một vụ rơi máy bay tại Ấn Độ — một kết thúc bi thảm và trớ trêu cho người đã dành sự nghiệp nghiên cứu cách giữ máy bay trên bầu trời.</p>
      </div>
    </details>
  </section>

