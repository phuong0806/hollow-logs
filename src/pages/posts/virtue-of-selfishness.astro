---
import NeobrutalismLayout from '../../layouts/NeobrutalismLayout.astro';

export const metadata = {
  title: '"Đức Hạnh Của Sự Ích Kỷ": Khi Ayn Rand Tái Phát Minh Đạo Đức — Hay Chỉ Tái Định Nghĩa Từ Ngữ?',
  description: 'Rand tuyên bố giải quyết bài toán đạo đức lớn nhất triết học phương Tây. Thực tế, bà tái định nghĩa "ích kỷ" đến mức nó không còn nghĩa gốc — rồi tuyên bố thắng cuộc tranh luận mà bà tự viết lại luật chơi.',
  pubDate: new Date('2026-04-23'),
  tags: ['philosophy', 'economics'],
  theme: 'neobrutalism',
  draft: false,
};
---

<NeobrutalismLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  heroColor="pink"
>
  <!-- INLINE STYLES FOR INTERACTIVE ELEMENTS -->
  <style>
    /* Neo popover */
    .neo-popover {
      position: relative;
      display: inline;
    }
    .neo-popover-trigger {
      background: #ffde59;
      padding: 0 4px;
      font-weight: 700;
      color: black;
      border: none;
      border-bottom: 3px solid black;
      cursor: help;
      font: inherit;
    }
    .neo-popover-trigger:hover {
      background: #ff5a87;
      color: white;
    }
    .neo-popover-bubble {
      display: none;
      position: absolute;
      bottom: calc(100% + 10px);
      left: 50%;
      transform: translateX(-50%);
      width: 280px;
      padding: 14px 16px;
      background: black;
      color: #ffde59;
      border: 3px solid black;
      box-shadow: 5px 5px 0 #ff5a87;
      font-size: 0.82rem;
      line-height: 1.5;
      font-weight: 500;
      z-index: 50;
    }
    .neo-popover-bubble::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 8px solid transparent;
      border-top-color: black;
    }
    .neo-popover-bubble.show { display: block; }

    @media (max-width: 640px) {
      .neo-popover-bubble {
        width: 230px;
        left: 0;
        transform: none;
      }
      .neo-popover-bubble::after { left: 20px; transform: none; }
    }

    /* Neo expandable */
    .neo-expand {
      border: 3px solid black;
      box-shadow: 4px 4px 0 black;
      margin: 1.5rem 0;
      background: white;
    }
    .neo-expand summary {
      cursor: pointer;
      padding: 12px 16px;
      font-weight: 800;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      display: flex;
      align-items: center;
      gap: 8px;
      list-style: none;
      user-select: none;
      background: #ffde59;
      border-bottom: 3px solid black;
      transition: background 0.15s;
    }
    .neo-expand summary::-webkit-details-marker { display: none; }
    .neo-expand summary:hover { background: #ff5a87; color: white; }
    .neo-expand summary .neo-chevron {
      transition: transform 0.25s;
      flex-shrink: 0;
    }
    .neo-expand[open] summary .neo-chevron { transform: rotate(90deg); }
    .neo-expand[open] summary { border-bottom: 3px solid black; }
    .neo-expand .neo-expand-content {
      padding: 16px;
      font-size: 0.95rem;
      line-height: 1.65;
    }

    /* Neo diagram cards — override prose-neo styles inside */
    .neo-card-grid { margin: 2rem 0; }
    .neo-card-grid h4 {
      font-family: inherit !important;
      font-size: 1rem !important;
      margin: 0 0 6px !important;
      padding: 0 !important;
      background: none !important;
      border: none !important;
      box-shadow: none !important;
      transform: none !important;
      color: black !important;
      display: block !important;
    }
    .neo-card-grid h5 {
      font-family: inherit !important;
      font-size: 0.85rem !important;
      margin: 0 0 6px !important;
      padding: 0 !important;
      background: none !important;
      border: none !important;
      box-shadow: none !important;
      transform: none !important;
      display: block !important;
    }
    .neo-card-grid p {
      font-size: 0.85rem !important;
      margin-bottom: 0 !important;
      line-height: 1.5 !important;
    }
    .neo-card-grid ul {
      margin: 0 !important;
      padding-left: 1rem !important;
      list-style: disc !important;
    }
    .neo-card-grid li {
      font-size: 0.85rem !important;
      margin-bottom: 0.5rem !important;
      line-height: 1.5 !important;
    }
    .neo-card-grid li::before {
      content: none !important;
    }
    .neo-card-grid li::marker {
      content: "• " !important;
      color: black !important;
    }

    /* Neo refs */
    .neo-refs { margin: 2.5rem 0 0; }
    .neo-refs ol {
      margin: 0 !important;
      padding-left: 1.5rem !important;
      list-style: decimal !important;
    }
    .neo-refs li {
      font-size: 0.85rem !important;
      margin-bottom: 0.75rem !important;
      line-height: 1.5 !important;
