  <!-- POPOVER JS                                  -->
  <!-- ═══════════════════════════════════════════ -->
  <script>
    document.querySelectorAll('.zine-pop-trigger').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const bubble = btn.nextElementSibling;
        const wasOpen = bubble?.classList.contains('show');
        document.querySelectorAll('.zine-pop-bubble.show').forEach(b => b.classList.remove('show'));
        if (!wasOpen && bubble) bubble.classList.add('show');
      });
    });
    document.addEventListener('click', () => {
      document.querySelectorAll('.zine-pop-bubble.show').forEach(b => b.classList.remove('show'));
    });
  </script>

</ZineLayout>
