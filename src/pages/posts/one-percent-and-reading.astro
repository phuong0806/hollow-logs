        </div>
      </div>
      <div style="display: flex; align-items: center; gap: 10px;">
        <span style="width: 110px; font-size: 0.75rem; font-weight: 900; text-align: right; font-family: 'Courier Prime', monospace;">Không đổi</span>
        <div class="zine-bar-track" style="flex: 1;">
          <div class="zine-bar-fill" style="background: #ccc; width: 3%;"></div>
