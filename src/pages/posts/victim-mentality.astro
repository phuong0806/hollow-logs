---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Tư Duy Đổ Lỗi — Khi Bạn Tự Nhốt Mình Trong Vai Nạn Nhân',
  description: 'Tại sao chúng ta đổ lỗi cho hoàn cảnh, người khác, số phận? Từ thí nghiệm chó bất lực của Seligman đến Locus of Control của Rotter — giải phẫu tâm lý học đằng sau tư duy nạn nhân và con đường thoát ra.',
  pubDate: new Date('2026-04-25'),
  tags: ['psychology', 'philosophy'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="Tâm Lý Học Hành Vi"
  kickerColor="rose"
>
  <style>
    /* ─── Popovers ─────────────────────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(167, 139, 250);
      border-bottom: 1px dashed rgba(167, 139, 250, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(167, 139, 250); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 300px;
      padding: 12px 14px; background: #1a2744;
      border: 1px solid rgba(139, 92, 246, 0.3);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(139, 92, 246, 0.3);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 240px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Timeline ─────────────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(139, 92, 246, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(139, 92, 246, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(139, 92, 246); border-color: rgb(139, 92, 246);
      box-shadow: 0 0 8px rgba(139, 92, 246, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.gold::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
    }
    .timeline-item.success::before {
      background: rgb(52, 211, 153); border-color: rgb(52, 211, 153);
      box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(167, 139, 250); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.gold .timeline-year { color: rgb(251, 191, 36); }
    .timeline-item.success .timeline-year { color: rgb(52, 211, 153); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.gold .timeline-desc { color: rgb(254 243 199); font-weight: 600; }
    .timeline-item.success .timeline-desc { color: rgb(209 250 229); font-weight: 600; }

    /* ─── Stat cards ───────────────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(139, 92, 246, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(167, 139, 250);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(139, 92, 246, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(139, 92, 246, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(139, 92, 246, 0.08);
      border: 1px solid rgba(139, 92, 246, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-box-danger {
      background: rgba(239, 68, 68, 0.06);
      border: 1px solid rgba(239, 68, 68, 0.3);
      padding: 16px; text-align: center;
    }
    .flow-box-success {
      background: rgba(16, 185, 129, 0.06);
      border: 1px solid rgba(16, 185, 129, 0.3);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(167, 139, 250); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }
    .flow-arrow-down {
      color: rgb(252, 165, 165); font-size: 1.3rem;
      display: flex; align-items: center; justify-content: center;
      padding: 4px 0;
    }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(139, 92, 246);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(167, 139, 250); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Red flags ────────────────────────────── */
    .redflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.03); margin-bottom: 10px;
    }
    .redflag-icon { color: rgb(239 68 68); flex-shrink: 0; margin-top: 2px; }
    .redflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .redflag-text strong { color: white; }

    /* ─── Green flags ──────────────────────────── */
    .greenflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(16, 185, 129, 0.2);
      background: rgba(16, 185, 129, 0.03); margin-bottom: 10px;
    }
    .greenflag-icon { color: rgb(52 211 153); flex-shrink: 0; margin-top: 2px; }
    .greenflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .greenflag-text strong { color: white; }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(139, 92, 246, 0.12);
      color: rgb(167, 139, 250);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(139, 92, 246, 0.35);
    }
    .hl-gold {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }
    .hl-rose {
      background: rgba(244, 63, 94, 0.12);
      color: rgb(251, 113, 133);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(244, 63, 94, 0.3);
    }

    /* ─── Horizontal bar chart ─────────────────── */
    .bar-chart { display: flex; flex-direction: column; gap: 12px; }
    .bar-row { display: flex; align-items: center; gap: 12px; }
    .bar-label {
      width: 140px; flex-shrink: 0; font-size: 0.8rem;
      color: rgb(148 163 184); text-align: right;
    }
    .bar-track {
      flex: 1; height: 28px; background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.15); position: relative;
      overflow: hidden;
    }
    .bar-fill {
      height: 100%; display: flex; align-items: center;
      padding-left: 10px; font-size: 0.75rem; font-weight: 700;
    }
    .bar-fill.violet { background: rgba(139, 92, 246, 0.35); color: rgb(196, 181, 253); }
    .bar-fill.red { background: rgba(239, 68, 68, 0.3); color: rgb(252, 165, 165); }
    .bar-fill.green { background: rgba(16, 185, 129, 0.3); color: rgb(52, 211, 153); }
    .bar-fill.gold { background: rgba(251, 191, 36, 0.25); color: rgb(251, 191, 36); }

    /* ─── Cycle diagram ────────────────────────── */
    .cycle-step {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(239, 68, 68, 0.2);
      padding: 14px; text-align: center;
    }
    .cycle-step-num {
      font-size: 0.65rem; font-family: monospace; font-weight: 700;
      color: rgb(252, 165, 165); letter-spacing: 0.08em;
      text-transform: uppercase; margin-bottom: 4px;
    }
    .cycle-step-title {
      font-size: 0.95rem; font-weight: 800; color: white; margin-bottom: 4px;
    }
    .cycle-step-desc {
      font-size: 0.8rem; line-height: 1.5; color: rgb(148 163 184);
    }

    /* ─── Dimension cards ──────────────────────── */
    .dim-card {
      background: rgba(21, 31, 50, 0.4);
      border: 1px solid rgba(100, 116, 139, 0.2);
      padding: 18px;
    }
    .dim-card:hover {
      border-color: rgba(139, 92, 246, 0.4);
      background: rgba(21, 31, 50, 0.6);
    }
    .dim-icon { font-size: 2rem; margin-bottom: 8px; }
    .dim-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 6px; }
    .dim-body { font-size: 0.85rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Step cards (for solutions) ──────────── */
    .step-card {
      background: rgba(16, 185, 129, 0.04);
      border: 1px solid rgba(16, 185, 129, 0.2);
      padding: 18px;
    }
    .step-card:hover {
      border-color: rgba(16, 185, 129, 0.45);
      background: rgba(16, 185, 129, 0.08);
    }
    .step-num {
      font-size: 0.65rem; font-family: monospace; font-weight: 700;
      color: rgb(52, 211, 153); letter-spacing: 0.08em;
      text-transform: uppercase; margin-bottom: 6px;
    }
    .step-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 6px; }
    .step-body { font-size: 0.85rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Scenario cards ──────────────────────── */
    .scenario-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(251, 191, 36);
      padding: 16px; margin-bottom: 12px;
    }
    .scenario-label {
      font-size: 0.7rem; font-family: monospace; font-weight: 700;
      color: rgb(251, 191, 36); letter-spacing: 0.06em;
      text-transform: uppercase; margin-bottom: 4px;
    }
    .scenario-quote {
      font-size: 0.95rem; font-weight: 600; color: rgb(254, 243, 199);
      font-style: italic; margin-bottom: 6px;
    }
    .scenario-analysis {
      font-size: 0.85rem; line-height: 1.6; color: rgb(148 163 184);
    }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-violet-500 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-violet-300 leading-snug">
        "Giữa kích thích và phản ứng, có một khoảng trống. Trong khoảng trống đó là quyền chọn phản ứng của chúng ta. Trong phản ứng đó chứa sự trưởng thành và tự do."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Viktor Frankl, <em>Man's Search for Meaning</em> (1946)
      </footer>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- CONTEXT INTRO                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh</p>
        <p class="text-slate-300 text-sm leading-relaxed">Bạn có từng nghe — hoặc chính mình nói — những câu như "Tại sếp không công bằng", "Do gia đình tôi nghèo", "Xã hội này không cho tôi cơ hội"? Đó là dấu hiệu của <span class="popover-wrap"><button class="popover-trigger">tư duy nạn nhân</button><span class="popover-bubble">Victim Mentality — một kiểu tư duy mà người ta luôn cảm thấy mình là nạn nhân của hoàn cảnh, người khác, hoặc số phận, dẫn đến thụ động và né tránh trách nhiệm cá nhân.</span></span>.</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed">Đổ lỗi tạo cảm giác an toàn tức thì — nhưng đánh đổi bằng <span class="hl-red">quyền kiểm soát cuộc đời chính mình</span>. Càng đổ lỗi nhiều, bạn càng mất khả năng thay đổi. Tâm lý học gọi đó là <span class="popover-wrap"><button class="popover-trigger">learned helplessness</button><span class="popover-bubble">Learned Helplessness (Sự bất lực học được) — trạng thái tâm lý khi một cá nhân tin rằng mình không thể kiểm soát tình huống, dù thực tế có thể. Được Martin Seligman phát hiện qua thí nghiệm trên chó năm 1967.</span></span>.</p>
      </div>
      <div class="border border-violet-500/20 bg-violet-950/10 p-4">
        <p class="text-xs font-mono text-violet-400 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed">Thí nghiệm kinh điển của <span class="hl">Seligman</span>, lý thuyết <span class="hl">Locus of Control</span>, 4 chiều tâm lý của nạn nhân, <span class="hl-red">vòng xoáy đổ lỗi</span>, và <span class="hl-green">5 bước thoát ra</span> dựa trên bằng chứng khoa học.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- STATS OVERVIEW                                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="stat-card">
        <div class="stat-num">1967</div>
        <div class="stat-label">Seligman phát hiện Learned Helplessness</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">2/3</div>
        <div class="stat-label">Chó không thoát dù có thể</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">4</div>
        <div class="stat-label">Chiều tâm lý của nạn nhân (TIV)</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">1966</div>
        <div class="stat-label">Rotter công bố Locus of Control</div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 01: LEARNED HELPLESSNESS                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-violet-500 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Thí Nghiệm Chó Bất Lực — Nơi Tất Cả Bắt Đầu</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Năm 1967, một thí nghiệm tại Đại học Pennsylvania đã thay đổi cách chúng ta hiểu về sự bất lực — và mở ra cánh cửa giải mã tư duy nạn nhân.</p>

    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-8">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4"><span class="popover-wrap"><button class="popover-trigger">Martin Seligman</button><span class="popover-bubble">Martin Seligman (sinh 1942) — nhà tâm lý học người Mỹ, giáo sư tại Đại học Pennsylvania. Cha đẻ của tâm lý học tích cực (Positive Psychology). Nổi tiếng nhất với phát hiện về Learned Helplessness và cuốn sách Learned Optimism (1990).</span></span> và <span class="popover-wrap"><button class="popover-trigger">Steven Maier</button><span class="popover-bubble">Steven F. Maier — nhà thần kinh học, đồng tác giả nghiên cứu Learned Helplessness năm 1967 cùng Seligman. Sau này Maier đã đảo ngược lý thuyết gốc: thụ động không phải được "học" — nó là phản ứng mặc định của não bộ.</span></span> chia 24 con chó thành 3 nhóm. Nhóm 1 có thể tắt sốc điện bằng cách đẩy tấm panel. Nhóm 2 nhận cùng cường độ sốc nhưng không thể kiểm soát. Nhóm 3 không bị sốc.</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Kết quả: khi đặt tất cả vào tình huống mới — nơi <strong class="text-white">mọi con chó đều có thể thoát</strong> chỉ bằng cách nhảy qua rào — <span class="hl-red">2/3 chó nhóm 2 nằm yên chịu đựng</span>, không cố gắng thoát. Chúng đã "học" rằng mình bất lực, dù thực tế đã thay đổi.</p>
    </div>

    <!-- Visual: 3 groups -->
    <div class="grid md:grid-cols-3 gap-3 mb-8">
      <div class="flow-box-success">
        <p class="text-xs font-mono text-emerald-400 font-bold uppercase mb-2">Nhóm 1 — Kiểm Soát</p>
        <p class="text-white font-bold text-lg mb-1">90% thoát được</p>
        <p class="text-sm text-slate-400">Có thể tắt sốc → Học được rằng hành động tạo ra kết quả</p>
      </div>
      <div class="flow-box-danger">
        <p class="text-xs font-mono text-red-400 font-bold uppercase mb-2">Nhóm 2 — Bất Lực</p>
        <p class="text-white font-bold text-lg mb-1">67% bỏ cuộc</p>
        <p class="text-sm text-slate-400">Không kiểm soát được sốc → "Học" rằng cố gắng là vô nghĩa</p>
      </div>
      <div class="flow-box">
        <p class="text-xs font-mono text-slate-400 font-bold uppercase mb-2">Nhóm 3 — Đối Chứng</p>
        <p class="text-white font-bold text-lg mb-1">90% thoát được</p>
        <p class="text-sm text-slate-400">Không bị sốc trước đó → Phản ứng tự nhiên, nhanh chóng thoát</p>
      </div>
    </div>

    <div class="border border-violet-500/20 bg-violet-950/10 p-5 mb-6">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed"><strong class="text-white">Bài học cốt lõi:</strong> Không phải nỗi đau khiến chúng ta bất lực — mà là <span class="hl-red">trải nghiệm mất kiểm soát</span>. Khi não bộ tin rằng "dù làm gì cũng không thay đổi được", nó ngừng cố gắng — ngay cả khi cánh cửa đã mở sẵn.</p>
    </div>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Bản cập nhật 2016: Thụ động là mặc định, không phải "học"
      </summary>
      <div class="expand-content">
        <p class="mb-3">50 năm sau, Maier và Seligman công bố một bản cập nhật quan trọng trên <em>Psychological Review</em> (2016). Nghiên cứu thần kinh cho thấy <strong class="text-white">thụ động và bất lực là phản ứng mặc định</strong> của não bộ trước stress — không cần "học".</p>
        <p class="mb-3">Khi gặp kích thích tiêu cực, <span class="popover-wrap"><button class="popover-trigger">nhân raphe lưng</button><span class="popover-bubble">Dorsal Raphe Nucleus (DRN) — vùng thân não chứa neuron serotonin. Khi kích hoạt kéo dài bởi stress, DRN tạo ra trạng thái thụ động, lo âu, và bất lực. Chỉ ~33% neuron trong DRN chứa serotonin.</span></span> (DRN) giải phóng serotonin, tạo ra trạng thái thụ động. Chỉ khi <span class="popover-wrap"><button class="popover-trigger">vỏ não trước trán</button><span class="popover-bubble">Ventromedial Prefrontal Cortex (vmPFC) — vùng não phát hiện sự kiểm soát và ức chế phản ứng stress từ DRN. Khi bạn nhận ra mình CÓ THỂ kiểm soát tình huống, vmPFC kích hoạt và "tắt" tín hiệu bất lực.</span></span> (vmPFC) phát hiện rằng bạn CÓ kiểm soát, nó mới ức chế DRN — nghĩa là <span class="hl-green">bạn phải chủ động "học" sự kiểm soát</span>, chứ không phải thụ động "học" sự bất lực.</p>
        <p>Nói cách khác: <strong class="text-white">bất lực là trạng thái tự nhiên khi bạn không hành động. Tự chủ là kỹ năng phải rèn luyện.</strong></p>
      </div>
    </details>
  </section>

