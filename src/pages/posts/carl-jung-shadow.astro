---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Cái Bóng — Carl Jung và Nửa Khuất của Tâm Hồn',
  description: 'Ai cũng mang trong mình một cái bóng. Càng né tránh nó, bóng càng đen đặc. Jung gọi đó là Shadow — phần bị chối bỏ của nhân cách, nhưng cũng là 90% vàng ròng chưa được khai phá.',
  pubDate: new Date('2026-04-23'),
  tags: ['psychology', 'philosophy'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="Tâm Lý Học Chiều Sâu"
  kickerColor="rose"
>
  <style>
    /* ─── Popovers ─────────────────────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(167, 139, 250);
      border-bottom: 1px dashed rgba(167, 139, 250, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(167, 139, 250); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 300px;
      padding: 12px 14px; background: #1a2744;
      border: 1px solid rgba(139, 92, 246, 0.3);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(139, 92, 246, 0.3);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 240px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Timeline ─────────────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(139, 92, 246, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(139, 92, 246, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(139, 92, 246); border-color: rgb(139, 92, 246);
      box-shadow: 0 0 8px rgba(139, 92, 246, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.gold::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
    }
    .timeline-item.success::before {
      background: rgb(52, 211, 153); border-color: rgb(52, 211, 153);
      box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(167, 139, 250); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.gold .timeline-year { color: rgb(251, 191, 36); }
    .timeline-item.success .timeline-year { color: rgb(52, 211, 153); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.gold .timeline-desc { color: rgb(254 243 199); font-weight: 600; }
    .timeline-item.success .timeline-desc { color: rgb(209 250 229); font-weight: 600; }

    /* ─── Stat cards ───────────────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(139, 92, 246, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(167, 139, 250);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(139, 92, 246, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }
    .compare-table .violet { color: rgb(167, 139, 250); }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(139, 92, 246, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(139, 92, 246, 0.08);
      border: 1px solid rgba(139, 92, 246, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(167, 139, 250); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(139, 92, 246);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(167, 139, 250); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Red flags ────────────────────────────── */
    .redflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.03); margin-bottom: 10px;
    }
    .redflag-icon { color: rgb(239 68 68); flex-shrink: 0; margin-top: 2px; }
    .redflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .redflag-text strong { color: white; }

    /* ─── Green flags ──────────────────────────── */
    .greenflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(16, 185, 129, 0.2);
      background: rgba(16, 185, 129, 0.03); margin-bottom: 10px;
    }
    .greenflag-icon { color: rgb(52 211 153); flex-shrink: 0; margin-top: 2px; }
    .greenflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .greenflag-text strong { color: white; }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(139, 92, 246, 0.12);
      color: rgb(167, 139, 250);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(139, 92, 246, 0.35);
    }
    .hl-gold {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }
    .hl-rose {
      background: rgba(244, 63, 94, 0.12);
      color: rgb(251, 113, 133);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(244, 63, 94, 0.3);
    }

    /* ─── Alchemy stage cards ──────────────────── */
    .alchemy-card {
      padding: 16px; text-align: center;
      background: rgba(21, 31, 50, 0.5);
    }
    .alchemy-label {
      font-size: 0.7rem; font-family: monospace;
      font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; margin-bottom: 6px;
    }
    .alchemy-title {
      font-size: 1.1rem; font-weight: 800; color: white; margin-bottom: 4px;
    }
    .alchemy-desc {
      font-size: 0.8rem; line-height: 1.5; color: rgb(148 163 184);
    }

    /* ─── Culture cards ────────────────────────── */
    .culture-card {
      background: rgba(21, 31, 50, 0.4);
      border: 1px solid rgba(100, 116, 139, 0.2);
      padding: 18px;
    }
    .culture-card:hover {
      border-color: rgba(139, 92, 246, 0.4);
      background: rgba(21, 31, 50, 0.6);
    }
    .culture-emoji { font-size: 2rem; margin-bottom: 8px; }
    .culture-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 6px; }
    .culture-body { font-size: 0.85rem; line-height: 1.6; color: rgb(148 163 184); }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-violet-500 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-violet-300 leading-snug">
        "Ai cũng mang trong mình một cái bóng, và càng ít thể hiện nó trong đời sống ý thức, nó càng đen tối và dày đặc hơn."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Carl Gustav Jung, <em>Psychology and Religion</em>, CW 11, para. 131 (1938)
      </footer>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- CONTEXT INTRO                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh</p>
        <p class="text-slate-300 text-sm leading-relaxed">Carl Jung — cha đẻ của <span class="popover-wrap"><button class="popover-trigger">tâm lý học phân tích</button><span class="popover-bubble">Analytical Psychology — trường phái tâm lý do Jung sáng lập, tách biệt khỏi phân tâm học của Freud. Tập trung vào vô thức tập thể, nguyên mẫu, và quá trình cá thể hóa thay vì chỉ phân tích tính dục.</span></span> — đã xây dựng một trong những khái niệm mạnh mẽ nhất về bản chất con người: <strong class="text-white">Shadow</strong>, phần nhân cách bị chối bỏ.</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed">Mỗi chúng ta xây một mặt nạ để được xã hội chấp nhận. Phần bị cắt bỏ không biến mất — nó chìm vào <span class="hl">vô thức</span>, lớn dần, và chi phối hành vi từ bên trong mà ta không hề hay biết.</p>
      </div>
      <div class="border border-violet-500/20 bg-violet-950/10 p-4">
        <p class="text-xs font-mono text-violet-400 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed">Shadow là gì, <span class="hl">cơ chế hình thành</span> ra sao, tại sao ta <span class="hl-rose">phóng chiếu bóng tối</span> lên người khác, <span class="hl-gold">90% vàng ròng</span> bị chôn vùi, và <span class="hl-green">con đường tích hợp</span> để trở nên trọn vẹn.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- STATS OVERVIEW                                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="stat-card">
        <div class="stat-num">20 tập</div>
        <div class="stat-label">Collected Works của Jung</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">1913</div>
        <div class="stat-label">Năm "Đối đầu Vô thức" bắt đầu</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">90%</div>
        <div class="stat-label">"Vàng ròng" trong Shadow</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">6+ năm</div>
        <div class="stat-label">Hiệu quả trị liệu Jung ổn định</div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 01: CARL JUNG                                     -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-violet-500 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Carl Jung — Người Dám Đi Vào Bóng Tối</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Trước khi hiểu Shadow, cần hiểu người đã dám nhìn thẳng vào nó — và suýt mất trí trong quá trình đó.</p>

    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-8">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Carl Gustav Jung (1875–1961) là bác sĩ tâm thần người Thụy Sĩ, từng là học trò thân cận nhất của <span class="popover-wrap"><button class="popover-trigger">Sigmund Freud</button><span class="popover-bubble">Sigmund Freud (1856–1939) — cha đẻ phân tâm học, người đầu tiên hệ thống hóa khái niệm vô thức. Freud nhấn mạnh tính dục là động lực chính của tâm lý. Jung ban đầu coi Freud như cha tinh thần, nhưng sau bất đồng sâu sắc về bản chất vô thức.</span></span>. Sự chia tay với Freud năm 1913 đẩy Jung vào cuộc khủng hoảng tâm lý sâu nhất đời ông.</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Thay vì chạy trốn, Jung chủ động đi vào vô thức của chính mình — ghi chép lại mọi thứ trong cuốn <span class="popover-wrap"><button class="popover-trigger">Liber Novus</button><span class="popover-bubble">Liber Novus (Sách Đỏ) — tác phẩm bí mật của Jung ghi lại cuộc đối đầu với vô thức (1914–1930), với tranh minh họa và thư pháp công phu. Được gia đình giữ kín đến năm 2009 mới xuất bản lần đầu. Đây là nền tảng trải nghiệm từ đó Shadow và các khái niệm khác ra đời.</span></span> (Sách Đỏ). Từ cuộc hành trình suýt-điên đó, ông xây dựng nên toàn bộ hệ thống tâm lý phân tích.</p>
    </div>

    <!-- Timeline -->
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-year">1875</div>
        <div class="timeline-desc">Sinh ra tại Kesswil, Thụy Sĩ. Tuổi thơ cô đơn, trí tưởng tượng phong phú. Cha là mục sư Tin Lành đang mất dần niềm tin.</div>
      </div>
      <div class="timeline-item">
        <div class="timeline-year">1900</div>
        <div class="timeline-desc">Vào làm tại bệnh viện tâm thần Burghölzli, Zurich. Tiến hành thí nghiệm liên tưởng từ — phát hiện bệnh nhân kìm nén những suy nghĩ mang tải cảm xúc mạnh.</div>
      </div>
      <div class="timeline-item highlight">
        <div class="timeline-year">1907</div>
        <div class="timeline-desc">Gặp Freud lần đầu — hai người nói chuyện liên tục 13 giờ. Bắt đầu giai đoạn hợp tác mật thiết. Freud coi Jung là "thái tử" kế vị.</div>
      </div>
      <div class="timeline-item danger">
        <div class="timeline-year">1912–1913</div>
        <div class="timeline-desc">Xuất bản Psychology of the Unconscious — bất đồng sâu sắc với Freud về bản chất vô thức. Mối quan hệ đổ vỡ hoàn toàn. Jung từ chức khỏi Hiệp hội Phân tâm Quốc tế.</div>
      </div>
      <div class="timeline-item danger">
        <div class="timeline-year">1913–1917</div>
        <div class="timeline-desc">"Đối đầu với Vô thức" — giai đoạn khủng hoảng tâm lý gần như loạn thần. Jung chủ động gợi ra ảo tượng trong trạng thái tỉnh, đối thoại với các hình ảnh tự phát từ vô thức.</div>
      </div>
      <div class="timeline-item gold">
        <div class="timeline-year">1914–1930</div>
        <div class="timeline-desc">Viết và minh họa Sách Đỏ (Liber Novus). Gặp Philemon — nhân vật nội tâm dạy Jung rằng "suy nghĩ không phải thứ bạn tạo ra, mà là thứ xảy đến với bạn."</div>
      </div>
      <div class="timeline-item success">
        <div class="timeline-year">1921</div>
        <div class="timeline-desc">Xuất bản Psychological Types — tác phẩm đầu tiên hệ thống hóa lý thuyết sau khủng hoảng. Nền tảng cho MBTI và khái niệm hướng nội/hướng ngoại.</div>
      </div>
      <div class="timeline-item highlight">
        <div class="timeline-year">1951</div>
        <div class="timeline-desc">Xuất bản Aion (CW 9ii) — chứa phân tích chính thức và tập trung nhất về Shadow. Chương II "The Shadow" định nghĩa khái niệm này một cách hệ thống.</div>
      </div>
    </div>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Bên trong Sách Đỏ — Jung gặp gì trong vô thức?
      </summary>
      <div class="expand-content">
        <p class="mb-3">Ngày 21 tháng 12 năm 1913, Jung ghi lại thị kiến đầu tiên: ông rơi vào một hố sâu nguyên thủy, gặp <strong class="text-white">Elijah</strong> — một tiên tri già mặc áo choàng — cùng <strong class="text-white">Salome</strong>, một thiếu nữ mù. Giữa họ là <strong class="text-white">một con rắn đen</strong>.</p>
        <p class="mb-3">Sau đó xuất hiện <strong class="text-white">Philemon</strong> — ông lão có cánh chim bói cá và sừng bò. Philemon dạy Jung bài học quan trọng nhất: tâm trí có đời sống riêng của nó, không phụ thuộc vào ý chí của ego.</p>
        <p>Con rắn trong thị kiến tượng trưng cho <em>"mọi thứ nguy hiểm và xấu xa, mọi thứ thuộc về đêm tối và kỳ bí"</em> — chính là hình ảnh sống động nhất của Shadow mà Jung từng chứng kiến. Từ những cuộc đối thoại này, toàn bộ hệ thống lý thuyết về Shadow, <span class="popover-wrap"><button class="popover-trigger">Archetype</button><span class="popover-bubble">Archetype (Nguyên Mẫu) — mô hình tâm lý phổ quát trong vô thức tập thể. Những hình ảnh và chủ đề bẩm sinh mà mọi nền văn hóa đều có, như Người Anh Hùng, Người Mẹ, Kẻ Lừa Đảo, Cái Bóng. Jung tin rằng chúng được thừa kế qua cấu trúc não bộ.</span></span>, và Cá thể hóa dần hình thành.</p>
      </div>
    </details>
  </section>

