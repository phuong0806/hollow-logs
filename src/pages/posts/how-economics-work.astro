---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Cỗ Máy Kinh Tế',
  description: 'Nền kinh tế vận hành bởi 3 lực: giao dịch, tín dụng, và chu kỳ nợ. Hiểu 3 thứ này, bạn đọc được 80% tin kinh tế mà không cần bằng MBA.',
  pubDate: new Date('2026-04-23'),
  tags: ['economics', 'finance'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="Kinh Tế Học Cơ Bản"
  kickerColor="cyan"
>
  <style>
    /* ─── Popovers ─────────────────────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(34 211 238);
      border-bottom: 1px dashed rgba(34, 211, 238, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(34 211 238); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 290px;
      padding: 12px 14px; background: #1a2744;
      border: 1px solid rgba(34, 211, 238, 0.25);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(34, 211, 238, 0.25);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 230px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Bar chart ────────────────────────────── */
    .bar-track {
      height: 28px; background: rgba(30, 41, 59, 0.8);
      position: relative; overflow: hidden;
    }
    .bar-fill { height: 100%; }
    .bar-label {
      position: absolute; right: 10px; top: 50%;
      transform: translateY(-50%);
      font-size: 0.75rem; font-weight: 700;
      color: white; text-shadow: 0 1px 2px rgba(0,0,0,0.6);
    }

    /* ─── Timeline ─────────────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(34, 211, 238, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(34, 211, 238, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(34, 211, 238); border-color: rgb(34, 211, 238);
      box-shadow: 0 0 8px rgba(34, 211, 238, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.gold::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(34, 211, 238); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.gold .timeline-year { color: rgb(251, 191, 36); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.gold .timeline-desc { color: rgb(254 243 199); font-weight: 600; }

    /* ─── Stats grid ───────────────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(34, 211, 238);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(34, 211, 238, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }

    /* ─── Red flags ────────────────────────────── */
    .redflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.03); margin-bottom: 10px;
    }
    .redflag-icon { color: rgb(239 68 68); flex-shrink: 0; margin-top: 2px; }
    .redflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .redflag-text strong { color: white; }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(34, 211, 238, 0.12);
      color: rgb(34, 211, 238);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(34, 211, 238, 0.35);
    }
    .hl-gold {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(34, 211, 238, 0.08);
      border: 1px solid rgba(34, 211, 238, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(34, 211, 238); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Cycle diagram ────────────────────────── */
    .cycle-phase {
      border: 1px solid rgba(100, 116, 139, 0.3);
      padding: 16px 20px;
    }
    .cycle-num {
      font-size: 0.7rem; font-weight: 700; font-family: monospace;
      letter-spacing: 0.06em; margin-bottom: 6px;
    }
    .cycle-title {
      font-size: 1rem; font-weight: 700; color: white; margin-bottom: 6px;
    }
    .cycle-desc {
      font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184);
    }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(34, 211, 238);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(34, 211, 238); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-cyan-500 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-cyan-400 leading-snug">
        "Nền kinh tế vận hành như một cỗ máy đơn giản. Nhưng nhiều người không hiểu nó — hoặc không đồng ý với nhau về cách nó vận hành — và điều đó dẫn đến rất nhiều đau khổ không cần thiết."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Ray Dalio, <em>How The Economic Machine Works</em>, 2008
      </footer>
    </div>
  </section>

  <!-- CONTEXT INTRO -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh 2026</p>
        <p class="text-slate-300 text-sm leading-relaxed">Fed giữ <span class="popover-wrap"><button class="popover-trigger">lãi suất</button><span class="popover-bubble">Interest rate — chi phí đi vay tiền. Khi ngân hàng trung ương tăng lãi suất, vay tiền đắt hơn, người dân và doanh nghiệp chi tiêu ít đi, nền kinh tế chậm lại. Ngược lại khi giảm lãi suất.</span></span> trên 4% suốt hơn một năm. Chiến tranh thuế quan Mỹ-Trung tái leo thang. Nợ công Mỹ vượt $36 nghìn tỷ. Thị trường chứng khoán dao động mạnh mỗi tuần.</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed">Tin kinh tế tràn ngập thuật ngữ: <span class="popover-wrap"><button class="popover-trigger">GDP</button><span class="popover-bubble">Gross Domestic Product — tổng giá trị hàng hóa và dịch vụ một quốc gia sản xuất trong một năm. GDP tăng = nền kinh tế mở rộng. GDP giảm 2 quý liên tiếp = suy thoái kỹ thuật.</span></span>, lạm phát, QE, suy thoái. Nhưng ít ai giải thích <em>cơ chế</em> — tại sao mọi thứ kết nối với nhau, và tại sao kinh tế luôn đi lên rồi lại đi xuống.</p>
      </div>
      <div class="border border-cyan-500/20 bg-cyan-950/10 p-4">
        <p class="text-xs font-mono text-cyan-500 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed">3 lực cốt lõi vận hành nền kinh tế: <span class="hl">giao dịch</span>, <span class="hl-gold">tín dụng</span>, và <span class="hl-red">chu kỳ nợ</span>. Hiểu 3 thứ này, bạn đọc được phần lớn tin kinh tế.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- H2-1: GIAO DỊCH                                        -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-cyan-400 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Giao Dịch — Viên Gạch Nhỏ Nhất</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Mọi phức tạp kinh tế — GDP, lạm phát, khủng hoảng — đều sinh ra từ hàng tỷ giao dịch cộng lại. Hiểu một giao dịch là hiểu toàn bộ nền kinh tế ở dạng thu nhỏ.</p>

    <!-- Core concept -->
    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-8">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Một <span class="popover-wrap"><button class="popover-trigger">giao dịch</button><span class="popover-bubble">Transaction — mỗi khi bạn dùng tiền hoặc tín dụng để đổi lấy hàng hóa, dịch vụ, hoặc tài sản tài chính, đó là một giao dịch. Mua cà phê 40.000đ là giao dịch. Mua trái phiếu $10 triệu cũng là giao dịch. Cùng cơ chế, khác quy mô.</span></span> xảy ra khi một người mua đổi <strong class="text-white">tiền</strong> hoặc <strong class="text-white">tín dụng</strong> để lấy hàng hóa, dịch vụ, hoặc tài sản tài chính từ một người bán.</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Công thức nền tảng:</p>
    </div>

    <!-- The formula -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-3 items-center mb-8">
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-cyan-400 uppercase tracking-wider mb-1">Tiền mặt</p>
        <p class="text-xl font-bold text-white">Cash</p>
      </div>
      <div class="flow-arrow hidden md:flex">+</div>
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-cyan-400 uppercase tracking-wider mb-1">Tín dụng</p>
        <p class="text-xl font-bold text-white">Credit</p>
      </div>
      <div class="flow-arrow hidden md:flex">=</div>
      <div class="flow-box" style="border-color: rgba(251, 191, 36, 0.4); background: rgba(251, 191, 36, 0.06);">
        <p class="text-xs font-mono text-amber-400 uppercase tracking-wider mb-1">Tổng chi tiêu</p>
        <p class="text-xl font-bold text-white">Total Spending</p>
      </div>
    </div>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Tổng chi tiêu trong nền kinh tế chính là tổng <span class="hl">tiền mặt</span> cộng <span class="hl-gold">tín dụng</span> mà mọi người dùng để mua sắm. Con số này quyết định mọi thứ — giá cả, lợi nhuận doanh nghiệp, việc làm.</p>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-6">Khi bạn mua một ly cà phê 50.000đ, số tiền đó trở thành <span class="hl">thu nhập</span> của quán cà phê. Quán dùng thu nhập đó trả lương nhân viên, mua nguyên liệu — tức chi tiêu cho người khác. Thu nhập của người này là chi tiêu của người kia. Chuỗi này lặp lại hàng tỷ lần mỗi ngày.</p>

    <!-- Key insight card -->
    <div class="lesson-card">
      <div class="lesson-num">NGUYÊN TẮC CỐT LÕI</div>
      <div class="lesson-title">Chi tiêu của người này = Thu nhập của người kia</div>
      <div class="lesson-body">Khi tổng chi tiêu tăng → thu nhập tăng → mọi người chi tiêu nhiều hơn → thu nhập lại tăng. Vòng lặp này là động cơ chính của tăng trưởng kinh tế. Nhưng nó cũng hoạt động ngược lại khi chi tiêu giảm.</div>
    </div>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Ví dụ: Tại sao một bát phở ảnh hưởng đến GDP?
      </summary>
      <div class="expand-content">
        <p class="mb-3">Bạn trả 80.000đ cho một bát phở. Chủ quán dùng một phần tiền mua thịt bò từ lò mổ. Lò mổ trả tiền cho nông dân nuôi bò. Nông dân mua thức ăn chăn nuôi từ nhà máy. Nhà máy trả lương cho công nhân. Công nhân đi ăn phở.</p>
        <p class="mb-3">Mỗi giao dịch trong chuỗi này được tính vào <strong class="text-white">GDP</strong>. 80.000đ ban đầu không dừng lại — nó tạo ra chuỗi giao dịch có tổng giá trị lớn hơn nhiều. Hiệu ứng này gọi là <strong class="text-white">multiplier effect</strong> (hiệu ứng nhân).</p>
        <p>Khi hàng triệu người cùng giảm chi tiêu (vì sợ hãi, vì mất việc, vì lãi suất cao), chuỗi giao dịch co lại ở mọi tầng. Đó là lý do <span class="popover-wrap"><button class="popover-trigger">suy thoái</button><span class="popover-bubble">Recession — giai đoạn GDP giảm liên tiếp ít nhất 2 quý. Thất nghiệp tăng, doanh nghiệp đóng cửa, thu nhập giảm. Suy thoái là phần tự nhiên của chu kỳ kinh tế, không phải sự cố bất thường.</span></span> có thể bắt đầu chỉ từ việc người tiêu dùng thận trọng hơn.</p>
      </div>
    </details>

    <!-- Price mechanism -->
    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4 mt-6">Giá cả hình thành từ tỷ lệ giữa tổng chi tiêu và tổng sản lượng trong mỗi <span class="popover-wrap"><button class="popover-trigger">thị trường</button><span class="popover-bubble">Market — nơi người mua và người bán giao dịch một loại hàng hóa cụ thể. Thị trường bất động sản, thị trường lao động, thị trường dầu mỏ — mỗi thứ có cung-cầu riêng và giá riêng.</span></span>:</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 items-center mb-8">
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-cyan-400 uppercase tracking-wider mb-1">Tổng chi tiêu</p>
        <p class="text-lg font-bold text-white">Total Spending</p>
      </div>
      <div class="flow-arrow hidden md:flex">÷</div>
      <div class="flow-box">
        <p class="text-xs font-mono text-slate-400 uppercase tracking-wider mb-1">Tổng sản lượng</p>
        <p class="text-lg font-bold text-white">Total Quantity</p>
      </div>
    </div>

    <div class="lesson-card" style="border-left-color: rgb(251, 191, 36);">
      <div class="lesson-num" style="color: rgb(251, 191, 36);">= GIÁ CẢ</div>
      <div class="lesson-title">Nhiều tiền đuổi theo ít hàng → giá tăng (lạm phát)</div>
      <div class="lesson-body">Ít tiền đuổi theo nhiều hàng → giá giảm (giảm phát). Đây là cơ chế nền tảng của <span class="popover-wrap"><button class="popover-trigger">lạm phát</button><span class="popover-bubble">Inflation — mức tăng chung của giá cả hàng hóa và dịch vụ theo thời gian. Lạm phát 2-3%/năm được coi là lành mạnh. Lạm phát vượt 5-6% bắt đầu gây đau — tiền lương không theo kịp giá cả, tiết kiệm mất giá trị thực.</span></span> — không phải do "doanh nghiệp tham lam" hay "chính phủ in tiền" đơn thuần, mà do tổng chi tiêu tăng nhanh hơn tổng sản lượng.</div>
    </div>

    <!-- Stat cards: Economy size -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8 mt-8">
      <div class="stat-card">
        <div class="stat-num">$105T</div>
        <div class="stat-label">GDP toàn cầu 2025</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">$7.5T</div>
        <div class="stat-label">Giao dịch forex/ngày</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">~1 tỷ</div>
        <div class="stat-label">Giao dịch thẻ/ngày toàn cầu</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">3:1</div>
        <div class="stat-label">Tỷ lệ tín dụng/tiền mặt (Mỹ)</div>
      </div>
    </div>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed">Con số cuối cùng là mấu chốt: trong nền kinh tế Mỹ, cứ <span class="hl">$1 tiền mặt</span> thì có khoảng <span class="hl-gold">$3 tín dụng</span> được tạo ra. Tín dụng chiếm phần lớn tổng chi tiêu. Đây là lý do tín dụng — không phải tiền mặt — mới là lực chính điều khiển nền kinh tế.</p>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- H2-2: TÍN DỤNG                                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-amber-400 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 02</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Tín Dụng — Nhiên Liệu Hay Bom Nổ Chậm?</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Tín dụng là phát minh tài chính mạnh nhất trong lịch sử. Nó cho phép chi tiêu hôm nay bằng thu nhập của ngày mai. Vấn đề: ngày mai luôn đến.</p>

    <!-- How credit works -->
    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-6">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4"><span class="popover-wrap"><button class="popover-trigger">Tín dụng</button><span class="popover-bubble">Credit — lời hứa trả tiền trong tương lai. Khi ngân hàng cho bạn vay 500 triệu, họ tạo ra 500 triệu tín dụng mới — tiền này chưa tồn tại trước đó. Bạn chi tiêu nó như tiền thật, nhưng bạn mang theo một nghĩa vụ: phải trả lại cộng lãi suất.</span></span> được tạo ra mỗi khi người cho vay và người đi vay đồng ý thực hiện một giao dịch. Người đi vay hứa sẽ trả lại gốc cộng <span class="popover-wrap"><button class="popover-trigger">lãi suất</button><span class="popover-bubble">Interest rate — phần trăm tiền bạn phải trả thêm khi vay. Nếu vay 100 triệu với lãi 8%/năm, bạn trả 108 triệu sau 1 năm. Lãi suất là "giá" của tín dụng — giống giá cà phê là giá của cà phê.</span></span>. Ngay lập tức, tín dụng mới được tạo ra — từ hư không.</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Đây không phải phép ẩn dụ. Khi ngân hàng cho vay, họ ghi thêm số dư vào tài khoản người vay mà <em>không cần rút tiền từ ai khác</em>. Tiền mới xuất hiện trên sổ sách. Đó gọi là <span class="popover-wrap"><button class="popover-trigger">fractional reserve banking</button><span class="popover-bubble">Ngân hàng dự trữ một phần — hệ thống cho phép ngân hàng chỉ giữ lại một tỷ lệ nhỏ (thường 3-10%) tiền gửi làm dự trữ, phần còn lại được cho vay. Cứ 100 triệu gửi vào, ngân hàng có thể cho vay 90 triệu. 90 triệu đó được gửi vào ngân hàng khác, ngân hàng khác lại cho vay 81 triệu. Tiền "nhân lên".</span></span>.</p>
    </div>

    <!-- The credit cycle: visual flow -->
    <p class="text-sm font-mono text-slate-500 font-bold uppercase tracking-wider mb-4">Vòng xoáy tín dụng — chiều đi lên</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <div class="cycle-phase" style="border-color: rgba(34, 211, 238, 0.3);">
        <div class="cycle-num text-cyan-400">BƯỚC 1</div>
        <div class="cycle-title">Tín dụng dễ dàng</div>
        <div class="cycle-desc">Lãi suất thấp. Ngân hàng sẵn sàng cho vay. Người dân và doanh nghiệp vay nhiều hơn.</div>
      </div>
      <div class="cycle-phase" style="border-color: rgba(34, 211, 238, 0.3);">
        <div class="cycle-num text-cyan-400">BƯỚC 2</div>
        <div class="cycle-title">Chi tiêu tăng</div>
        <div class="cycle-desc">Tiền vay được chi tiêu ngay → trở thành thu nhập của người khác. Tổng chi tiêu nền kinh tế tăng.</div>
      </div>
      <div class="cycle-phase" style="border-color: rgba(74, 222, 128, 0.3);">
        <div class="cycle-num text-emerald-400">BƯỚC 3</div>
        <div class="cycle-title">Thu nhập & tài sản tăng</div>
        <div class="cycle-desc">Thu nhập tăng → giá bất động sản, cổ phiếu tăng → <span class="popover-wrap"><button class="popover-trigger">tài sản thế chấp</button><span class="popover-bubble">Collateral — tài sản bạn dùng để đảm bảo cho khoản vay. Thường là nhà đất hoặc xe hơi. Nếu không trả được nợ, ngân hàng thu hồi tài sản thế chấp. Khi giá nhà tăng, giá trị thế chấp tăng theo.</span></span> tăng giá trị.</div>
      </div>
      <div class="cycle-phase" style="border-color: rgba(74, 222, 128, 0.3);">
        <div class="cycle-num text-emerald-400">BƯỚC 4</div>
        <div class="cycle-title">Vay thêm được nhiều hơn</div>
        <div class="cycle-desc">Tài sản tăng = thế chấp lớn hơn = ngân hàng cho vay thêm. Quay lại Bước 1 với quy mô lớn hơn. Vòng xoáy đi lên.</div>
      </div>
    </div>

    <blockquote class="border-l-4 border-cyan-500/40 pl-5 py-1 my-6">
      <p class="text-lg md:text-xl italic text-slate-300 leading-relaxed">
        "Tín dụng tốt khi nó phân bổ nguồn lực hiệu quả để tạo ra thu nhập trả được nợ. Tín dụng xấu khi nó tài trợ cho tiêu dùng quá mức mà không tạo ra thu nhập tương ứng."
      </p>
      <footer class="mt-2 text-slate-500 text-sm font-mono">— Ray Dalio, <em>Principles for Navigating Big Debt Crises</em></footer>
    </blockquote>

    <!-- The reverse -->
    <p class="text-sm font-mono text-slate-500 font-bold uppercase tracking-wider mb-4 mt-8">Vòng xoáy tín dụng — chiều đi xuống</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <div class="cycle-phase" style="border-color: rgba(239, 68, 68, 0.3);">
        <div class="cycle-num text-red-400">BƯỚC 1</div>
        <div class="cycle-title">Lãi suất tăng hoặc nợ quá lớn</div>
        <div class="cycle-desc">Ngân hàng trung ương tăng lãi suất, hoặc người vay đã nợ quá nhiều so với thu nhập. Chi phí vay tăng.</div>
      </div>
      <div class="cycle-phase" style="border-color: rgba(239, 68, 68, 0.3);">
        <div class="cycle-num text-red-400">BƯỚC 2</div>
        <div class="cycle-title">Chi tiêu giảm</div>
        <div class="cycle-desc">Người dân vừa trả nợ cũ vừa vay ít hơn → tổng chi tiêu giảm → thu nhập của người khác giảm theo.</div>
      </div>
      <div class="cycle-phase" style="border-color: rgba(252, 165, 165, 0.3);">
        <div class="cycle-num text-red-300">BƯỚC 3</div>
        <div class="cycle-title">Giá tài sản giảm</div>
        <div class="cycle-desc">Thu nhập giảm → chi tiêu giảm → giá nhà, cổ phiếu giảm → giá trị thế chấp co lại.</div>
      </div>
      <div class="cycle-phase" style="border-color: rgba(252, 165, 165, 0.3);">
        <div class="cycle-num text-red-300">BƯỚC 4</div>
        <div class="cycle-title">Tín dụng bị siết</div>
        <div class="cycle-desc">Thế chấp mất giá → ngân hàng thu hẹp cho vay → vòng xoáy đi xuống. Nếu nghiêm trọng: <span class="hl-red">khủng hoảng tín dụng</span>.</div>
      </div>
    </div>

    <!-- Case study: 2008 -->
    <div class="border border-amber-500/20 bg-amber-950/10 p-6 mb-6">
      <p class="text-xs font-mono text-amber-400 font-bold uppercase mb-3">Case Study — Khủng Hoảng 2008</p>
      <p class="text-base text-slate-300 leading-relaxed mb-3">Giai đoạn 2001–2006, Fed giữ lãi suất thấp (1-2%). Ngân hàng cho vay mua nhà tràn lan — kể cả người không có thu nhập ổn định (<span class="popover-wrap"><button class="popover-trigger">subprime mortgage</button><span class="popover-bubble">Cho vay dưới chuẩn — khoản vay bất động sản dành cho người có điểm tín dụng thấp, thu nhập bấp bênh. Lãi suất cao hơn để bù rủi ro. Trước 2008, các ngân hàng bán lại những khoản vay này dưới dạng chứng khoán phái sinh, phân tán rủi ro khắp hệ thống tài chính toàn cầu.</span></span>).</p>
      <p class="text-base text-slate-300 leading-relaxed mb-3">Giá nhà tăng → thế chấp tăng → vay thêm → giá nhà tăng tiếp. Vòng xoáy đi lên hoàn hảo — cho đến khi lãi suất bắt đầu tăng năm 2006.</p>
      <p class="text-base text-slate-300 leading-relaxed">Người vay không trả nổi → ngân hàng mất tiền → <span class="popover-wrap"><button class="popover-trigger">Lehman Brothers</button><span class="popover-bubble">Ngân hàng đầu tư 158 năm tuổi tại Mỹ. Phá sản ngày 15/9/2008 với $639 tỷ tài sản — vụ phá sản lớn nhất lịch sử. Lehman nắm quá nhiều chứng khoán thế chấp dưới chuẩn. Sự sụp đổ của nó gây hoảng loạn toàn cầu vì không ai biết ai còn dính rủi ro tương tự.</span></span> phá sản → tín dụng đóng băng toàn cầu → <span class="hl-red">GDP Mỹ giảm 4.3%</span>, thất nghiệp đạt 10%. Một vòng xoáy tín dụng đi xuống kinh điển.</p>
    </div>

    <!-- Bar chart: Credit growth -->
    <p class="text-sm font-mono text-slate-500 font-bold uppercase tracking-wider mb-4">Tỷ lệ nợ hộ gia đình/GDP — Mỹ</p>
    <div class="space-y-2 mb-8">
      <div class="flex items-center gap-3">
        <span class="w-16 text-right text-xs text-slate-500 shrink-0 font-mono">2000</span>
        <div class="flex-1 bar-track">
