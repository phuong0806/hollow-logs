---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Ray Dalio',
  description: 'Dalio xây được quỹ $160 tỷ không phải nhờ thiên tài bẩm sinh — mà nhờ một lần thất bại hoàn toàn năm 1982 buộc ông tái cấu trúc lại toàn bộ cách tư duy về rủi ro.',
  pubDate: new Date('2026-04-22'),
  tags: ['economics', 'investing'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="Đầu Tư & Quản Lý Tài Sản"
  kickerColor="cyan"
  canonicalUrl="https://grimlogs.com/posts/ray-dalio"
>
  <style>
    /* ─── Popovers ─────────────────────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(34 211 238);
      border-bottom: 1px dashed rgba(34, 211, 238, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(34 211 238); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 290px;
      padding: 12px 14px; background: #1a2744;
      border: 1px solid rgba(34, 211, 238, 0.25);
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(34, 211, 238, 0.25);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 230px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Bar chart ────────────────────────────── */
    .bar-track {
      height: 28px; background: rgba(30, 41, 59, 0.8);
      position: relative; overflow: hidden;
    }
    .bar-fill { height: 100%; }
    .bar-label {
      position: absolute; right: 10px; top: 50%;
      transform: translateY(-50%);
      font-size: 0.75rem; font-weight: 700;
      color: white; text-shadow: 0 1px 2px rgba(0,0,0,0.6);
    }

    /* ─── Timeline ─────────────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(34, 211, 238, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(34, 211, 238, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(34, 211, 238); border-color: rgb(34, 211, 238);
      box-shadow: 0 0 8px rgba(34, 211, 238, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.gold::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(34, 211, 238); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.gold .timeline-year { color: rgb(251, 191, 36); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.gold .timeline-desc { color: rgb(254 243 199); font-weight: 600; }

    /* ─── Stats grid ───────────────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(34, 211, 238);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Environment grid ─────────────────────── */
    .env-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
      background: rgba(100, 116, 139, 0.15);
      border: 1px solid rgba(100, 116, 139, 0.2);
    }
    .env-cell { background: #0B1221; padding: 16px; }
    .env-label {
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.06em; margin-bottom: 8px;
    }
    .env-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .env-assets { font-size: 0.82rem; color: rgb(148 163 184); line-height: 1.5; }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(34, 211, 238, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }

    /* ─── Criticism columns ────────────────────── */
    .crit-col { border: 1px solid rgba(100, 116, 139, 0.2); padding: 20px; }
    .crit-badge {
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.07em; margin-bottom: 10px; padding: 4px 10px;
      display: inline-block;
    }
    .crit-item { margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid rgba(100,116,139,0.15); }
    .crit-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .crit-claim { font-size: 0.88rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .crit-body { font-size: 0.85rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Red flags ────────────────────────────── */
    .redflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.03); margin-bottom: 10px;
    }
    .redflag-icon { color: rgb(239 68 68); flex-shrink: 0; margin-top: 2px; }
    .redflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .redflag-text strong { color: white; }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(34, 211, 238, 0.12);
      color: rgb(34, 211, 238);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(34, 211, 238, 0.35);
    }
    .hl-gold {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(34, 211, 238);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(34, 211, 238); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Performance bars ─────────────────────── */
    .perf-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .perf-year { font-family: monospace; font-size: 0.78rem; font-weight: 700; width: 36px; flex-shrink: 0; color: rgb(148 163 184); }
    .perf-bar-wrap { flex: 1; display: flex; align-items: center; gap: 8px; }
    .perf-bar {
      height: 22px; position: relative; overflow: hidden; min-width: 4px;
    }
    .perf-val { font-size: 0.78rem; font-weight: 700; white-space: nowrap; }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-cyan-500 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-cyan-400 leading-snug">
        "Tôi muốn mình đúng — nhưng tôi sợ mình sai hơn là muốn mình đúng."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Ray Dalio, <em>Principles: Life and Work</em>, 2017
      </footer>
    </div>
  </section>

  <!-- CONTEXT INTRO -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh 2026</p>
        <p class="text-slate-300 text-sm leading-relaxed">Chiến tranh <span class="popover-wrap"><button class="popover-trigger">thuế quan</button><span class="popover-bubble">Tariff — thuế đánh lên hàng hóa nhập khẩu. Trong bối cảnh Mỹ-Trung 2026, các đợt áp thuế leo thang tạo ra áp lực lạm phát và khiến chuỗi cung ứng toàn cầu tái cấu trúc, làm tăng biến động thị trường.</span></span> Mỹ-Trung leo thang. Lạm phát dai dẳng 3–4%. Nhiều <span class="popover-wrap"><button class="popover-trigger">quỹ phòng hộ</button><span class="popover-bubble">Hedge fund — quỹ đầu tư tư nhân dành cho nhà đầu tư tổ chức và cá nhân giàu có. Khác với quỹ tương hỗ, hedge fund được phép dùng đòn bẩy, bán khống, và đầu tư vào các tài sản phức tạp nhằm tạo lợi nhuận trong cả thị trường tăng lẫn giảm.</span></span> macro lớn lỗ hai chữ số.</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Tại Sao Dalio Nổi Tiếng</p>
        <p class="text-slate-300 text-sm leading-relaxed">Người ta trích dẫn ông về <span class="popover-wrap"><button class="popover-trigger">chu kỳ nợ dài hạn</button><span class="popover-bubble">Long-term debt cycle — theo Dalio, chu kỳ tín dụng kéo dài 50-75 năm. Khi nợ tích lũy đến ngưỡng mà thu nhập không đủ trả, nền kinh tế buộc phải "delever" — hoặc qua thắt lưng buộc bụng, hoặc qua in tiền, hoặc qua tái cơ cấu nợ.</span></span>, về sự suy tàn của Mỹ, về vàng và Trung Quốc. Được nhắc nhiều không có nghĩa được hiểu đúng.</p>
      </div>
      <div class="border border-cyan-500/20 bg-cyan-950/10 p-4">
        <p class="text-xs font-mono text-cyan-500 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed">Hành trình thực sự — cơ chế đằng sau chiến lược — và những gì cả hai phía đều bỏ qua.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- WHO IS RAY DALIO?                                      -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-slate-700 text-slate-200 font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Primer</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Ray Dalio Là Ai?</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Tóm tắt nhanh cho ai chưa biết — từ cậu bé chơi cổ phiếu năm 12 tuổi đến người sáng lập quỹ phòng hộ lớn nhất thế giới.</p>

    <!-- Bio steps -->
    <div class="grid md:grid-cols-2 gap-5 mb-10">
      <div class="flex gap-4 items-start">
        <span class="bg-cyan-400 text-[#0B1221] w-8 h-8 flex items-center justify-center font-black text-sm shrink-0 mt-0.5">1</span>
        <div class="border border-slate-700/50 bg-slate-900/30 p-4 flex-1">
          <p class="font-bold text-white text-sm mb-2">Khởi đầu sớm (1949–1973)</p>
          <p class="text-slate-400 text-sm leading-relaxed">Sinh tại New York trong gia đình bình thường — cha là nhạc sĩ jazz. Bắt đầu mua cổ phiếu <span class="hl">từ năm 12 tuổi</span> (Northeast Airlines, $300, gấp 3 nhờ M&A). Tốt nghiệp cử nhân Tài chính tại Long Island University, sau đó <strong class="text-white">MBA Harvard Business School (1973)</strong>. Bắt đầu thực hành <strong class="text-white">Transcendental Meditation</strong> từ 1969 — thói quen ông duy trì suốt đời và coi là <span class="hl-gold">yếu tố quan trọng nhất</span> dẫn đến thành công.</p>
        </div>
      </div>

      <div class="flex gap-4 items-start">
        <span class="bg-rose-500 text-white w-8 h-8 flex items-center justify-center font-black text-sm shrink-0 mt-0.5">2</span>
        <div class="border border-rose-700/30 bg-rose-950/10 p-4 flex-1">
          <p class="font-bold text-white text-sm mb-2">Làm việc & bị sa thải (1974)</p>
          <p class="text-slate-400 text-sm leading-relaxed">Làm trader tại <strong class="text-white">Shearson Hayden Stone</strong> (công ty của Sandy Weill). <span class="hl-red">Bị sa thải sau khi đấm sếp trong bữa tiệc Giao thừa.</span> Sự kiện này — nghe có vẻ không liên quan — thực ra là chất xúc tác buộc ông tự lập và thành lập Bridgewater ngay năm sau.</p>
        </div>
      </div>

      <div class="flex gap-4 items-start">
        <span class="bg-emerald-500 text-[#0B1221] w-8 h-8 flex items-center justify-center font-black text-sm shrink-0 mt-0.5">3</span>
        <div class="border border-emerald-700/30 bg-emerald-950/10 p-4 flex-1">
          <p class="font-bold text-white text-sm mb-2">Thành lập Bridgewater (1975)</p>
            <p class="text-slate-400 text-sm leading-relaxed">Mở công ty từ <span class="hl">căn hộ 2 phòng ngủ ở Manhattan</span>. Ban đầu tư vấn cho doanh nghiệp về rủi ro tỷ giá và lãi suất. Khách hàng đầu tiên bao gồm <strong class="text-white">McDonald's</strong> và quỹ hưu trí <strong class="text-white">World Bank</strong>. Xuất bản bản tin <em>Daily Observations</em> thu hút ngày càng nhiều tổ chức lớn.</p>
        </div>
      </div>

      <div class="flex gap-4 items-start">
        <span class="bg-amber-400 text-[#0B1221] w-8 h-8 flex items-center justify-center font-black text-sm shrink-0 mt-0.5">4</span>
        <div class="border border-amber-700/30 bg-amber-950/10 p-4 flex-1">
          <p class="font-bold text-white text-sm mb-2">Phá sản & tái sinh (1982)</p>
          <p class="text-slate-400 text-sm leading-relaxed">Dự báo công khai Mỹ sắp suy thoái. <span class="hl-red">Sai hoàn toàn.</span> Mất hết khách hàng, phải vay <span class="hl-red">$4,000 từ cha</span>. Đây là bước ngoặt thực sự — thất bại này buộc ông xây <span class="hl">hệ thống ra quyết định dựa trên quy tắc</span> thay vì tin vào phán đoán chủ quan. Cái cỗ máy đó sau này trở thành Pure Alpha.</p>
        </div>
      </div>
    </div>

    <!-- Core philosophy -->
    <div class="border border-slate-600/40 bg-slate-900/20 p-6">
      <h3 class="text-white font-bold text-base mb-4 uppercase tracking-wider text-sm">Triết Lý Cốt Lõi: <span class="text-cyan-400">Idea Meritocracy</span></h3>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <div class="text-cyan-400 font-bold text-sm mb-2">Radical Transparency</div>
          <p class="text-slate-400 text-sm leading-relaxed">Mọi cuộc họp tại Bridgewater được ghi hình. Nhân viên đánh giá nhau theo thời gian thực qua app <strong class="text-white">"Dot Collector"</strong>. Mục đích: loại bỏ chính trị văn phòng và tin đồn. Hệ quả: môi trường đòi hỏi tâm lý cực kỳ vững.</p>
        </div>
        <div>
          <div class="text-emerald-400 font-bold text-sm mb-2">Idea Meritocracy</div>
          <p class="text-slate-400 text-sm leading-relaxed">Ý tưởng tốt nhất thắng, bất kể ai đề xuất. Bất đồng ý kiến được khuyến khích — thậm chí <strong class="text-white">bắt buộc</strong>. Không ai được im lặng khi thấy sai chỉ vì người kia là sếp.</p>
        </div>
        <div>
          <div class="text-amber-400 font-bold text-sm mb-2">Nguyên Tắc Hóa</div>
          <p class="text-slate-400 text-sm leading-relaxed">Mọi quyết định đầu tư được mã hóa thành rule có thể <span class="popover-wrap"><button class="popover-trigger">backtest</button><span class="popover-bubble">Backtest — kiểm tra xem một chiến lược hoặc quy tắc đầu tư sẽ hoạt động thế nào nếu được áp dụng cho dữ liệu lịch sử. Dùng để đánh giá tính hiệu quả của một hệ thống trước khi đưa vào thực tế.</span></span>. Mỗi thất bại → viết thành "principle" để không lặp lại. Đây là nền tảng của cả cuốn sách lẫn Pure Alpha.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- H2-1: TIMELINE & NUMBERS                              -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-cyan-400 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Hành Trình</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">
      Từ $300 Đến $160 Tỷ — Và Hai Lần Suýt Mất Tất Cả
    </h2>
    <p class="text-slate-400 text-base md:text-lg mb-10">
      Câu chuyện về Dalio thường bắt đầu từ 2008 — năm ông đúng khi cả thế giới sai. Nhưng phiên bản đó bỏ qua điều quan trọng nhất: năm 1982, khi ông sai hoàn toàn và phá sản, mới là lúc ông thực sự được tạo ra.
    </p>

    <div class="grid md:grid-cols-2 gap-10 items-start">
