---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Thiên Kiến Xác Nhận — Khi Não Bộ Chỉ Nghe Những Gì Nó Muốn Nghe',
  description: 'Bạn không tìm kiếm sự thật — bạn tìm kiếm bằng chứng cho thứ bạn đã tin. Từ thí nghiệm 2-4-6 của Peter Wason năm 1960 đến fMRI cho thấy não thưởng dopamine khi bạn bác bỏ sự thật, confirmation bias đang điều khiển mọi quyết định của bạn mà bạn không hề hay biết.',
  pubDate: new Date('2026-04-25'),
  tags: ['psychology', 'neuroscience'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="THIÊN KIẾN NHẬN THỨC"
  kickerColor="rose"
>
  <style>
    /* ─── Popovers (rose theme) ────────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(251, 113, 133);
      border-bottom: 1px dashed rgba(251, 113, 133, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(251, 113, 133); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 300px;
      padding: 12px 14px; background: #1a1420;
      border: 1px solid rgba(244, 63, 94, 0.3);
      box-shadow: 0 8px 24px rgba(0,0,0,0.5);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(244, 63, 94, 0.3);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 240px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Stat cards (rose) ────────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(244, 63, 94, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(251, 113, 133);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Timeline (rose) ──────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(244, 63, 94, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(244, 63, 94, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(244, 63, 94); border-color: rgb(244, 63, 94);
      box-shadow: 0 0 8px rgba(244, 63, 94, 0.6);
    }
    .timeline-item.cyan::before {
      background: rgb(34, 211, 238); border-color: rgb(34, 211, 238);
      box-shadow: 0 0 8px rgba(34, 211, 238, 0.5);
    }
    .timeline-item.gold::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
    }
    .timeline-item.green::before {
      background: rgb(52, 211, 153); border-color: rgb(52, 211, 153);
      box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(251, 113, 133); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.cyan .timeline-year { color: rgb(34, 211, 238); }
    .timeline-item.gold .timeline-year { color: rgb(251, 191, 36); }
    .timeline-item.green .timeline-year { color: rgb(52, 211, 153); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.cyan .timeline-desc { color: rgb(207 250 254); font-weight: 600; }
    .timeline-item.gold .timeline-desc { color: rgb(254 243 199); font-weight: 600; }
    .timeline-item.green .timeline-desc { color: rgb(209 250 229); font-weight: 600; }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(244, 63, 94, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }

    /* ─── Evidence bars ────────────────────────── */
    .evidence-row { margin-bottom: 12px; }
    .evidence-label {
      font-size: 0.78rem; font-weight: 600; color: rgb(203 213 225);
      margin-bottom: 4px;
    }
    .evidence-track {
      height: 28px; background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.2);
      position: relative; overflow: hidden;
    }
    .evidence-fill {
      height: 100%; display: flex; align-items: center;
      padding-left: 8px; font-size: 0.7rem; font-weight: 700;
    }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(244, 63, 94);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(251, 113, 133); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Case cards ───────────────────────────── */
    .case-card {
      background: rgba(21, 31, 50, 0.4);
      border: 1px solid rgba(100, 116, 139, 0.2);
      padding: 18px;
    }
    .case-card:hover {
      border-color: rgba(244, 63, 94, 0.4);
      background: rgba(21, 31, 50, 0.6);
    }
    .case-label { font-size: 0.7rem; font-family: monospace; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px; }
    .case-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 6px; }
    .case-body { font-size: 0.85rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(244, 63, 94, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(244, 63, 94, 0.06);
      border: 1px solid rgba(244, 63, 94, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(251, 113, 133); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(244, 63, 94, 0.12);
      color: rgb(251, 113, 133);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(244, 63, 94, 0.35);
    }
    .hl-cyan {
      background: rgba(34, 211, 238, 0.12);
      color: rgb(34, 211, 238);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(34, 211, 238, 0.35);
    }
    .hl-gold {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }

    /* ─── Brain diagram cards ──────────────────── */
    .brain-card {
      padding: 14px; border: 1px solid rgba(100, 116, 139, 0.2);
      background: rgba(21, 31, 50, 0.4);
    }
    .brain-card:hover {
      border-color: rgba(244, 63, 94, 0.4);
      background: rgba(21, 31, 50, 0.6);
    }
    .brain-region {
      font-size: 0.72rem; font-family: monospace; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;
    }
    .brain-role {
      font-size: 0.85rem; font-weight: 700; color: white; margin-bottom: 4px;
    }
    .brain-desc {
      font-size: 0.8rem; line-height: 1.5; color: rgb(148 163 184);
    }

    /* ─── Versus cards ─────────────────────────── */
    .vs-card {
      padding: 16px; text-align: center;
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.2);
    }
    .vs-label {
      font-size: 0.7rem; font-family: monospace;
      font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; margin-bottom: 6px;
    }
    .vs-text {
      font-size: 1rem; font-weight: 700; color: white;
    }
    .vs-sub {
      font-size: 0.8rem; line-height: 1.5; color: rgb(148 163 184); margin-top: 4px;
    }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-rose-400 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-rose-300 leading-snug">
        "Trí tuệ con người, khi đã chấp nhận một ý kiến, sẽ kéo mọi thứ khác đến để ủng hộ và đồng ý với nó."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Francis Bacon, <em>Novum Organum</em>, Aphorism XLVI (1620)
      </footer>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- CONTEXT INTRO                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh</p>
        <p class="text-slate-300 text-sm leading-relaxed">Bạn Google "cà phê có hại không" — và chỉ đọc những bài nói cà phê tốt. Bạn tin ứng viên A giỏi nhất — và bỏ qua mọi bằng chứng nói ngược lại. Bạn không tìm kiếm <strong class="text-white">sự thật</strong> — bạn tìm kiếm <strong class="text-white">sự xác nhận</strong>.</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed"><span class="popover-wrap"><button class="popover-trigger">Confirmation bias</button><span class="popover-bubble">Confirmation bias (thiên kiến xác nhận) — xu hướng tìm kiếm, diễn giải, ưu tiên, và ghi nhớ thông tin theo cách xác nhận niềm tin hoặc giả thuyết có sẵn của mình. Được đặt tên bởi Peter Wason (1960) và được Raymond Nickerson (1998) gọi là "hiện tượng phổ biến nhất dưới nhiều hình dạng."</span></span> không phải lỗi logic hiếm gặp — nó là <span class="hl">chế độ mặc định</span> của bộ não. Và não còn thưởng cho bạn bằng <span class="hl-cyan">dopamine</span> mỗi khi bạn bác bỏ sự thật thành công.</p>
      </div>
      <div class="border border-rose-500/20 bg-rose-950/10 p-4">
        <p class="text-xs font-mono text-rose-400 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed"><span class="hl">Thí nghiệm 2-4-6</span> của Wason. <span class="hl-cyan">Ba cơ chế</span> bóp méo nhận thức. <span class="hl-gold">fMRI não bộ</span> khi đảng viên tự lừa mình. <span class="hl-red">Hậu quả</span> trong y tế, tòa án, và tài chính. Và <span class="hl-green">chiến lược</span> để phá vỡ vòng lặp.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- STATS OVERVIEW                                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="stat-card">
        <div class="stat-num">&lt;10%</div>
        <div class="stat-label">Giải đúng bài Wason Selection Task</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">10–15%</div>
        <div class="stat-label">Chẩn đoán y khoa sai do thiên kiến</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">64%</div>
        <div class="stat-label">Nghiên cứu tâm lý không tái lập được</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">60%</div>
        <div class="stat-label">NĐT bán cổ phiếu thắng sớm hơn cổ thua</div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 01: CONFIRMATION BIAS LÀ GÌ?                      -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-rose-500 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Bạn Không Tìm Sự Thật — Bạn Tìm Sự Đồng Ý</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Confirmation bias là gì, và tại sao Francis Bacon đã nhìn thấy nó 400 năm trước khi khoa học đặt tên.</p>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Năm 1620, triết gia người Anh <span class="popover-wrap"><button class="popover-trigger">Francis Bacon</button><span class="popover-bubble">Francis Bacon (1561–1626) — triết gia, chính trị gia, nhà khoa học người Anh, được coi là cha đẻ của phương pháp khoa học thực nghiệm. Cuốn Novum Organum (1620) đặt nền móng cho tư duy quy nạp và cảnh báo về "Idols of the Mind" — các ảo tưởng hệ thống của trí tuệ con người.</span></span> viết trong <em>Novum Organum</em>: trí tuệ con người mắc một lỗi hệ thống mà ông gọi là <span class="popover-wrap"><button class="popover-trigger">Idols of the Tribe</button><span class="popover-bubble">Idols of the Tribe (Thần tượng của Bộ tộc) — một trong bốn loại ảo tưởng mà Bacon mô tả. Đây là những lỗi nhận thức chung của toàn nhân loại, bắt nguồn từ bản chất sinh học của trí não. Bao gồm: xu hướng tìm kiếm trật tự nơi không có, ưu tiên bằng chứng xác nhận, và bỏ qua bằng chứng phản bác.</span></span> — xu hướng bẩm sinh của con người trong việc nhìn thấy trật tự nơi không có trật tự, và ưu tiên thông tin ủng hộ niềm tin đã có.</p>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Bốn trăm năm sau, <span class="popover-wrap"><button class="popover-trigger">Raymond Nickerson</button><span class="popover-bubble">Raymond S. Nickerson — nhà tâm lý học nhận thức tại Đại học Tufts. Bài tổng quan năm 1998 của ông, "Confirmation Bias: A Ubiquitous Phenomenon in Many Guises," được trích dẫn hơn 5,000 lần — là tài liệu tham khảo chuẩn mực về chủ đề này.</span></span> (1998) gọi nó bằng tên hiện đại: <strong class="text-white">confirmation bias</strong> — "một hiện tượng phổ biến dưới nhiều hình dạng."</p>

    <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Định nghĩa chính thức: xu hướng <span class="hl">tìm kiếm</span>, <span class="hl">diễn giải</span>, <span class="hl">ưu tiên</span>, và <span class="hl">ghi nhớ</span> thông tin theo cách xác nhận niềm tin hoặc giả thuyết có sẵn — đồng thời bỏ qua hoặc đánh giá thấp thông tin mâu thuẫn.</p>

    <!-- Three mechanisms overview -->
    <div class="grid md:grid-cols-3 gap-4 mb-8">
      <div class="vs-card" style="border-color: rgba(244, 63, 94, 0.3);">
        <div class="vs-label" style="color: rgb(251, 113, 133);">Cơ chế 1</div>
        <div class="vs-text">Tìm kiếm thiên lệch</div>
        <div class="vs-sub">Bạn chỉ Google những câu hỏi cho ra câu trả lời bạn muốn nghe. Bạn đặt câu hỏi theo hướng xác nhận giả thuyết.</div>
      </div>
      <div class="vs-card" style="border-color: rgba(34, 211, 238, 0.3);">
        <div class="vs-label" style="color: rgb(34, 211, 238);">Cơ chế 2</div>
        <div class="vs-text">Diễn giải thiên lệch</div>
        <div class="vs-sub">Cùng một dữ liệu, bạn đánh giá bằng chứng ủng hộ là "chất lượng cao" và bằng chứng phản bác là "có vấn đề."</div>
      </div>
      <div class="vs-card" style="border-color: rgba(52, 211, 153, 0.3);">
        <div class="vs-label" style="color: rgb(52, 211, 153);">Cơ chế 3</div>
        <div class="vs-text">Ghi nhớ chọn lọc</div>
        <div class="vs-sub">Não lưu trữ thông tin phù hợp với niềm tin dễ dàng hơn — và "quên" thông tin mâu thuẫn.</div>
      </div>
    </div>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Tại sao confirmation bias tồn tại? — Ba giải thích tiến hóa
      </summary>
      <div class="expand-content">
        <p class="mb-3"><strong class="text-white">1. Hiệu quả xử lý thông tin:</strong> Với lượng thông tin vô hạn, não không thể đánh giá phê phán mọi thứ. Ưu tiên thông tin quen thuộc là <span class="popover-wrap"><button class="popover-trigger">heuristic</button><span class="popover-bubble">Heuristic (lối tắt nhận thức) — quy tắc ngón tay cái mà não sử dụng để đưa ra quyết định nhanh mà không cần phân tích đầy đủ. Kahneman & Tversky (1974) xác định nhiều heuristic, bao gồm anchoring, availability, và representativeness. Chúng hữu ích trong hầu hết trường hợp nhưng gây ra thiên kiến hệ thống.</span></span> tiết kiệm năng lượng.</p>
        <p class="mb-3"><strong class="text-white">2. Bảo vệ lòng tự trọng:</strong> Thừa nhận mình sai gây đau — theo nghĩa đen. <span class="popover-wrap"><button class="popover-trigger">Cognitive dissonance</button><span class="popover-bubble">Cognitive dissonance (bất hòa nhận thức) — trạng thái căng thẳng tâm lý khi bạn giữ hai niềm tin mâu thuẫn cùng lúc. Leon Festinger (1957) phát hiện: con người giảm bất hòa bằng cách thay đổi niềm tin, thêm niềm tin mới, hoặc giảm tầm quan trọng của mâu thuẫn. Thường dẫn đến tự biện hộ thay vì thay đổi hành vi.</span></span> — trạng thái khó chịu khi hai niềm tin xung đột — khiến não tìm cách loại bỏ mâu thuẫn thay vì đối mặt.</p>
        <p><strong class="text-white">3. Gắn kết xã hội:</strong> Trong bộ tộc nguyên thủy, đồng ý với nhóm = sống sót. Thách thức niềm tin nhóm = bị trục xuất. Não tiến hóa để ưu tiên sự đồng thuận hơn sự chính xác.</p>
      </div>
    </details>
  </section>

