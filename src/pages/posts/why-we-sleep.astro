---
import DarkInfographicLayout from '../../layouts/DarkInfographicLayout.astro';

export const metadata = {
  title: 'Why We Sleep — Thông Điệp Đúng, Dữ Liệu Sai',
  description: 'Matthew Walker đúng khi nói giấc ngủ là nền tảng sức khỏe. Nhưng ông phóng đại số liệu, xuyên tạc đồ thị, và tạo ra một thế hệ mắc orthosomnia — lo lắng về giấc ngủ đến mất ngủ.',
  pubDate: new Date('2026-04-23'),
  tags: ['science', 'psychology'],
  theme: 'dark-infographic',
  draft: false,
};
---

<DarkInfographicLayout
  title={metadata.title}
  description={metadata.description}
  pubDate={metadata.pubDate}
  tags={metadata.tags}
  kicker="KHOA HỌC GIẤC NGỦ"
  kickerColor="cyan"
>
  <style>
    /* ─── Popovers (cyan theme) ────────────────── */
    .popover-wrap { position: relative; display: inline; }
    .popover-trigger {
      color: rgb(34, 211, 238);
      border-bottom: 1px dashed rgba(34, 211, 238, 0.4);
      cursor: help; background: none;
      border-top: none; border-left: none; border-right: none;
      font: inherit; padding: 0;
    }
    .popover-trigger:hover { border-bottom-color: rgb(34, 211, 238); }
    .popover-bubble {
      display: none; position: absolute;
      bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 300px;
      padding: 12px 14px; background: #0f2438;
      border: 1px solid rgba(34, 211, 238, 0.3);
      box-shadow: 0 8px 24px rgba(0,0,0,0.5);
      font-size: 0.8rem; line-height: 1.5;
      color: rgb(203 213 225); z-index: 50; text-align: left;
    }
    .popover-bubble::after {
      content: ''; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: rgba(34, 211, 238, 0.3);
    }
    .popover-bubble.show { display: block; }
    @media (max-width: 640px) {
      .popover-bubble { width: 240px; left: 0; transform: none; }
      .popover-bubble::after { left: 20px; transform: none; }
    }

    /* ─── Expand blocks ────────────────────────── */
    .expand-block {
      border: 1px solid rgba(100, 116, 139, 0.3);
      background: rgba(21, 31, 50, 0.3); margin: 1rem 0;
    }
    .expand-block summary {
      cursor: pointer; padding: 12px 16px;
      font-size: 0.85rem; font-weight: 600;
      color: rgb(148 163 184);
      display: flex; align-items: center; gap: 8px;
      list-style: none; user-select: none; transition: color 0.2s;
    }
    .expand-block summary::-webkit-details-marker { display: none; }
    .expand-block summary:hover { color: rgb(226 232 240); }
    .expand-block summary .chevron { transition: transform 0.25s; flex-shrink: 0; }
    .expand-block[open] summary .chevron { transform: rotate(90deg); }
    .expand-block .expand-content {
      padding: 0 16px 16px;
      font-size: 0.9rem; line-height: 1.7; color: rgb(203 213 225);
    }

    /* ─── Timeline (cyan) ──────────────────────── */
    .timeline { position: relative; padding-left: 28px; }
    .timeline::before {
      content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
      width: 2px; background: rgba(34, 211, 238, 0.2);
    }
    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item::before {
      content: ''; position: absolute; left: -24px; top: 6px;
      width: 10px; height: 10px; border-radius: 50%;
      background: #0B1221; border: 2px solid rgba(34, 211, 238, 0.5);
    }
    .timeline-item.highlight::before {
      background: rgb(34, 211, 238); border-color: rgb(34, 211, 238);
      box-shadow: 0 0 8px rgba(34, 211, 238, 0.6);
    }
    .timeline-item.danger::before {
      background: rgb(239, 68, 68); border-color: rgb(239, 68, 68);
      box-shadow: 0 0 8px rgba(239, 68, 68, 0.5);
    }
    .timeline-item.gold::before {
      background: rgb(251, 191, 36); border-color: rgb(251, 191, 36);
      box-shadow: 0 0 8px rgba(251, 191, 36, 0.5);
    }
    .timeline-item.success::before {
      background: rgb(52, 211, 153); border-color: rgb(52, 211, 153);
      box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    }
    .timeline-year {
      font-size: 0.72rem; font-weight: 700; font-family: monospace;
      color: rgb(34, 211, 238); letter-spacing: 0.05em; margin-bottom: 2px;
    }
    .timeline-item.danger .timeline-year { color: rgb(252, 165, 165); }
    .timeline-item.gold .timeline-year { color: rgb(251, 191, 36); }
    .timeline-item.success .timeline-year { color: rgb(52, 211, 153); }
    .timeline-desc {
      font-size: 0.9rem; line-height: 1.5; color: rgb(203 213 225);
    }
    .timeline-item.highlight .timeline-desc { color: white; font-weight: 600; }
    .timeline-item.danger .timeline-desc { color: rgb(254 226 226); font-weight: 600; }
    .timeline-item.gold .timeline-desc { color: rgb(254 243 199); font-weight: 600; }
    .timeline-item.success .timeline-desc { color: rgb(209 250 229); font-weight: 600; }

    /* ─── Stat cards (cyan) ────────────────────── */
    .stat-card {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.15);
      padding: 20px; text-align: center;
    }
    .stat-num {
      font-size: 2rem; font-weight: 900; color: rgb(34, 211, 238);
      line-height: 1; margin-bottom: 6px;
    }
    .stat-label {
      font-size: 0.75rem; color: rgb(100 116 139);
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ─── Comparison table ─────────────────────── */
    .compare-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .compare-table th {
      padding: 10px 12px; background: rgba(21, 31, 50, 0.8);
      color: rgb(148 163 184); font-weight: 700; text-align: left;
      border-bottom: 1px solid rgba(100,116,139,0.3);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .compare-table td {
      padding: 10px 12px; border-bottom: 1px solid rgba(100,116,139,0.15);
      color: rgb(203 213 225); vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(34, 211, 238, 0.03); }
    .compare-table .col-metric { color: white; font-weight: 600; }
    .compare-table .good { color: rgb(74, 222, 128); }
    .compare-table .bad { color: rgb(252, 165, 165); }
    .compare-table .neutral { color: rgb(251, 191, 36); }

    /* ─── Lesson cards ─────────────────────────── */
    .lesson-card {
      background: rgba(21, 31, 50, 0.4);
      border-left: 3px solid rgb(34, 211, 238);
      padding: 14px 16px; margin-bottom: 12px;
    }
    .lesson-num { font-size: 0.7rem; font-family: monospace; color: rgb(34, 211, 238); font-weight: 700; margin-bottom: 4px; }
    .lesson-title { font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .lesson-body { font-size: 0.88rem; line-height: 1.6; color: rgb(148 163 184); }

    /* ─── Red flags ────────────────────────────── */
    .redflag-item {
      display: flex; gap: 12px; align-items: flex-start;
      padding: 14px; border: 1px solid rgba(239, 68, 68, 0.2);
      background: rgba(239, 68, 68, 0.03); margin-bottom: 10px;
    }
    .redflag-icon { color: rgb(239 68 68); flex-shrink: 0; margin-top: 2px; }
    .redflag-text { font-size: 0.92rem; line-height: 1.6; color: rgb(203 213 225); }
    .redflag-text strong { color: white; }

    /* ─── Inline highlights ────────────────────── */
    .hl {
      background: rgba(34, 211, 238, 0.12);
      color: rgb(34, 211, 238);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(34, 211, 238, 0.35);
    }
    .hl-gold {
      background: rgba(251, 191, 36, 0.12);
      color: rgb(251, 191, 36);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(251, 191, 36, 0.35);
    }
    .hl-red {
      background: rgba(239, 68, 68, 0.12);
      color: rgb(252, 165, 165);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    }
    .hl-green {
      background: rgba(16, 185, 129, 0.12);
      color: rgb(52, 211, 153);
      font-weight: 700;
      padding: 1px 5px;
      border-bottom: 1px solid rgba(16, 185, 129, 0.3);
    }

    /* ─── Flow diagram ─────────────────────────── */
    .flow-box {
      background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(34, 211, 238, 0.2);
      padding: 16px; text-align: center;
    }
    .flow-box-accent {
      background: rgba(34, 211, 238, 0.06);
      border: 1px solid rgba(34, 211, 238, 0.35);
      padding: 16px; text-align: center;
    }
    .flow-arrow {
      color: rgb(34, 211, 238); font-size: 1.5rem;
      display: flex; align-items: center; justify-content: center;
    }

    /* ─── Sleep cycle bars ─────────────────────── */
    .cycle-row {
      display: flex; align-items: center; gap: 10px; margin-bottom: 8px;
    }
    .cycle-label {
      width: 90px; font-size: 0.75rem; font-weight: 700;
      font-family: monospace; color: rgb(148 163 184);
      flex-shrink: 0;
    }
    .cycle-track {
      flex: 1; display: flex; height: 32px; overflow: hidden;
      border: 1px solid rgba(100, 116, 139, 0.2);
    }
    .cycle-nrem {
      background: rgba(34, 211, 238, 0.35);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.65rem; font-weight: 700; color: rgb(34, 211, 238);
      letter-spacing: 0.03em;
    }
    .cycle-rem {
      background: rgba(251, 191, 36, 0.3);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.65rem; font-weight: 700; color: rgb(251, 191, 36);
      letter-spacing: 0.03em;
    }

    /* ─── Evidence bars ────────────────────────── */
    .evidence-row { margin-bottom: 12px; }
    .evidence-label {
      font-size: 0.78rem; font-weight: 600; color: rgb(203 213 225);
      margin-bottom: 4px;
    }
    .evidence-track {
      height: 24px; background: rgba(21, 31, 50, 0.5);
      border: 1px solid rgba(100, 116, 139, 0.2);
      position: relative; overflow: hidden;
    }
    .evidence-fill {
      height: 100%; display: flex; align-items: center;
      padding-left: 8px; font-size: 0.7rem; font-weight: 700;
    }
  </style>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OPENING QUOTE                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border-l-4 border-cyan-400 pl-6 py-2">
      <blockquote class="text-2xl md:text-3xl font-bold italic text-cyan-300 leading-snug">
        "Các nhà khoa học đã phát hiện một phương pháp điều trị mang tính cách mạng giúp bạn sống lâu hơn, tăng cường trí nhớ, giảm cân, và khiến bạn hấp dẫn hơn. Nó được gọi là giấc ngủ."
      </blockquote>
      <footer class="mt-3 text-slate-500 text-sm font-mono tracking-wide">
        — Matthew Walker, <em>Why We Sleep</em>, Chương 1 (2017)
      </footer>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- CONTEXT INTRO                                          -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid md:grid-cols-3 gap-3 mb-6">
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Bối Cảnh</p>
        <p class="text-slate-300 text-sm leading-relaxed"><em>Why We Sleep</em> (2017) của <span class="popover-wrap"><button class="popover-trigger">Matthew Walker</button><span class="popover-bubble">Matthew Walker — Giáo sư Khoa học Thần kinh và Tâm lý học tại UC Berkeley, giám đốc Trung tâm Khoa học Giấc ngủ Con người. Từng nghiên cứu tại Harvard Medical School. Chuyên nghiên cứu tác động của giấc ngủ lên sức khỏe và bệnh tật.</span></span> là cuốn sách về giấc ngủ bán chạy nhất mọi thời đại — dịch ra hơn 30 ngôn ngữ, được Bill Gates khuyên đọc, thay đổi chính sách giờ học tại hàng trăm trường học.</p>
      </div>
      <div class="border border-slate-700/40 bg-slate-900/20 p-4">
        <p class="text-xs font-mono text-slate-500 font-bold uppercase mb-2">Vấn Đề</p>
        <p class="text-slate-300 text-sm leading-relaxed">Năm 2019, nhà nghiên cứu Alexey Guzey công bố bản phân tích chi tiết: Walker <span class="hl-red">xuyên tạc đồ thị</span>, trích dẫn sai số liệu, và đưa ra tuyên bố không thể xác minh. Nhiều nhà khoa học giấc ngủ khác cũng lên tiếng phê bình giọng văn <span class="hl-gold">giật gân quá mức</span>.</p>
      </div>
      <div class="border border-cyan-500/20 bg-cyan-950/10 p-4">
        <p class="text-xs font-mono text-cyan-400 font-bold uppercase mb-2">Bài Này Đi Qua</p>
        <p class="text-slate-300 text-sm leading-relaxed"><span class="hl">Khoa học thực sự</span> đằng sau giấc ngủ — NREM, REM, hệ glymphatic. <span class="hl-red">Những gì Walker phóng đại</span> — đường cong tử vong, nguy cơ ung thư, "đại dịch" WHO. Và <span class="hl-gold">nghịch lý orthosomnia</span> — khi sợ mất ngủ khiến bạn mất ngủ.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- STATS OVERVIEW                                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="stat-card">
        <div class="stat-num">30+</div>
        <div class="stat-label">Ngôn ngữ đã dịch</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">2019</div>
        <div class="stat-label">Năm Guzey phát hiện lỗi</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">~7h</div>
        <div class="stat-label">Thời gian ngủ tối ưu (dữ liệu dịch tễ)</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">5.7–7.1h</div>
        <div class="stat-label">Giấc ngủ bộ lạc săn bắt</div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- MỞ BÀI                                                 -->
  <!-- ══════════════════════════════════════════════════════ -->
  <section>
    <div class="border border-slate-700/40 bg-slate-900/20 p-6">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Năm 2026, ngành công nghiệp "tối ưu giấc ngủ" trị giá hàng tỷ đô — Apple Watch, Oura Ring, WHOOP, hàng ngàn ứng dụng theo dõi từng phút bạn ngủ. Phần lớn ý tưởng đổ về đây bắt nguồn từ một cuốn sách: <em>Why We Sleep</em> của Matthew Walker.</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Walker viết với sứ mệnh rõ ràng: đánh thức thế giới về tầm quan trọng của giấc ngủ. Ông làm điều đó bằng những con số gây sốc — ung thư gấp đôi, tim ngừng đập, trí nhớ tan biến. Vấn đề là <strong class="text-white">nhiều con số đó không chính xác</strong>.</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Khoa học giấc ngủ là thật. Cơ chế sinh học là thật. Nhưng cách Walker trình bày nó — bẻ cong đồ thị, phóng đại rủi ro, tuyên bố những điều không thể xác minh — đã biến một thông điệp y tế quan trọng thành <span class="popover-wrap"><button class="popover-trigger">propaganda</button><span class="popover-bubble">Propaganda — thuật tuyên truyền nhằm tác động cảm xúc và niềm tin của người đọc thay vì trình bày bằng chứng khách quan. Trong truyền thông khoa học, propaganda xảy ra khi tác giả chọn lọc dữ liệu có lợi và che giấu dữ liệu bất lợi để đẩy mạnh narrative mong muốn.</span></span>. Và propaganda — dù với ý tốt — vẫn gây hại.</p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- PHẦN 01: CỖ MÁY SINH HỌC                               -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="h-px w-full bg-slate-800"></div>

  <section>
    <span class="inline-block bg-cyan-400 text-[#0B1221] font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider">Phần 01</span>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Cỗ Máy Sinh Học — Giấc Ngủ Thực Sự Làm Gì Với Não Và Cơ Thể?</h2>
    <p class="text-slate-400 text-base md:text-lg mb-8">Trước khi phê phán Walker, cần hiểu phần ông viết đúng — và phần đó ấn tượng hơn bất kỳ sự phóng đại nào.</p>

    <!-- NREM vs REM -->
    <p class="text-xs font-mono text-cyan-400 font-bold uppercase tracking-wider mb-4">Hai Loại Giấc Ngủ — Hai Nhiệm Vụ Khác Nhau</p>

    <div class="grid md:grid-cols-2 gap-4 mb-8">
      <div class="border border-cyan-500/20 bg-cyan-950/10 p-5">
        <p class="text-sm font-mono text-cyan-400 font-bold uppercase mb-2">NREM — Non-Rapid Eye Movement</p>
        <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-3"><span class="popover-wrap"><button class="popover-trigger">NREM</button><span class="popover-bubble">NREM (Non-Rapid Eye Movement) — giấc ngủ không chuyển động mắt nhanh, gồm 3 giai đoạn từ nông đến sâu. Chiếm khoảng 75-80% tổng thời gian ngủ. Giai đoạn 3 (sóng chậm) là giấc ngủ sâu nhất, quan trọng nhất cho phục hồi cơ thể.</span></span> chiếm phần lớn nửa đầu đêm. Đây là lúc não "dọn dẹp" — chuyển ký ức từ <span class="popover-wrap"><button class="popover-trigger">hippocampus</button><span class="popover-bubble">Hippocampus (Hồi Hải Mã) — cấu trúc não hình con cá ngựa, đóng vai trò bộ nhớ tạm. Thông tin mới được lưu tạm ở đây trước khi được "đóng gói" và chuyển sang vỏ não (neocortex) trong giấc ngủ sâu để lưu trữ dài hạn.</span></span> sang vỏ não để lưu trữ dài hạn.</p>
        <p class="text-sm text-slate-400 leading-relaxed"><span class="popover-wrap"><button class="popover-trigger">Sleep spindles</button><span class="popover-bubble">Sleep Spindles (Sóng Thoi Ngủ) — các đợt bùng phát hoạt động thần kinh kéo dài 0.5-2 giây trong giai đoạn 2 NREM. Mật độ spindle tương quan với khả năng học tập — người có nhiều spindle hơn ghi nhớ tốt hơn. Cơ chế: spindle "khóa" thông tin mới vào mạng thần kinh dài hạn.</span></span> — những đợt bùng phát sóng não trong giai đoạn 2 — đóng vai trò "khóa" ký ức mới vào mạng thần kinh. Hormone tăng trưởng được tiết ra mạnh nhất trong giấc ngủ sâu giai đoạn 3.</p>
      </div>
      <div class="border border-amber-500/20 bg-amber-950/10 p-5">
        <p class="text-sm font-mono text-amber-400 font-bold uppercase mb-2">REM — Rapid Eye Movement</p>
        <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-3"><span class="popover-wrap"><button class="popover-trigger">REM</button><span class="popover-bubble">REM (Rapid Eye Movement) — giấc ngủ chuyển động mắt nhanh, giai đoạn mơ chính. Não hoạt động gần như tỉnh nhưng cơ thể bị tê liệt tạm thời (muscle atonia) để ngăn hành động theo giấc mơ. Chiếm 20-25% tổng thời gian ngủ, tăng dần về cuối đêm.</span></span> tập trung ở nửa sau đêm — đây là giai đoạn mơ. Não xử lý cảm xúc, "tháo ngòi" những trải nghiệm tiêu cực, và tạo kết nối sáng tạo giữa các ý tưởng tưởng chừng không liên quan.</p>
        <p class="text-sm text-slate-400 leading-relaxed">Walker gọi REM là "liệu pháp tâm lý qua đêm" — não tách nội dung ký ức khỏi cảm xúc đi kèm. Cơ bắp bị tê liệt hoàn toàn (<strong class="text-white">muscle atonia</strong>) để ngăn bạn hành động theo giấc mơ.</p>
      </div>
    </div>

    <!-- Sleep cycle chart -->
    <p class="text-xs font-mono text-cyan-400 font-bold uppercase tracking-wider mb-4">Chu Kỳ Giấc Ngủ Qua Một Đêm 8 Tiếng</p>
    <div class="border border-slate-700/40 bg-slate-900/20 p-5 mb-3">
      <div class="cycle-row">
        <span class="cycle-label">Chu kỳ 1</span>
        <div class="cycle-track">
          <div class="cycle-nrem" style="width: 85%;">NREM 85%</div>
          <div class="cycle-rem" style="width: 15%;">REM</div>
        </div>
      </div>
      <div class="cycle-row">
        <span class="cycle-label">Chu kỳ 2</span>
        <div class="cycle-track">
          <div class="cycle-nrem" style="width: 70%;">NREM 70%</div>
          <div class="cycle-rem" style="width: 30%;">REM 30%</div>
        </div>
      </div>
      <div class="cycle-row">
        <span class="cycle-label">Chu kỳ 3</span>
        <div class="cycle-track">
          <div class="cycle-nrem" style="width: 55%;">NREM 55%</div>
          <div class="cycle-rem" style="width: 45%;">REM 45%</div>
        </div>
      </div>
      <div class="cycle-row">
        <span class="cycle-label">Chu kỳ 4</span>
        <div class="cycle-track">
          <div class="cycle-nrem" style="width: 40%;">NREM</div>
          <div class="cycle-rem" style="width: 60%;">REM 60%</div>
        </div>
      </div>
      <div class="cycle-row">
        <span class="cycle-label">Chu kỳ 5</span>
        <div class="cycle-track">
          <div class="cycle-nrem" style="width: 25%;">NREM</div>
          <div class="cycle-rem" style="width: 75%;">REM 75%</div>
        </div>
      </div>
    </div>
    <p class="text-sm text-slate-500 mb-8">Ngủ 6 giờ thay vì 8 giờ không mất 25% giấc ngủ — mất gần <strong class="text-white">60-90% REM</strong> vì REM tập trung ở 2 chu kỳ cuối. Đây là một trong những insight quan trọng nhất của Walker và hoàn toàn chính xác.</p>

    <!-- Adenosine mechanism -->
    <p class="text-xs font-mono text-cyan-400 font-bold uppercase tracking-wider mb-4">Cơ Chế Adenosine — Tại Sao Bạn Buồn Ngủ?</p>
    <div class="grid grid-cols-1 md:grid-cols-5 gap-3 items-center mb-8">
      <div class="flow-box-accent">
        <p class="text-xs font-mono text-cyan-400 uppercase tracking-wider mb-1">Tỉnh dậy</p>
        <p class="text-base font-bold text-white"><span class="popover-wrap"><button class="popover-trigger">Adenosine</button><span class="popover-bubble">Adenosine — chất hóa học tích lũy trong não khi bạn thức. Càng thức lâu, adenosine càng nhiều, gắn vào thụ thể tạo ra cảm giác buồn ngủ ("áp lực ngủ"). Khi ngủ, não dọn sạch adenosine — giống như xả hết nước trong bể chứa.</span></span> = 0</p>
        <p class="text-xs text-slate-400 mt-1">Bể chứa trống</p>
      </div>
      <div class="flow-arrow hidden md:flex">&rarr;</div>
      <div class="flow-box">
        <p class="text-xs font-mono text-slate-400 uppercase tracking-wider mb-1">12-16 giờ sau</p>
        <p class="text-base font-bold text-white">Adenosine tích lũy</p>
        <p class="text-xs text-slate-400 mt-1">"Áp lực ngủ" tăng dần</p>
      </div>
      <div class="flow-arrow hidden md:flex">&rarr;</div>
      <div class="grid grid-cols-1 gap-2">
        <div class="flow-box-accent" style="border-color: rgba(251, 191, 36, 0.4); background: rgba(251, 191, 36, 0.06);">
          <p class="text-xs font-mono text-amber-400 uppercase tracking-wider"><span class="popover-wrap"><button class="popover-trigger">Caffeine</button><span class="popover-bubble">Caffeine — hoạt động bằng cách chặn thụ thể adenosine trong não. Không xóa adenosine — chỉ che mắt bạn khỏi tín hiệu buồn ngủ. Khi caffeine hết tác dụng (thời gian bán hủy 5-7 giờ), adenosine tích lũy ào vào gây "caffeine crash." Drake et al. (2013) cho thấy caffeine uống 6 giờ trước khi ngủ vẫn giảm giấc ngủ sâu đáng kể.</span></span> chặn</p>
          <p class="text-sm font-bold text-white">Che tín hiệu, không xóa</p>
        </div>
        <div class="flow-box-accent">
          <p class="text-xs font-mono text-cyan-400 uppercase tracking-wider">Ngủ</p>
          <p class="text-sm font-bold text-white">Não dọn sạch adenosine</p>
        </div>
      </div>
    </div>

    <!-- Glymphatic system -->
    <div class="border-l-4 border-cyan-400 pl-6 py-2 mb-8">
      <blockquote class="text-lg md:text-xl font-semibold italic text-cyan-300 leading-relaxed">
        "Tỉnh dậy là tổn thương não cấp thấp, còn giấc ngủ là cơ chế vệ sinh thần kinh."
      </blockquote>
      <footer class="mt-2 text-slate-500 text-sm font-mono tracking-wide">
        — Walker, diễn giải từ nghiên cứu của Maiken Nedergaard về hệ glymphatic
      </footer>
    </div>

    <div class="border border-slate-700/40 bg-slate-900/20 p-6 mb-8">
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-4">Năm 2013, phòng thí nghiệm của Maiken Nedergaard tại Đại học Rochester công bố phát hiện đột phá trên tạp chí <em>Science</em>: não có <span class="popover-wrap"><button class="popover-trigger">hệ glymphatic</button><span class="popover-bubble">Glymphatic System (Hệ Glymphatic) — hệ thống dọn rác của não, phát hiện năm 2012-2013 bởi phòng thí nghiệm Maiken Nedergaard. Trong giấc ngủ sâu NREM, các tế bào thần kinh đệm co lại ~60%, tạo kênh cho dịch não tủy cuốn trôi chất thải chuyển hóa — bao gồm beta-amyloid, protein liên quan đến Alzheimer. Hoạt động mạnh nhất khi ngủ, giảm đáng kể khi thức.</span></span> riêng — một mạng lưới dọn rác hoạt động mạnh nhất trong giấc ngủ sâu.</p>

      <p class="text-base md:text-lg text-slate-300 leading-relaxed">Khi bạn ngủ, tế bào thần kinh đệm co lại khoảng 60%, tạo kênh cho dịch não tủy cuốn trôi chất thải — bao gồm <span class="popover-wrap"><button class="popover-trigger">beta-amyloid</button><span class="popover-bubble">Beta-amyloid — protein tích tụ thành mảng bám trong não bệnh nhân Alzheimer. Giấc ngủ sâu NREM là thời điểm beta-amyloid được dọn sạch hiệu quả nhất qua hệ glymphatic. Mối quan hệ hai chiều: thiếu ngủ → tích tụ amyloid → amyloid phá vỡ giấc ngủ sâu → thiếu ngủ thêm.</span></span>, protein liên quan đến Alzheimer. Phát hiện này đã được xác nhận nhiều lần và là một trong những đóng góp lớn nhất của khoa học giấc ngủ thế kỷ 21.</p>
    </div>

    <!-- Well-supported findings -->
    <p class="text-xs font-mono text-cyan-400 font-bold uppercase tracking-wider mb-4">Những Phát Hiện Được Xác Nhận Vững Chắc</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-8">
      <div class="stat-card">
        <div class="stat-num" style="font-size: 1.5rem;">+60%</div>
        <div class="stat-label"><span class="popover-wrap"><button class="popover-trigger">Amygdala</button><span class="popover-bubble">Amygdala (Hạch Hạnh Nhân) — vùng não xử lý cảm xúc và phát hiện mối đe dọa. Nghiên cứu fMRI của chính Walker (Yoo et al., 2007) cho thấy thiếu ngủ khiến amygdala phản ứng mạnh hơn 60% với kích thích tiêu cực — não mất khả năng kiểm soát cảm xúc, quay về trạng thái "nguyên thủy."</span></span> tăng phản ứng khi thiếu ngủ</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" style="font-size: 1.5rem;">4.2×</div>
        <div class="stat-label">Nguy cơ cảm lạnh tăng khi ngủ dưới 6 giờ</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" style="font-size: 1.5rem;">0.08%</div>
        <div class="stat-label">BAC tương đương sau 19 giờ thức</div>
      </div>
    </div>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Chi tiết: Nghiên cứu gốc đằng sau 3 con số trên
      </summary>
      <div class="expand-content">
        <p class="mb-3"><strong class="text-white">Amygdala +60%:</strong> Yoo, Gujar, Hu, Jolesz & Walker (2007), <em>Current Biology</em>. Nhóm nghiên cứu của chính Walker tại Harvard. Quét fMRI cho thấy người thiếu ngủ có phản ứng amygdala mạnh hơn 60% với hình ảnh tiêu cực, đồng thời mất kết nối với <span class="popover-wrap"><button class="popover-trigger">vỏ não trước trán</button><span class="popover-bubble">Prefrontal Cortex (Vỏ Não Trước Trán) — vùng não phụ trách chức năng điều hành: ra quyết định, kiểm soát xung lực, lập kế hoạch. Khi thiếu ngủ, kết nối giữa vỏ não trước trán và amygdala suy yếu — não mất "cái phanh" cảm xúc.</span></span> — vùng não kiểm soát cảm xúc. Kết quả đã được tái lập.</p>
        <p class="mb-3"><strong class="text-white">4.2× cảm lạnh:</strong> Prather, Janicki-Deverts, Hall & Cohen (2015), <em>Sleep</em>. 164 người được cho tiếp xúc virus rhinovirus. Nhóm ngủ dưới 5 giờ có tỉ lệ nhiễm 50%, nhóm ngủ trên 7 giờ chỉ 18%. Ngủ dưới 6 giờ tăng nguy cơ 4.2 lần. Nghiên cứu được thiết kế cẩn thận và đăng trên tạp chí hàng đầu.</p>
        <p><strong class="text-white">0.08% BAC:</strong> Dawson & Reid (1997), <em>Nature</em>. Sau 17-19 giờ thức, hiệu suất nhận thức tương đương ngưỡng say rượu hợp pháp tại Mỹ. Đây là nghiên cứu nền tảng cho luật lái xe buồn ngủ tại nhiều quốc gia.</p>
      </div>
    </details>

    <details class="expand-block">
      <summary>
        <svg class="chevron w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        Đọc thêm: Circadian rhythm và chronotype — bạn là "cú đêm" hay "chim sơn ca"?
      </summary>
      <div class="expand-content">
        <p class="mb-3"><span class="popover-wrap"><button class="popover-trigger">Nhịp sinh học circadian</button><span class="popover-bubble">Circadian Rhythm (Nhịp Sinh Học Ngày Đêm) — đồng hồ sinh học nội tại chạy trên chu kỳ khoảng 24 giờ 15 phút, được đồng bộ bởi ánh sáng thông qua nhân trên chéo (suprachiasmatic nucleus) trong vùng dưới đồi. Điều khiển chu kỳ ngủ-thức, nhiệt độ cơ thể, tiết hormone, và hàng trăm quá trình sinh học khác.</span></span> được điều khiển bởi <span class="popover-wrap"><button class="popover-trigger">nhân trên chéo</button><span class="popover-bubble">Suprachiasmatic Nucleus (SCN) — nhân trên chéo thị giác, đồng hồ sinh học chủ trong não, nằm ở vùng dưới đồi (hypothalamus). Chứa khoảng 20,000 tế bào thần kinh tạo nhịp. Nhận tín hiệu ánh sáng từ mắt để đồng bộ đồng hồ nội tại với chu kỳ sáng-tối bên ngoài.</span></span> (SCN) trong não — một đồng hồ sinh học chính xác chạy trên chu kỳ ~24 giờ 15 phút.</p>
        <p class="mb-3"><span class="popover-wrap"><button class="popover-trigger">Chronotype</button><span class="popover-bubble">Chronotype (Kiểu Thời Gian) — xu hướng sinh học quyết định bạn hoạt động tốt nhất vào buổi sáng hay buổi tối. Khoảng 30% dân số thuộc nhóm "sớm" (larks), 30% thuộc nhóm "muộn" (owls), 40% ở giữa. Chronotype được quy định bởi di truyền — không phải lười biếng hay kỷ luật kém.</span></span> — kiểu thời gian — được quy định bởi gene. Khoảng 30% dân số là "chim sơn ca" (thức sớm, hiệu quả buổi sáng), 30% là "cú đêm" (thức khuya, hiệu quả buổi tối), 40% ở giữa. Walker đúng khi chỉ ra xã hội phân biệt đối xử với nhóm cú đêm — ép họ vào lịch trình sáng sớm mà sinh học không cho phép.</p>
        <p><span class="popover-wrap"><button class="popover-trigger">Melatonin</button><span class="popover-bubble">Melatonin — hormone do tuyến tùng tiết ra khi trời tối, báo hiệu cho cơ thể "đã đến giờ ngủ." Melatonin là tín hiệu thời gian, không phải chất gây ngủ — nó mở cổng cho giấc ngủ nhưng không tạo ra giấc ngủ. Ánh sáng xanh từ màn hình ức chế tiết melatonin mạnh nhất.</span></span> là tín hiệu thời gian, không phải thuốc ngủ — nó mở cổng cho giấc ngủ nhưng không tạo ra giấc ngủ. Ánh sáng xanh từ điện thoại ức chế melatonin mạnh nhất — đây là lý do đọc sách giấy trước khi ngủ hiệu quả hơn lướt mạng.</p>
      </div>
    </details>
  </section>

