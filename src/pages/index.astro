---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getAllPosts } from '../lib/posts';

const posts = getAllPosts();
---

<BaseLayout
  title="hollow.logs — nhật ký học tập"
  description="Blog cá nhân về những gì tôi đang học."
  bodyClass="bg-[#0f0806] text-[#d4c4a8] font-sans min-h-screen relative"
>
  <!-- Star field + Mars atmosphere -->
  <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
    <!-- Atmospheric haze at horizon -->
    <div class="absolute inset-0"
         style="background:
           radial-gradient(ellipse 120% 50% at 50% 100%, rgba(232,112,64,0.08) 0%, transparent 60%),
           radial-gradient(ellipse 80% 40% at 30% 90%, rgba(196,90,60,0.06) 0%, transparent 50%),
           radial-gradient(ellipse 60% 30% at 70% 95%, rgba(212,163,92,0.04) 0%, transparent 40%);">
    </div>
    <!-- Scattered stars -->
    <div class="absolute inset-0" style="background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(212,196,168,0.4) 50%, transparent 50%),
      radial-gradient(1px 1px at 25% 8%, rgba(212,196,168,0.3) 50%, transparent 50%),
      radial-gradient(1.5px 1.5px at 40% 22%, rgba(232,112,64,0.5) 50%, transparent 50%),
      radial-gradient(1px 1px at 55% 5%, rgba(212,196,168,0.35) 50%, transparent 50%),
      radial-gradient(1px 1px at 70% 18%, rgba(212,196,168,0.25) 50%, transparent 50%),
      radial-gradient(1px 1px at 85% 12%, rgba(212,196,168,0.4) 50%, transparent 50%),
      radial-gradient(1.5px 1.5px at 15% 35%, rgba(212,196,168,0.2) 50%, transparent 50%),
      radial-gradient(1px 1px at 90% 28%, rgba(212,196,168,0.3) 50%, transparent 50%),
      radial-gradient(1px 1px at 5% 42%, rgba(232,112,64,0.3) 50%, transparent 50%),
      radial-gradient(1px 1px at 60% 38%, rgba(212,196,168,0.2) 50%, transparent 50%),
      radial-gradient(1px 1px at 35% 48%, rgba(212,196,168,0.25) 50%, transparent 50%),
      radial-gradient(1px 1px at 78% 45%, rgba(212,196,168,0.15) 50%, transparent 50%);">
    </div>
  </div>

  <div class="relative z-10">
    <Nav variant="mars" logo="hollow.logs" />

    <main class="max-w-[680px] mx-auto px-5 sm:px-8 py-16 sm:py-24">
      <!-- Signal status bar -->
      <div class="font-mono text-[10px] sm:text-[11px] text-[#5a5044] tracking-[0.25em] uppercase mb-8 sm:mb-10 flex flex-wrap items-center gap-x-4 gap-y-1">
        <span class="flex items-center gap-2">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-[#e87040] mars-pulse"></span>
          Đang truyền tín hiệu
        </span>
        <span>{posts.length} bản ghi</span>
      </div>

      <!-- Hero -->
      <h1 class="text-[2.5rem] sm:text-[3.5rem] font-bold leading-[1.05] tracking-tight mb-3 font-space">
        <span class="text-[#e87040]">Những gì</span> tôi đang học.
      </h1>
      <p class="font-mono text-[11px] sm:text-xs tracking-[0.2em] uppercase mb-4">
        <span class="text-[#8a7d6b]">by Phuong Nguyen</span>
        <span class="text-[#e87040] ml-1">aka Mars</span>
      </p>

      <!-- Terrain divider -->
      <div class="relative h-8 mb-10 sm:mb-14 overflow-hidden">
        <svg viewBox="0 0 680 32" class="w-full h-full" preserveAspectRatio="none">
          <path d="M0 28 Q40 20 80 24 T160 18 T240 22 T320 14 T400 20 T480 16 T560 22 T640 18 L680 20 L680 32 L0 32 Z"
                fill="rgba(232,112,64,0.06)" />
          <path d="M0 28 Q40 20 80 24 T160 18 T240 22 T320 14 T400 20 T480 16 T560 22 T640 18 L680 20"
                fill="none" stroke="rgba(232,112,64,0.15)" stroke-width="1" />
        </svg>
      </div>

      <p class="text-[#8a7d6b] text-base sm:text-lg mb-14 sm:mb-18 border-l-2 border-[#e87040]/30 pl-4 sm:pl-5 leading-relaxed italic">
        "The mind is not a vessel to be filled, but a fire to be kindled."
        <span class="block text-[#5a5044] text-sm mt-1 not-italic">— Plutarch</span>
      </p>

      <!-- Post list -->
      <div class="space-y-4">
        {posts.map(post => (
          <a href={post.url} class="group block no-underline rounded-xl border border-[#2a1f18]/80 bg-[#1a120e] hover:bg-[#221810] hover:border-[#e87040]/30 transition-all duration-300 overflow-hidden">
            <div class="flex">
              <div class="w-1 shrink-0 bg-[#e87040]/20 group-hover:bg-[#e87040]/60 transition-colors duration-300"></div>
              <div class="px-5 sm:px-6 py-5 sm:py-6 flex-1 min-w-0 bg-[#241a14] group-hover:bg-[#2a1e16] transition-colors duration-300">
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[10px] sm:text-[11px] tracking-[0.2em] uppercase mb-2.5">
                  {post.meta.tags && post.meta.tags.length > 0 && (
                    <span class="text-[#e87040]/80">{post.meta.tags.join(' · ')}</span>
                  )}
                  <span class="text-[#7a6d5e]">
                    {new Date(post.meta.pubDate).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' })}
                  </span>
                </div>
                <h2 class="text-xl sm:text-2xl font-medium text-[#e8dcc8] group-hover:text-[#e87040] transition-colors duration-300 mb-2 leading-snug font-space">
                  {post.meta.title}
                </h2>
                <p class="text-[#a89880] text-[0.9rem] sm:text-[0.95rem] leading-relaxed group-hover:text-[#b8a890] transition-colors duration-300">
                  {post.meta.description}
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>

    <Footer variant="mars" />
  </div>
</BaseLayout>

<style>
  .mars-pulse {
    animation: mars-glow 3s ease-in-out infinite;
  }
  @keyframes mars-glow {
    0%, 100% { opacity: 1; box-shadow: 0 0 4px rgba(232,112,64,0.6); }
    50% { opacity: 0.4; box-shadow: 0 0 2px rgba(232,112,64,0.2); }
  }
</style>
