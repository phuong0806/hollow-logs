---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getAllPosts } from '../lib/posts';

const posts = getAllPosts();
---

<BaseLayout
  title="hollow.logs — nhật ký học tập"
  description="Blog cá nhân về những gì tôi đang học."
  bodyClass="bg-ink text-paper font-serif text-xl min-h-screen relative"
>
  <!-- Paper texture -->
  <div class="fixed inset-0 pointer-events-none z-0"
       style="background: radial-gradient(ellipse at top, rgba(201,169,97,0.03) 0%, transparent 50%), radial-gradient(ellipse at bottom, rgba(201,169,97,0.02) 0%, transparent 50%);">
  </div>

  <div class="relative z-10">
    <Nav variant="dark" logo="hollow.logs" />

    <main class="max-w-[680px] mx-auto px-5 sm:px-8 py-12 sm:py-16 pb-20 sm:pb-24">
      <!-- Intro -->
      <div class="font-mono text-[11px] sm:text-xs text-paper-faint tracking-wider uppercase mb-5 sm:mb-6 flex flex-wrap items-center gap-x-3 gap-y-1">
        <span>Nhật ký học tập</span>
        <span class="before:content-['·'] before:mr-3 before:text-paper-faint">{posts.length} bài viết</span>
      </div>

      <h1 class="text-[2.25rem] sm:text-5xl font-medium leading-[1.1] tracking-tight mb-4">
        Những gì tôi đang học.
      </h1>
      <p class="italic text-paper-dim text-lg sm:text-[1.3rem] mb-12 sm:mb-16 border-l-2 border-accent-gold pl-4 sm:pl-5 leading-snug">
        Một nơi để ghi lại những suy nghĩ, bài học, và câu hỏi còn dang dở.
      </p>

      <!-- Post list -->
      <ul class="divide-y divide-border-subtle">
        {posts.map(post => (
          <li class="py-5 sm:py-6 first:pt-0">
            <a href={post.url} class="group block no-underline">
              {post.meta.tags && post.meta.tags.length > 0 && (
                <div class="font-mono text-[10px] sm:text-xs text-paper-faint tracking-wider uppercase mb-2">
                  {post.meta.tags.join(' · ')}
                </div>
              )}
              <h2 class="text-xl sm:text-2xl font-medium text-paper group-hover:text-accent-gold transition-colors mb-2 leading-snug">
                {post.meta.title}
              </h2>
              <p class="text-paper-dim text-[0.95rem] sm:text-base leading-relaxed">
                {post.meta.description}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </main>

    <Footer variant="dark" />
  </div>
</BaseLayout>
