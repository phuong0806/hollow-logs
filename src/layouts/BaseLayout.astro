---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** theme class áp lên body — mỗi bài có thể override */
  bodyClass?: string;
  /** Canonical URL cho SEO — nếu không set sẽ không render thẻ canonical */
  canonicalUrl?: string;
}

const {
  title,
  description = 'Nhật ký học tập cá nhân',
  bodyClass = 'bg-ink text-paper font-serif text-xl',
  canonicalUrl,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title={title} href="/rss.xml" />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  <title>{title}</title>
</head>
<body class={bodyClass}>
  <slot />
</body>
</html>
