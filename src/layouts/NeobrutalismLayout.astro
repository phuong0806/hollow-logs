---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  heroColor?: 'yellow' | 'pink' | 'blue';
}

const { title, description, pubDate, tags = [], heroColor = 'yellow' } = Astro.props;
const formattedDate = pubDate.toISOString().split('T')[0];

const heroBg = {
  yellow: 'bg-accent-yellow',
  pink: 'bg-accent-pink text-white',
  blue: 'bg-accent-blue text-white',
};
---

<BaseLayout 
  title={title} 
  description={description}
  bodyClass="bg-[#fff8e7] text-black font-sans text-base min-h-screen"
>
  <!-- Dot pattern background -->
  <div class="fixed inset-0 pointer-events-none opacity-[0.08] z-0" 
       style="background-image: radial-gradient(circle, black 1.5px, transparent 1.5px); background-size: 24px 24px;">
  </div>
  
  <div class="relative z-10">
    <Nav variant="neobrutalism" logo="HOLLOW.LOGS" />
    
    <!-- Hero block -->
    <section class:list={[
      'max-w-[1100px] mx-auto my-8 mx-8 border-[4px] border-black shadow-[8px_8px_0_black] p-12',
      heroBg[heroColor]
    ]}>
      <span class="inline-block bg-black text-accent-yellow px-3 py-1 font-mono text-xs tracking-[0.15em] uppercase font-bold mb-6">
        ◆ {formattedDate} {tags.length > 0 && ` · ${tags.join(' · ')}`}
      </span>
      
      <h1 class="font-display text-7xl md:text-8xl leading-[0.95] tracking-tight uppercase text-black mb-8">
        {title}
      </h1>
      
      <div class="bg-white border-[3px] border-black p-6 font-medium text-lg max-w-2xl shadow-[4px_4px_0_black] text-black">
        {description}
      </div>
    </section>
    
    <!-- Content -->
    <main class="max-w-[1100px] mx-auto px-8 pb-16">
      <article class="prose-neo max-w-[720px] mx-auto">
        <slot />
      </article>
    </main>
    
    <Footer variant="neobrutalism" />
  </div>
</BaseLayout>
