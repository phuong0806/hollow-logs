---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  /** Label chip trên tiêu đề hero, vd: "Cơ Chế Sinh Học" */
  kicker?: string;
  /** Màu của kicker chip */
  kickerColor?: 'cyan' | 'emerald' | 'rose';
  /** Canonical URL cho SEO */
  canonicalUrl?: string;
}

const { title, description, pubDate, tags = [], kicker, kickerColor = 'cyan', canonicalUrl } = Astro.props;
const formattedDate = pubDate.toISOString().split('T')[0];

const kickerStyles = {
  cyan: 'bg-cyan-400 text-[#0B1221]',
  emerald: 'bg-emerald-500 text-[#0B1221]',
  rose: 'bg-rose-500 text-white',
};
---

<BaseLayout
  title={title}
  description={description}
  bodyClass="bg-[#0B1221] text-slate-300 font-sans min-h-screen"
  canonicalUrl={canonicalUrl}
>
  <!-- Post nav with logo + back -->
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex justify-between items-center">
    <div class="flex items-center gap-3">
      <a href="/" class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-slate-700 text-slate-400 hover:text-[#e87040] hover:border-[#e87040] transition-colors duration-300 no-underline text-lg leading-none">&larr;</a>
      <a href="/" class="no-underline">
        <Logo variant="mars" size={36} />
      </a>
    </div>
    {tags.length > 0 && (
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs tracking-wider text-slate-500 min-w-0 ml-4">
        {tags.map(tag => <span class="whitespace-nowrap">#{tag}</span>)}
      </div>
    )}
  </nav>
  
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-20 text-lg">
    <!-- Header -->
    <header>
      {tags.length > 0 && (
        <div class="flex items-center gap-3 mb-4 font-mono text-xs text-slate-500 tracking-wider uppercase">
          <span>{tags.join(' · ')}</span>
        </div>
      )}

      {kicker && (
        <span class={`inline-block font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider ${kickerStyles[kickerColor]}`}>
          {kicker}
        </span>
      )}

      <h1 class="text-3xl md:text-5xl font-bold text-white mb-3 tracking-tight">
        {title}
      </h1>
      <p class="text-slate-400 text-xl">
        {description}
      </p>
    </header>
    
    <slot />
  </main>
  
  <Footer variant="dark" />
</BaseLayout>
