---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  /** Label chip trên tiêu đề hero, vd: "Cơ Chế Sinh Học" */
  kicker?: string;
  /** Màu của kicker chip */
  kickerColor?: 'cyan' | 'emerald' | 'rose';
}

const { title, description, pubDate, tags = [], kicker, kickerColor = 'cyan' } = Astro.props;
const formattedDate = pubDate.toISOString().split('T')[0];

const kickerStyles = {
  cyan: 'bg-cyan-400 text-[#0B1221]',
  emerald: 'bg-emerald-500 text-[#0B1221]',
  rose: 'bg-rose-500 text-white',
};
---

<BaseLayout 
  title={title} 
  description={description}
  bodyClass="bg-[#0B1221] text-slate-300 font-sans min-h-screen"
>
  <Nav variant="dark" logo="hollow.logs" />
  
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-20">
    <!-- Header -->
    <header>
      <div class="flex items-center gap-3 mb-4 font-mono text-xs text-slate-500 tracking-wider uppercase">
        <span>{formattedDate}</span>
        {tags.length > 0 && (
          <span class="text-slate-700">·</span>
          <span>{tags.join(' · ')}</span>
        )}
      </div>
      
      {kicker && (
        <span class={`inline-block font-bold uppercase px-4 py-1.5 mb-4 text-sm tracking-wider ${kickerStyles[kickerColor]}`}>
          {kicker}
        </span>
      )}
      
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-3 tracking-tight">
        {title}
      </h1>
      <p class="text-slate-400 text-lg max-w-3xl">
        {description}
      </p>
    </header>
    
    <slot />
  </main>
  
  <Footer variant="dark" />
</BaseLayout>
