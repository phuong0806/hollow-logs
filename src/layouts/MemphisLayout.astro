---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  heroColor?: 'pink' | 'cyan' | 'yellow' | 'mint';
}

const { title, description, pubDate, tags = [], heroColor = 'pink' } = Astro.props;
const formattedDate = pubDate.toISOString().split('T')[0];

const heroBg = {
  pink: 'bg-memphis-pink',
  cyan: 'bg-memphis-cyan',
  yellow: 'bg-memphis-yellow',
  mint: 'bg-memphis-mint',
};
---

<BaseLayout
  title={title}
  description={description}
  bodyClass="bg-[#fffaf2] text-black font-sans text-base min-h-screen relative overflow-x-hidden"
>
  <!-- Floating geometric shapes — the Memphis signature -->
  <div class="fixed inset-0 pointer-events-none z-0">
    <!-- Squiggle top-left -->
    <svg class="absolute top-[6%] left-[5%] w-24 h-16 text-memphis-pink" viewBox="0 0 140 40" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round">
      <path d="M5 20 Q 20 0, 35 20 T 65 20 T 95 20 T 125 20" />
    </svg>
    <!-- Triangle top-right -->
    <svg class="absolute top-[14%] right-[7%] w-16 h-16 text-memphis-cyan rotate-12" viewBox="0 0 100 100">
      <polygon points="50,10 92,88 8,88" fill="currentColor" stroke="black" stroke-width="4"/>
    </svg>
    <!-- Dot grid -->
    <div class="absolute top-[42%] left-[3%] w-20 h-20 opacity-70"
         style="background-image: radial-gradient(circle, black 2px, transparent 2px); background-size: 14px 14px;"></div>
    <!-- Circle mid-right -->
    <svg class="absolute top-[55%] right-[4%] w-20 h-20 text-memphis-yellow" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="38" fill="currentColor" stroke="black" stroke-width="4"/>
    </svg>
    <!-- Zigzag bottom-left -->
    <svg class="absolute bottom-[12%] left-[8%] w-32 h-10 text-black" viewBox="0 0 140 40" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
      <polyline points="0,20 18,5 36,35 54,5 72,35 90,5 108,35 126,5 140,20" />
    </svg>
    <!-- Checkerboard bottom-right -->
    <div class="absolute bottom-[8%] right-[6%] w-16 h-16"
         style="background-image: linear-gradient(45deg, black 25%, transparent 25%, transparent 75%, black 75%), linear-gradient(45deg, black 25%, transparent 25%, transparent 75%, black 75%); background-size: 10px 10px; background-position: 0 0, 5px 5px;"></div>
    <!-- Small confetti dots -->
    <div class="absolute top-[30%] right-[22%] w-2 h-2 bg-memphis-pink rounded-full"></div>
    <div class="absolute top-[70%] left-[20%] w-3 h-3 bg-memphis-cyan rounded-full"></div>
    <div class="absolute top-[80%] right-[30%] w-2 h-2 bg-memphis-yellow rounded-full"></div>
  </div>

  <div class="relative z-10">
    <Nav variant="memphis" logo="hollow.logs" />

    <!-- Hero block -->
    <section class="max-w-[1100px] mx-auto px-8 my-10">
      <div class:list={[
        'relative border-[4px] border-black p-10 md:p-14 shadow-[10px_10px_0_black]',
        heroBg[heroColor]
      ]}>
        <!-- Decorative cut-out shapes on hero corners -->
        <svg class="absolute -top-7 -left-5 w-14 h-14 text-memphis-mint rotate-12" viewBox="0 0 100 100">
          <rect x="10" y="10" width="80" height="80" fill="currentColor" stroke="black" stroke-width="4"/>
        </svg>
        <svg class="absolute -bottom-6 -right-5 w-14 h-14 text-memphis-yellow" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="40" fill="currentColor" stroke="black" stroke-width="4"/>
        </svg>

        <span class="inline-block bg-black text-memphis-yellow px-3 py-1 font-mono text-xs tracking-[0.2em] uppercase font-bold mb-6 -rotate-2">
          ✦ {formattedDate} {tags.length > 0 && ` · ${tags.join(' · ')}`}
        </span>

        <h1 class="font-display text-6xl md:text-7xl leading-[0.95] tracking-tight uppercase text-black mb-8">
          {title}
        </h1>

        <div class="bg-white border-[3px] border-black p-5 font-medium text-lg max-w-2xl shadow-[4px_4px_0_black] text-black rotate-[-0.4deg]">
          {description}
        </div>
      </div>
    </section>

    <!-- Content -->
    <main class="max-w-[1100px] mx-auto px-8 pb-16">
      <article class="prose-memphis max-w-[720px] mx-auto">
        <slot />
      </article>
    </main>

    <Footer variant="memphis" />
  </div>
</BaseLayout>
