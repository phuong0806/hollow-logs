---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  heroColor?: 'pink' | 'cyan' | 'yellow' | 'mint';
}

const { title, description, pubDate, tags = [], heroColor = 'pink' } = Astro.props;
const formattedDate = pubDate.toISOString().split('T')[0];

const heroBg = {
  pink: 'bg-memphis-pink',
  cyan: 'bg-memphis-cyan',
  yellow: 'bg-memphis-yellow',
  mint: 'bg-memphis-mint',
};

/* Shadow color contrast — dark shadow on light hero, colored shadow on saturated hero */
const heroShadow = {
  pink: 'shadow-[10px_10px_0_black]',
  cyan: 'shadow-[10px_10px_0_black]',
  yellow: 'shadow-[10px_10px_0_black]',
  mint: 'shadow-[10px_10px_0_black]',
};

/* Accent color for decorative shapes on the hero */
const cornerAccent = {
  pink: 'text-memphis-yellow',
  cyan: 'text-memphis-pink',
  yellow: 'text-memphis-cyan',
  mint: 'text-memphis-pink',
};
---

<BaseLayout
  title={title}
  description={description}
  bodyClass="bg-[#fffaf2] text-black font-poppins text-base min-h-screen relative overflow-x-hidden"
>
  <!-- Floating geometric shapes — the Memphis signature -->
  <div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
    <!-- Squiggle top-left -->
    <svg class="absolute top-[5%] left-[4%] w-28 h-20 text-memphis-pink" viewBox="0 0 160 50" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round">
      <path d="M5 25 Q 20 5, 40 25 T 75 25 T 110 25 T 145 25" />
    </svg>

    <!-- Triangle top-right -->
    <svg class="absolute top-[12%] right-[6%] w-20 h-20 text-memphis-cyan rotate-12" viewBox="0 0 100 100">
      <polygon points="50,8 95,90 5,90" fill="currentColor" stroke="black" stroke-width="4"/>
    </svg>

    <!-- Plus / cross shape — iconic Memphis motif -->
    <svg class="absolute top-[28%] left-[6%] w-14 h-14 text-memphis-yellow" viewBox="0 0 100 100">
      <rect x="35" y="5" width="30" height="90" fill="currentColor" stroke="black" stroke-width="4"/>
      <rect x="5" y="35" width="90" height="30" fill="currentColor" stroke="black" stroke-width="4"/>
    </svg>

    <!-- Dot grid -->
    <div class="absolute top-[44%] left-[3%] w-24 h-24 opacity-60"
         style="background-image: radial-gradient(circle, black 2px, transparent 2px); background-size: 14px 14px;"></div>

    <!-- Half-circle mid-right -->
    <svg class="absolute top-[38%] right-[4%] w-20 h-12 text-memphis-pink" viewBox="0 0 120 60">
      <path d="M5 60 A55 55 0 0 1 115 60Z" fill="currentColor" stroke="black" stroke-width="4"/>
    </svg>

    <!-- Circle lower-right -->
    <svg class="absolute top-[58%] right-[5%] w-16 h-16 text-memphis-yellow" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="38" fill="currentColor" stroke="black" stroke-width="4"/>
    </svg>

    <!-- Zigzag bottom-left -->
    <svg class="absolute bottom-[14%] left-[7%] w-36 h-12 text-black" viewBox="0 0 160 40" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
      <polyline points="0,20 20,5 40,35 60,5 80,35 100,5 120,35 140,5 160,20" />
    </svg>

    <!-- Checkerboard bottom-right -->
    <div class="absolute bottom-[8%] right-[6%] w-20 h-20"
         style="background-image: linear-gradient(45deg, black 25%, transparent 25%, transparent 75%, black 75%), linear-gradient(45deg, black 25%, transparent 25%, transparent 75%, black 75%); background-size: 10px 10px; background-position: 0 0, 5px 5px;"></div>

    <!-- Squiggle bottom-right (horizontal wave) -->
    <svg class="absolute bottom-[30%] right-[10%] w-24 h-8 text-memphis-mint" viewBox="0 0 140 30" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
      <path d="M5 15 Q 20 0, 35 15 T 65 15 T 95 15 T 125 15" />
    </svg>

    <!-- Confetti dots -->
    <div class="absolute top-[22%] right-[20%] w-3 h-3 bg-memphis-pink rounded-full border border-black"></div>
    <div class="absolute top-[68%] left-[18%] w-4 h-4 bg-memphis-cyan rounded-full border border-black"></div>
    <div class="absolute top-[78%] right-[28%] w-2.5 h-2.5 bg-memphis-yellow rounded-full border border-black"></div>
    <div class="absolute top-[15%] left-[30%] w-2 h-2 bg-memphis-mint rounded-full"></div>
    <div class="absolute top-[52%] left-[12%] w-2 h-2 bg-memphis-pink rounded-full"></div>
    <div class="absolute top-[85%] left-[35%] w-3 h-3 bg-memphis-yellow rounded-full border border-black"></div>
  </div>

  <div class="relative z-10">
    <!-- Post nav with logo + back -->
    <nav class="max-w-[1100px] mx-auto px-8 py-6 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <a href="/" class="inline-flex items-center justify-center w-10 h-10 bg-black text-white border-[3px] border-black no-underline hover:bg-memphis-pink hover:border-black transition-colors text-xl leading-none">&larr;</a>
        <a href="/" class="no-underline">
          <Logo variant="mars" size={36} />
        </a>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs tracking-wider text-neutral-600 min-w-0 ml-4">
          {tags.map(tag => <span class="whitespace-nowrap">#{tag}</span>)}
        </div>
      )}
    </nav>

    <!-- Hero block -->
    <section class="max-w-[1400px] mx-auto px-8 my-10">
      <div class:list={[
        'relative border-[4px] border-black p-10 md:p-14',
        heroBg[heroColor],
        heroShadow[heroColor]
      ]}>
        <!-- Decorative cut-out shapes on hero corners -->
        <svg class:list={['absolute -top-7 -left-6 w-16 h-16 rotate-12', cornerAccent[heroColor]]} viewBox="0 0 100 100">
          <rect x="8" y="8" width="84" height="84" fill="currentColor" stroke="black" stroke-width="4"/>
        </svg>
        <svg class="absolute -bottom-6 -right-6 w-16 h-16 text-memphis-mint" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="42" fill="currentColor" stroke="black" stroke-width="4"/>
        </svg>
        <!-- Small triangle accent -->
        <svg class="absolute -top-4 right-16 w-8 h-8 text-memphis-pink rotate-6" viewBox="0 0 60 60">
          <polygon points="30,5 55,52 5,52" fill="currentColor" stroke="black" stroke-width="3"/>
        </svg>

        {tags.length > 0 && (
          <span class="inline-block bg-black text-memphis-yellow px-3 py-1 font-mono text-xs tracking-[0.2em] uppercase font-bold mb-6 -rotate-2">
            ◆ {tags.join(' · ')}
          </span>
        )}

        <h1 class="font-display text-6xl sm:text-7xl md:text-8xl leading-[0.92] tracking-tight uppercase text-black mb-8">
          {title}
        </h1>

        <div class="flex flex-col sm:flex-row sm:items-end gap-6">
          <div class="bg-white border-[3px] border-black p-5 sm:p-6 font-medium text-lg max-w-2xl shadow-[4px_4px_0_black] text-black rotate-[-0.5deg] font-poppins">
            {description}
          </div>
          <span class="inline-block bg-black text-white px-4 py-2 font-mono text-xs tracking-wider shrink-0 self-start sm:self-auto shadow-[3px_3px_0_var(--color-memphis-pink)]">
            {formattedDate}
          </span>
        </div>
      </div>
    </section>

    <!-- Content -->
    <main class="max-w-[1400px] mx-auto px-8 pb-16">
      <article class="prose-memphis max-w-[920px] mx-auto">
        <slot />
      </article>
    </main>

    <Footer variant="memphis" />
  </div>
</BaseLayout>
