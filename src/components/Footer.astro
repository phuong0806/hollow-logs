---
interface Props {
  variant?: 'dark' | 'light' | 'neobrutalism' | 'editorial' | 'memphis' | 'zine' | 'dark-ui' | 'mars';
}

const { variant = 'dark' } = Astro.props;
const year = new Date().getFullYear();

const styles = {
  dark: 'max-w-[720px] mx-auto px-8 py-8 border-t border-border-subtle text-center font-mono text-xs text-paper-faint tracking-wider',
  light: 'max-w-[720px] mx-auto px-8 py-8 border-t border-neutral-300 text-center font-mono text-xs text-neutral-500 tracking-wider',
  neobrutalism: 'max-w-[1100px] mx-auto mt-12 mb-8 mx-8 px-8 py-6 bg-black text-white border-[4px] border-black shadow-[6px_6px_0_black] text-center font-mono text-sm tracking-wider',
  editorial: 'max-w-[1000px] mx-auto px-8 py-8 mt-16 border-t-[3px] border-double border-neutral-900 text-center font-sans text-xs text-neutral-600 tracking-wider uppercase',
  memphis: 'max-w-[1100px] mx-auto mt-12 mb-10 px-8 py-6 bg-memphis-cyan text-black border-[4px] border-black shadow-[6px_6px_0_black] text-center font-mono text-sm tracking-wider -rotate-[0.4deg]',
  zine: 'max-w-[900px] mx-auto px-8 py-6 mt-16 border-t-2 border-dashed border-zinc-900 text-center font-mono text-[11px] text-zinc-700 tracking-[0.22em] uppercase',
  'dark-ui': 'max-w-[960px] mx-auto px-4 sm:px-8 py-6 mt-16 border-t border-zinc-800 flex items-center justify-between font-mono text-[11px] text-zinc-500 tracking-wider',
  mars: 'max-w-[680px] mx-auto px-5 sm:px-8 py-8 mt-12 border-t border-[#2a1f18] flex items-center justify-between font-mono text-[10px] sm:text-[11px] text-[#5a5044] tracking-[0.2em]',
};

const c = styles[variant];
---

<footer class={c}>
  {variant === 'mars' ? (
    <>
      <span class="flex items-center gap-2">
        <span class="inline-block w-1 h-1 rounded-full bg-[#e87040]"></span>
        <span class="uppercase">hollow.logs · {year}</span>
      </span>
      <span class="text-[#3d3428] uppercase">Signal from Mars</span>
    </>
  ) : variant === 'dark-ui' ? (
    <>
      <span><span class="text-emerald-400">$</span> echo "© {year} hollow.logs"</span>
      <span class="text-zinc-600">exit 0</span>
    </>
  ) : (
    <>
      © {year} — hollow.logs
      {variant === 'neobrutalism' && ' · '}
      {variant === 'neobrutalism' && <span class="text-accent-yellow">BUILT WITH LOVE</span>}
      {variant === 'memphis' && ' · '}
      {variant === 'memphis' && <span class="font-display tracking-wider">STAY WEIRD</span>}
      {variant === 'zine' && ' · '}
      {variant === 'zine' && <span class="text-zine-red font-bold">CUT. PASTE. PUBLISH.</span>}
    </>
  )}
</footer>
