---
interface Props {
  /** Dark variant cho bg tối, light cho bg sáng */
  variant?: 'dark' | 'light' | 'neobrutalism' | 'editorial' | 'memphis' | 'zine' | 'dark-ui' | 'mars';
  /** Tên logo */
  logo?: string;
}

const { variant = 'dark', logo = 'hollow.logs' } = Astro.props;

// Style cho từng variant
const styles = {
  dark: {
    wrapper: 'max-w-[720px] mx-auto px-8 pt-10 pb-4 flex justify-between items-center font-mono text-xs tracking-wider',
    logo: 'text-accent-gold font-medium no-underline',
    link: 'text-paper-dim hover:text-paper ml-8 transition-colors no-underline',
  },
  light: {
    wrapper: 'max-w-[720px] mx-auto px-8 pt-10 pb-4 flex justify-between items-center font-mono text-xs tracking-wider',
    logo: 'text-accent-red font-medium no-underline',
    link: 'text-neutral-600 hover:text-neutral-900 ml-8 transition-colors no-underline',
  },
  neobrutalism: {
    wrapper: 'max-w-[1100px] mx-auto px-8 py-6 flex justify-between items-center',
    logo: 'bg-black text-accent-yellow px-4 py-2 font-display text-xl tracking-wider border-[3px] border-black shadow-[4px_4px_0_black] -rotate-1 no-underline',
    link: 'bg-black text-white px-4 py-2 font-mono text-sm uppercase tracking-wider border-[3px] border-black font-bold no-underline ml-3',
  },
  editorial: {
    wrapper: 'max-w-[1000px] mx-auto px-8 py-6 border-b-[3px] border-double border-neutral-900 flex justify-between items-baseline',
    logo: 'font-editorial italic text-3xl font-black no-underline text-neutral-900',
    link: 'font-sans text-[11px] tracking-[0.2em] uppercase text-neutral-600 hover:text-neutral-900 ml-6 no-underline',
  },
  memphis: {
    wrapper: 'max-w-[1100px] mx-auto px-8 py-6 flex justify-between items-center',
    logo: 'bg-memphis-pink text-black px-4 py-2 font-display text-xl tracking-wider border-[3px] border-black shadow-[4px_4px_0_black] -rotate-2 no-underline',
    link: 'bg-memphis-cyan text-black px-3 py-1.5 font-mono text-[11px] uppercase tracking-wider border-[3px] border-black font-bold no-underline ml-3 hover:-rotate-3 transition-transform',
  },
  zine: {
    wrapper: 'max-w-[900px] mx-auto px-8 pt-8 pb-3 flex justify-between items-baseline font-mono text-[11px] uppercase tracking-[0.22em] border-b-2 border-dashed border-zinc-900',
    logo: 'font-display text-2xl tracking-tight text-zinc-900 no-underline normal-case',
    link: 'text-zinc-700 hover:text-zine-red ml-6 no-underline underline underline-offset-[6px] decoration-dotted decoration-2',
  },
  'dark-ui': {
    wrapper: 'max-w-[960px] mx-auto px-4 sm:px-8 pt-8 pb-3 flex justify-between items-center font-mono text-xs border-b border-zinc-800',
    logo: 'text-emerald-400 no-underline',
    link: 'text-zinc-500 hover:text-zinc-100 ml-6 no-underline transition-colors',
  },
  mars: {
    wrapper: 'max-w-[680px] mx-auto px-5 sm:px-8 pt-10 pb-4 flex justify-between items-center font-mono text-[11px] tracking-[0.2em]',
    logo: 'text-[#e87040] font-medium no-underline font-space',
    link: 'text-[#5a5044] hover:text-[#d4c4a8] ml-6 sm:ml-8 transition-colors duration-300 no-underline',
  },
};

const s = styles[variant];
---

<nav class={s.wrapper}>
  <a href="/" class={s.logo}>{logo}</a>
  <div>
    <a href="/" class={s.link}>posts</a>
    <a href="/about" class={s.link}>about</a>
    <a href="/rss.xml" class={s.link}>rss</a>
  </div>
</nav>
