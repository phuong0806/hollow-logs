---
import type { Post } from '../lib/posts';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<div>
  <!-- Search + count -->
  <div class="flex items-center gap-3 mb-6">
    <div class="relative flex-1">
      <input
        type="text"
        id="post-search"
        placeholder="Tìm kiếm bài viết..."
        autocomplete="off"
        class="w-full bg-[#1a120e] border border-[#2a1f18] rounded-lg px-4 py-2.5 pr-9 font-mono text-xs text-[#d4c4a8] placeholder-[#4a4238] focus:outline-none focus:border-[#e87040]/40 transition-colors duration-200"
      />
      <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-[#4a4238]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </div>
    <div class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#5a5044] shrink-0 tabular-nums">
      <span id="post-count">{posts.length}</span> bản ghi
    </div>
  </div>

  <!-- Post list -->
  <div id="post-list" class="space-y-4">
    {posts.map(post => (
      <a
        href={post.url}
        class="group block no-underline rounded-xl border border-[#2a1f18]/80 bg-[#1a120e] hover:bg-[#221810] hover:border-[#e87040]/30 transition-all duration-300 overflow-hidden"
        data-title={post.meta.title.toLowerCase()}
        data-description={(post.meta.description ?? '').toLowerCase()}
        data-tags={(post.meta.tags ?? []).join(' ').toLowerCase()}
      >
        <div class="flex">
          <div class="w-1 shrink-0 bg-[#e87040]/20 group-hover:bg-[#e87040]/60 transition-colors duration-300"></div>
          <div class="px-5 sm:px-6 py-5 sm:py-6 flex-1 min-w-0 bg-[#241a14] group-hover:bg-[#2a1e16] transition-colors duration-300">
            <h2 class="text-xl sm:text-2xl font-medium text-[#e8dcc8] group-hover:text-[#e87040] transition-colors duration-300 mb-2 leading-snug font-space">
              {post.meta.title}
            </h2>
            <p class="text-[#a89880] text-[0.78rem] sm:text-[0.82rem] leading-relaxed group-hover:text-[#b8a890] transition-colors duration-300 mb-3">
              {post.meta.description}
            </p>
            <div class="flex items-center justify-between gap-x-3 font-mono text-[10px] sm:text-[11px] tracking-[0.2em] uppercase">
              <div class="flex flex-wrap gap-x-2 gap-y-1">
                {post.meta.tags && post.meta.tags.slice(0, 3).map(tag => (
                  <span class="text-[#e87040]/70">#{tag}</span>
                ))}
              </div>
              <span class="text-[#7a6d5e] shrink-0">
                {new Date(post.meta.pubDate).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' })}
              </span>
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>

  <p id="no-results" class="hidden text-center py-12 font-mono text-xs tracking-[0.15em] text-[#4a4238]">
    Không tìm thấy bài viết nào.
  </p>
</div>

<script>
  const search = document.getElementById('post-search') as HTMLInputElement | null;
  const countEl = document.getElementById('post-count');
  const noResults = document.getElementById('no-results');
  const items = document.querySelectorAll<HTMLAnchorElement>('#post-list > a');

  search?.addEventListener('input', () => {
    const q = search.value.toLowerCase().trim();
    let visible = 0;

    items.forEach(item => {
      const match =
        !q ||
        (item.dataset.title ?? '').includes(q) ||
        (item.dataset.description ?? '').includes(q) ||
        (item.dataset.tags ?? '').includes(q);

      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    if (countEl) countEl.textContent = String(visible);
    noResults?.classList.toggle('hidden', visible > 0);
  });
</script>
